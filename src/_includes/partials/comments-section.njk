<section class="section o2f-comments-section bg-white/[0.015]" id="service-comments">
  <div class="container-x">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-10">
      <div>
        <p class="section-kicker" data-aos="fade-up">{{ 'آراء العملاء' if lang == 'ar' else 'Client feedback' }}</p>
        <h2 class="section-title mb-3" data-aos="fade-up" data-aos-delay="80">{{ 'تجارب العملاء مع O2F' if lang == 'ar' else 'Client experiences with O2F' }}</h2>
        <p class="text-brand-off/65 max-w-2xl leading-relaxed" data-aos="fade-up" data-aos-delay="140">{{ 'تعليقات عربية وإنجليزية تظهر معًا كما كتبها العملاء بعد مراجعتها.' if lang == 'ar' else 'Arabic and English comments appear together as written after review.' }}</p>
      </div>
      <a href="#comment-form" class="btn-ghost self-start lg:self-auto" data-aos="fade-up" data-aos-delay="180">{{ 'اكتب تعليقك' if lang == 'ar' else 'Write a comment' }}</a>
    </div>

    <div class="o2f-comments-marquee" data-aos="fade-up" data-aos-delay="220">
      <div class="o2f-comments-track o2f-comments-row-a" id="o2f-comments-track">
        {% for item in comments.items %}{% if item.status == 'approved' %}
        <article class="o2f-comment-card">
          <div class="flex items-start justify-between gap-3 mb-4">
            <div><h3 class="text-lg font-bold text-brand-off">{{ item.name }}</h3><p class="text-xs text-brand-mint mt-1">{{ item.service }}</p></div>
            <div class="text-brand-gold text-sm">★★★★★</div>
          </div>
          <p class="text-brand-off/70 text-sm leading-relaxed">“{{ item.comment }}”</p>
        </article>
        {% endif %}{% endfor %}
      </div>
      <div class="o2f-comments-track o2f-comments-row-b" id="o2f-comments-track-secondary">
        {% for item in comments.items %}{% if item.status == 'approved' %}
        <article class="o2f-comment-card">
          <div class="flex items-start justify-between gap-3 mb-4">
            <div><h3 class="text-lg font-bold text-brand-off">{{ item.name }}</h3><p class="text-xs text-brand-mint mt-1">{{ item.service }}</p></div>
            <div class="text-brand-gold text-sm">★★★★★</div>
          </div>
          <p class="text-brand-off/70 text-sm leading-relaxed">“{{ item.comment }}”</p>
        </article>
        {% endif %}{% endfor %}
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_.85fr] gap-6 mt-10 items-stretch">
      <div class="card card-hover" data-aos="fade-up">
        <h3 class="text-2xl mb-3">{{ 'شارك تجربتك' if lang == 'ar' else 'Share your experience' }}</h3>
        <p class="text-brand-off/65 text-sm leading-relaxed mb-5">{{ 'التعليق ينتقل للمراجعة، ثم يمكن قبوله أو تعديله من لوحة الإدارة.' if lang == 'ar' else 'The comment goes to review, then it can be approved or edited from the admin panel.' }}</p>
        <form id="comment-form" class="o2f-comment-form">
          <div class="grid sm:grid-cols-2 gap-3"><input id="o2f-comment-name" type="text" required maxlength="40" placeholder="{{ 'الاسم' if lang == 'ar' else 'Name' }}"><input id="o2f-comment-service" type="text" maxlength="60" placeholder="{{ 'الخدمة / الباقة' if lang == 'ar' else 'Service / plan' }}"></div>
          <textarea id="o2f-comment-text" required maxlength="320" rows="4" placeholder="{{ 'اكتب تعليقك هنا...' if lang == 'ar' else 'Write your comment here...' }}"></textarea>
          <button type="submit" class="btn-primary justify-center w-full sm:w-auto">{{ 'إرسال للمراجعة' if lang == 'ar' else 'Submit for review' }}</button>
          <p id="o2f-comment-status" class="text-sm text-brand-mint mt-3 hidden"></p>
        </form>
      </div>
      <div class="card border-brand-mint/25 bg-brand-mint/5" data-aos="fade-up" data-aos-delay="120">
        <h3 class="text-xl mb-3">{{ 'إدارة التعليقات' if lang == 'ar' else 'Comment moderation' }}</h3>
        <ul class="space-y-3 text-sm text-brand-off/70 leading-relaxed"><li>✓ {{ 'العميل يرسل الاسم والتعليق.' if lang == 'ar' else 'Client submits name and comment.' }}</li><li>✓ {{ 'الأدمن يراجع التعليقات في لوحة الإدارة.' if lang == 'ar' else 'Admin reviews comments in the admin panel.' }}</li><li>✓ {{ 'يمكن القبول أو الرفض أو التعديل.' if lang == 'ar' else 'Admin can approve, reject, or edit.' }}</li></ul>
      </div>
    </div>
  </div>
</section>
<style>
.o2f-comments-marquee{display:grid;gap:1rem;overflow:hidden;padding:.35rem 0;mask-image:linear-gradient(90deg,transparent,#000 10%,#000 90%,transparent)}
.o2f-comments-track{display:flex;align-items:stretch;gap:1.15rem;width:max-content;min-width:200%;will-change:transform}
.o2f-comments-row-a{animation:o2fCommentsMoveLtr 72s linear infinite}
.o2f-comments-row-b{animation:o2fCommentsMoveRtl 86s linear infinite;animation-delay:-28s;transform:translateX(-50%)}
.o2f-comments-track:hover{animation-play-state:paused}
.o2f-comment-card{flex:0 0 clamp(280px,28vw,360px);width:clamp(280px,28vw,360px);min-height:220px;padding:1.15rem;border-radius:1.25rem;background:linear-gradient(145deg,rgba(255,255,255,.075),rgba(255,255,255,.035));border:1px solid rgba(255,255,255,.12);box-shadow:0 18px 45px rgba(0,0,0,.22);transition:transform .25s ease,border-color .25s ease,background .25s ease;overflow:hidden}
.o2f-comment-card p,.o2f-comment-card h3{overflow-wrap:anywhere;text-wrap:pretty}
.o2f-comment-card:hover{transform:translateY(-5px);border-color:rgba(0,217,163,.45);background:rgba(0,217,163,.075)}
.o2f-comment-form{display:grid;gap:.85rem}
.o2f-comment-form input,.o2f-comment-form textarea{width:100%;border:1px solid rgba(255,255,255,.12);border-radius:.95rem;padding:.85rem 1rem;color:#F7F8FA;background:rgba(255,255,255,.055);outline:none;resize:vertical}
@keyframes o2fCommentsMoveLtr{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes o2fCommentsMoveRtl{from{transform:translateX(-50%)}to{transform:translateX(0)}}
html[dir="rtl"] .o2f-comments-track{animation-name:o2fCommentsMoveRtl}
html[dir="rtl"] .o2f-comments-row-b{animation-name:o2fCommentsMoveLtr}
html[dir="rtl"] .o2f-comment-card{direction:rtl;text-align:right}
@media(max-width:640px){.o2f-comments-marquee{gap:.85rem;mask-image:linear-gradient(90deg,transparent,#000 14%,#000 86%,transparent)}.o2f-comments-track{gap:.85rem}.o2f-comments-row-a{animation-duration:82s}.o2f-comments-row-b{animation-duration:96s}.o2f-comment-card{flex-basis:min(78vw,300px);width:min(78vw,300px);min-height:210px}.o2f-comment-card:hover{transform:none}}
</style>
<script>(function(){
var SUPABASE_URL='https://qalzanmeusuqssrgxumg.supabase.co';
var SUPABASE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFhbHphbm1ldXN1cXNzcmd4dW1nIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc2MjAxMDMsImV4cCI6MjA5MzE5NjEwM30.PHP_zC5firTlCfA9zFLXO1iqzUXMbiTsM6-7wKsDPOU';
var rows=Array.from(document.querySelectorAll('.o2f-comments-track')),t=document.getElementById('o2f-comments-track'),f=document.getElementById('comment-form');if(!t||!f||!rows.length)return;
function clean(v){return String(v||'').replace(/[<>]/g,'').trim()}
function api(path,opts){opts=opts||{};opts.headers=Object.assign({'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY,'Content-Type':'application/json','Prefer':'return=representation'},opts.headers||{});return fetch(SUPABASE_URL+'/rest/v1/'+path,opts)}
function card(x){return '<article class="o2f-comment-card"><div class="flex items-start justify-between gap-3 mb-4"><div><h3 class="text-lg font-bold text-brand-off">'+clean(x.name)+'</h3><p class="text-xs text-brand-mint mt-1">'+clean(x.service||'O2F')+'</p></div><div class="text-brand-gold text-sm">★★★★★</div></div><p class="text-brand-off/70 text-sm leading-relaxed">“'+clean(x.comment)+'”</p></article>'}
function repeat(html){return html+html+html}
function loadFallback(){rows.forEach(function(row){var cards=Array.from(row.children).map(function(el){return el.outerHTML}).join('');row.innerHTML=repeat(cards)})}
function fillRows(data){var a=data.map(card).join(''),b=data.slice().reverse().map(card).join('');rows[0].innerHTML=repeat(a);if(rows[1])rows[1].innerHTML=repeat(b)}
async function loadApproved(){try{var res=await api('comments?select=id,name,service,comment,rating,status&status=eq.approved&order=created_at.desc&limit=12');if(!res.ok)throw new Error('load failed');var data=await res.json();if(data.length){fillRows(data)}else{loadFallback()}}catch(e){loadFallback()}}
loadApproved();
f.addEventListener('submit',async function(e){e.preventDefault();var s=document.getElementById('o2f-comment-status');s.classList.remove('hidden');s.textContent='{{ 'جاري إرسال التعليق...' if lang == 'ar' else 'Submitting your comment...' }}';var item={name:clean(document.getElementById('o2f-comment-name').value),service:clean(document.getElementById('o2f-comment-service').value||'O2F'),comment:clean(document.getElementById('o2f-comment-text').value),status:'pending',rating:5};try{var res=await api('comments',{method:'POST',body:JSON.stringify(item)});if(!res.ok)throw new Error('submit failed');f.reset();s.textContent='{{ 'تم إرسال تعليقك للمراجعة.' if lang == 'ar' else 'Your comment was submitted for review.' }}'}catch(err){s.textContent='{{ 'تعذر إرسال التعليق الآن. حاول لاحقًا.' if lang == 'ar' else 'Could not submit now. Please try again later.' }}'}})
})();</script>
