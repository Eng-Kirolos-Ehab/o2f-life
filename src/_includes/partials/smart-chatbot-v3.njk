{# Consultative free chatbot — goal understanding, plan recommendation, sales guidance, no external API #}
<div id="o2f-chatbot" class="o2f-chatbot" data-lang="{{ lang }}">
  <button id="o2f-chat-toggle" class="o2f-chat-toggle" type="button" aria-label="{{ 'افتح مساعد الباقات' if lang == 'ar' else 'Open plan assistant' }}"><span class="o2f-chat-dot"></span><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/><path d="M8 10h8M8 14h5"/></svg></button>
  <section id="o2f-chat-panel" class="o2f-chat-panel" aria-live="polite">
    <header class="o2f-chat-head"><div><strong>{{ 'مساعد O2F لاختيار الباقة' if lang == 'ar' else 'O2F Plan Assistant' }}</strong><span>{{ 'يفهم هدفك ويرشح الباقة والمدة الأنسب' if lang == 'ar' else 'Understands your goal and recommends the right plan' }}</span></div><button id="o2f-chat-close" type="button">×</button></header>
    <div id="o2f-chat-messages" class="o2f-chat-messages"></div>
    <div id="o2f-chat-quick" class="o2f-chat-quick"></div>
    <form id="o2f-chat-form" class="o2f-chat-form"><input id="o2f-chat-input" type="text" autocomplete="off" placeholder="{{ 'مثال: عايز اخس 12 كيلو ومش بروح جيم' if lang == 'ar' else 'Example: I want to lose 10 kg and train at home' }}"><button type="submit">{{ 'إرسال' if lang == 'ar' else 'Send' }}</button></form>
  </section>
</div>

<style>
.o2f-chatbot,.o2f-chatbot *{box-sizing:border-box}.o2f-chatbot{position:fixed;z-index:80;font-family:inherit}html[dir="ltr"] .o2f-chatbot{right:1.25rem;bottom:5.9rem}html[dir="rtl"] .o2f-chatbot{right:1.25rem;bottom:1.25rem}.o2f-chat-toggle{position:relative;width:3.6rem;height:3.6rem;border:0;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;color:#07111F;background:linear-gradient(135deg,#00D9A3,#C9A84A);box-shadow:0 20px 45px rgba(0,0,0,.35);transition:.2s}.o2f-chat-toggle:hover{transform:translateY(-2px);filter:brightness(1.05)}.o2f-chat-dot{position:absolute;top:.45rem;right:.45rem;width:.65rem;height:.65rem;border-radius:999px;background:#fff;border:2px solid #0B1220}.o2f-chat-panel{position:absolute;bottom:4.4rem;right:0;width:min(410px,calc(100vw - 2rem));max-height:min(700px,calc(100vh - 8rem));overflow:hidden;display:none;flex-direction:column;color:#F7F8FA;background:rgba(11,18,32,.96);border:1px solid rgba(255,255,255,.12);border-radius:1.4rem;box-shadow:0 28px 70px rgba(0,0,0,.48);backdrop-filter:blur(18px)}.o2f-chatbot.is-open .o2f-chat-panel{display:flex}.o2f-chat-head{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1rem;border-bottom:1px solid rgba(255,255,255,.1);background:radial-gradient(circle at top right,rgba(0,217,163,.18),transparent 48%)}.o2f-chat-head strong{display:block;font-size:1rem}.o2f-chat-head span{display:block;margin-top:.25rem;font-size:.75rem;line-height:1.45;color:rgba(247,248,250,.62)}.o2f-chat-head button{width:2rem;height:2rem;border:1px solid rgba(255,255,255,.12);border-radius:999px;color:rgba(247,248,250,.8);background:rgba(255,255,255,.06);cursor:pointer;font-size:1.25rem}.o2f-chat-messages{padding:1rem;overflow-y:auto;display:flex;flex-direction:column;gap:.7rem;min-height:310px}.o2f-msg{display:flex;width:100%;animation:o2fMsgIn .18s ease-out}.o2f-msg.bot{justify-content:flex-start}.o2f-msg.user{justify-content:flex-end}.o2f-bubble{max-width:92%;padding:.78rem .9rem;border-radius:1rem;font-size:.86rem;line-height:1.7;white-space:pre-line}.o2f-msg.bot .o2f-bubble{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.09);color:rgba(247,248,250,.9);border-start-start-radius:.3rem}.o2f-msg.user .o2f-bubble{background:rgba(0,217,163,.16);border:1px solid rgba(0,217,163,.28);color:#F7F8FA;border-end-end-radius:.3rem}.o2f-typing .o2f-bubble{display:inline-flex;gap:.35rem;min-width:4.4rem}.o2f-typing-dot{width:.38rem;height:.38rem;border-radius:999px;background:rgba(247,248,250,.72);animation:o2fDot 1s infinite ease-in-out}.o2f-typing-dot:nth-child(2){animation-delay:.15s}.o2f-typing-dot:nth-child(3){animation-delay:.3s}.o2f-chat-quick{padding:0 1rem .9rem;display:flex;gap:.45rem;flex-wrap:wrap;max-height:180px;overflow-y:auto}.o2f-chip{border:1px solid rgba(0,217,163,.28);color:#00D9A3;background:rgba(0,217,163,.08);border-radius:999px;padding:.45rem .65rem;font-size:.74rem;cursor:pointer;transition:.15s}.o2f-chip:hover{background:rgba(0,217,163,.16);transform:translateY(-1px)}.o2f-chat-form{display:flex;gap:.5rem;padding:.85rem;border-top:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.03)}.o2f-chat-form input{min-width:0;flex:1;border:1px solid rgba(255,255,255,.12);border-radius:.9rem;padding:.75rem .85rem;color:#F7F8FA;background:rgba(255,255,255,.06);outline:none}.o2f-chat-form button{border:0;border-radius:.9rem;padding:.75rem .95rem;color:#07111F;background:#00D9A3;font-weight:800;cursor:pointer}@keyframes o2fMsgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}@keyframes o2fDot{0%,80%,100%{transform:translateY(0);opacity:.35}40%{transform:translateY(-4px);opacity:1}}@media(max-width:640px){html[dir="ltr"] .o2f-chatbot{right:1rem;bottom:5.75rem}html[dir="rtl"] .o2f-chatbot{right:1rem;bottom:1rem}.o2f-chat-panel{position:fixed;left:1rem;right:1rem;bottom:5.8rem;width:auto;max-height:calc(100vh - 7rem)}}
</style>

<script>
(function(){
  var root=document.getElementById('o2f-chatbot'); if(!root)return;
  var lang=root.getAttribute('data-lang')==='ar'?'ar':'en', isAr=lang==='ar';
  var whatsappNumber='{{ site.whatsapp | replace("+", "") | replace(" ", "") }}';
  var elToggle=document.getElementById('o2f-chat-toggle'), elClose=document.getElementById('o2f-chat-close'), elMessages=document.getElementById('o2f-chat-messages'), elQuick=document.getElementById('o2f-chat-quick'), elForm=document.getElementById('o2f-chat-form'), elInput=document.getElementById('o2f-chat-input');
  var busy=false, leadDraft='', lastInsight=null;
  var T=isAr?{
    hello:'أهلًا 👋 أنا مش مجرد FAQ. احكيلي هدفك بصيغة طبيعية، مثلًا: “عايز أخس 10 كيلو ومش فاضي غير 3 أيام” أو “عايز أزيد عضل”. هحلل كلامك وأرشح لك الباقة والمدة الأنسب.',
    ask:'احكيلي هدفك الحالي: تخس؟ تزيد عضل؟ طاقة وصحة؟ مكافحة شيخوخة؟ مع السن/الوزن/الطول لو متاح.',
    fallback:'محتاج تفاصيل أكتر عشان أرشح صح. اكتب هدفك + هل تتمرن + المدة اللي عايز تشوف فيها نتيجة.',
    safety:'تنبيه: لو عندك مرض، إصابة، أدوية، أو تفكر في الميثيلين بلو، لازم تقييم متخصص. الشات للتوجيه العام وليس وصف علاج.',
    wa:'مرحبا كابتن أسامة، أريد ترشيح الباقة المناسبة. هذه بياناتي: ',
    quick:['رشح لي باقة','عايز أخس','عايز أزيد عضل','مكافحة الشيخوخة','الأسعار والعروض','المتابعة','الميثيلين بلو']
  }:{
    hello:'Hi 👋 I am not just an FAQ. Tell me your goal naturally, for example: “I want to lose 10 kg and can train 3 days” or “I want to build muscle”. I will analyze it and recommend the best plan and duration.',
    ask:'Tell me your goal: fat loss, muscle gain, energy, health, or anti-aging. Add age/weight/height if available.',
    fallback:'I need more detail to recommend properly. Type your goal + training status + how fast you want results.',
    safety:'Note: if you have a condition, injury, medication, or you are considering methylene blue, you need professional assessment. This chat is general guidance only.',
    wa:'Hi Coach Osama, I want a plan recommendation. My details: ',
    quick:['Recommend a plan','I want fat loss','I want muscle gain','Anti-aging','Pricing & offers','Follow-up','Methylene blue']
  };

  var plans=isAr?{
    basic:{name:'الباقة الأساسية', fit:'مناسبة كبداية لشخص هدفه بسيط أو يريد تنظيم الأكل والتمرين بدون متابعة مكثفة.', result:'نتائجها المتوقعة: تنظيم عادات، بداية نزول وزن أو تحسين أداء، وفهم أوضح للأكل والتمرين.', months:'شهر واحد مناسب للتجربة، لكن 3 شهور أفضل لو الهدف خسارة وزن واضحة.'},
    standard:{name:'باقة التحول والمتابعة', fit:'أنسب اختيار لمعظم العملاء: خسارة وزن، شد جسم، زيادة عضل تدريجية، أو الالتزام الحقيقي.', result:'نتائجها المتوقعة: تغيير أوضح في المقاسات، التزام أعلى، تعديل أسبوعي، ومتابعة تساعدك تكمل.', months:'أرشح 3 شهور كحد أدنى. لو الهدف أكبر من 8–10 كيلو أو تغيير شكل الجسم بوضوح، 6 شهور أذكى.'},
    advanced:{name:'الباقة المتقدمة / الشاملة', fit:'مناسبة لو الهدف كبير، عندك ثبات سابق، تحتاج متابعة دقيقة، أو تريد خطة صحة وطاقة ومكافحة شيخوخة بجانب الجسم.', result:'نتائجها المتوقعة: خطة أعمق، متابعة أدق، تحسين طاقة وتعافي وعادات، وتدرج أقوى في التدريب والتغذية.', months:'6 شهور هي الأفضل هنا لأن التغيير العميق في الصحة والجسم يحتاج وقت ومراجعة.'}
  }:{
    basic:{name:'Basic Plan', fit:'Best as a starting point for a simple goal or someone who needs structure without intensive follow-up.', result:'Expected results: better habits, early fat-loss or performance progress, and clearer nutrition/training structure.', months:'One month is fine for testing, but 3 months is better for visible fat-loss progress.'},
    standard:{name:'Transformation & Follow-up Plan', fit:'Best for most clients: fat loss, body recomposition, steady muscle gain, and real accountability.', result:'Expected results: clearer measurement changes, better adherence, weekly adjustment, and stronger consistency.', months:'I recommend at least 3 months. If the goal is more than 8–10 kg or a visible body-shape change, 6 months is smarter.'},
    advanced:{name:'Advanced / Complete Plan', fit:'Best for big goals, previous plateaus, detailed follow-up, or health, energy and anti-aging support alongside body goals.', result:'Expected results: deeper planning, closer follow-up, better energy/recovery habits, and stronger nutrition/training progression.', months:'6 months is best here because deep health and body transformation needs time and review.'}
  };

  function n(s){return String(s||'').toLowerCase().replace(/[أإآا]/g,'ا').replace(/ى/g,'ي').replace(/ة/g,'ه').replace(/[ًٌٍَُِّْ]/g,'')}
  function score(text,arr){text=n(text);var v=0;arr.forEach(function(k){k=n(k); if(text.indexOf(k)>-1)v+=1});return v}
  function extractKg(text){var m=String(text).match(/(\d+)\s*(kg|كيلو|kilo|pound|lb)?/i);return m?parseInt(m[1],10):0}
  function analyze(text){
    var t=n(text), kg=extractKg(text), s={fat:0,muscle:0,aging:0,medical:0,beginner:0,busy:0,serious:0,home:0,gym:0,fast:0};
    s.fat+=score(t,['اخس','تخسيس','وزن','دهون','كرش','تنشيف','fat','weight loss','lose','cut']);
    s.muscle+=score(t,['عضل','ضخامه','قوه','bulk','muscle','gain','strength']);
    s.aging+=score(t,['شيخوخه','طاقه','خمول','نوم','تعافي','ميتوكوندريا','anti aging','longevity','energy','methylene','blue']);
    s.medical+=score(t,['اصابه','الم','مرض','سكر','ضغط','ادويه','دواء','injury','pain','medical','diabetes','pressure']);
    s.beginner+=score(t,['مبتدئ','اول مره','مش بتمرن','beginner','new']);
    s.busy+=score(t,['مش فاضي','وقت قليل','مشغول','busy','no time']);
    s.home+=score(t,['بيت','من البيت','home']); s.gym+=score(t,['جيم','gym']);
    s.fast+=score(t,['سريع','فرح','مناسبه','شهر','fast','quick','wedding']);
    if(kg>=8)s.serious+=2; if(kg>=15)s.serious+=3;
    var primary='health'; if(s.fat>=s.muscle&&s.fat>=s.aging&&s.fat>0)primary='fat'; if(s.muscle>s.fat&&s.muscle>=s.aging)primary='muscle'; if(s.aging>s.fat&&s.aging>s.muscle)primary='aging';
    var plan='standard'; if(s.aging>=2||s.medical>=1||s.serious>=3)plan='advanced'; else if(s.beginner>=1&&s.serious===0&&s.fast===0)plan='basic'; else plan='standard';
    var months='3 شهور'; if(!isAr)months='3 months'; if(plan==='advanced'||s.serious>=3||(primary==='fat'&&kg>=10)){months=isAr?'6 شهور':'6 months'} if(plan==='basic'&&s.serious===0){months=isAr?'شهر للتجربة أو 3 شهور لنتيجة أوضح':'1 month to test or 3 months for clearer results'}
    return {primary:primary, plan:plan, months:months, kg:kg, s:s, raw:text};
  }
  function recommendation(ins){
    var p=plans[ins.plan]; var goal=isAr?{fat:'خسارة وزن/دهون',muscle:'زيادة عضل وقوة',aging:'طاقة ومكافحة شيخوخة',health:'تحسين صحة ولياقة'}[ins.primary]:{fat:'fat loss',muscle:'muscle gain and strength',aging:'energy and anti-aging',health:'health and fitness improvement'}[ins.primary];
    lastInsight=ins; leadDraft=ins.raw;
    if(isAr){return 'تحليلي لكلامك: هدفك الأقرب هو: '+goal+'.\n\nترشيحي: '+p.name+'.\nليه؟ '+p.fit+'\n\nالنتائج المتوقعة: '+p.result+'\n\nالمدة الأنسب: '+ins.months+'. '+p.months+'\n\nتسويقيًا، لو جاد في النتيجة: 3 شهور أفضل من شهر لأن الجسم يحتاج وقت للتكيف. ولو الهدف كبير أو فيه ثبات/إرهاق/صحة عامة، 6 شهور أوفر وأقوى على المدى الحقيقي.\n\n'+(ins.s.medical?'وبما إنك ذكرت إصابة/حالة صحية، لازم التقييم يكون أدق قبل أي خطة. ':'')+'تحب أجهز لك رسالة واتساب بالبيانات دي؟'}
    return 'My analysis: your likely goal is '+goal+'.\n\nRecommendation: '+p.name+'.\nWhy? '+p.fit+'\n\nExpected results: '+p.result+'\n\nBest duration: '+ins.months+'. '+p.months+'\n\nSales-wise, if you are serious: 3 months is better than 1 month because the body needs time to adapt. If the goal is bigger, or there is plateau/fatigue/health focus, 6 months is stronger and usually better value.\n\n'+(ins.s.medical?'Since you mentioned a health/injury note, assessment should be more careful before any plan. ':'')+'Would you like me to prepare a WhatsApp message with these details?';
  }
  var info={
    ar:{pricing:'العروض تعتمد على المدة: شهر للتجربة، 3 شهور للتحول الواضح، و6 شهور لأفضل قيمة واستمرارية. الأسعار تظهر تلقائيًا حسب بلد الزائر: مصر بالجنيه، الخليج بالريال، وباقي العالم بالدولار.',follow:'المتابعة ليست مجرد سؤال: بنراجع الوزن، المقاسات، الالتزام، الجوع، الطاقة، النوم، الأداء، ونعدّل الخطة بناءً على الواقع.',blue:'الميثيلين بلو موضوع متقدم مرتبط بطاقة الخلايا والميتوكوندريا، لكنه ليس مكملًا عاديًا. قد يتداخل مع أدوية خصوصًا أدوية السيروتونين، لذلك لا يُستخدم عشوائيًا.',aging:'مكافحة الشيخوخة هنا تعني: عضلات أقوى، نوم أفضل، طاقة أعلى، أكل مضاد للالتهاب قدر الإمكان، حركة يومية، وتعافي ذكي. الأدوات المتقدمة تأتي بعد الأساس.'},
    en:{pricing:'Offers depend on duration: 1 month to test, 3 months for visible transformation, and 6 months for best value and consistency. Prices auto-display by visitor country.',follow:'Follow-up is not just checking in. We review weight, measurements, adherence, hunger, energy, sleep, performance, and adjust based on reality.',blue:'Methylene blue is an advanced cellular-energy topic, not a casual supplement. It may interact with medications, especially serotonin-related drugs, so it should not be used randomly.',aging:'Anti-aging here means stronger muscle, better sleep, higher energy, smarter nutrition, daily movement, and better recovery. Advanced tools come after the foundation.'}
  }[lang];
  function scroll(){elMessages.scrollTop=elMessages.scrollHeight}
  function add(type,text,anim,done){var r=document.createElement('div');r.className='o2f-msg '+type;var b=document.createElement('div');b.className='o2f-bubble';r.appendChild(b);elMessages.appendChild(r);scroll();if(!anim){b.textContent=text;scroll();done&&done();return}var w=String(text).split(/(\s+)/),i=0,sp=text.length>520?13:22;b.textContent='';var tm=setInterval(function(){b.textContent+=w[i]||'';i++;scroll();if(i>=w.length){clearInterval(tm);done&&done()}},sp)}
  function typing(){var r=document.createElement('div');r.className='o2f-msg bot o2f-typing';var b=document.createElement('div');b.className='o2f-bubble';b.innerHTML='<span class="o2f-typing-dot"></span><span class="o2f-typing-dot"></span><span class="o2f-typing-dot"></span>';r.appendChild(b);elMessages.appendChild(r);scroll();return r}
  function bot(text,qs){if(busy)return;busy=true;elQuick.innerHTML='';var t=typing();setTimeout(function(){t.remove();add('bot',text,true,function(){busy=false;quick(qs||['recommend','pricing','follow','aging','blue'])})},Math.min(1800,Math.max(900,text.length*3)))}
  function user(text){add('user',text,false)}
  function quick(ids){var map=isAr?{recommend:'رشح لي باقة',pricing:'الأسعار والعروض',follow:'المتابعة',aging:'مكافحة الشيخوخة',blue:'الميثيلين بلو',whatsapp:'واتساب',restart:'ابدأ من جديد'}:{recommend:'Recommend a plan',pricing:'Pricing & offers',follow:'Follow-up',aging:'Anti-aging',blue:'Methylene blue',whatsapp:'WhatsApp',restart:'Start again'};elQuick.innerHTML='';ids.forEach(function(id){var btn=document.createElement('button');btn.type='button';btn.className='o2f-chip';btn.textContent=map[id]||id;btn.onclick=function(){if(busy)return;user(btn.textContent);handle(id,true)};elQuick.appendChild(btn)})}
  function openWa(){var txt=T.wa+(lastInsight?recommendation(lastInsight).replace(/\n+/g,' | '):leadDraft||'');window.open('https://wa.me/'+whatsappNumber+'?text='+encodeURIComponent(txt),'_blank','noopener')}
  function handle(input,isId){if(input==='restart')return reset(); if(input==='whatsapp')return openWa(); if(input==='recommend')return bot(T.ask,['pricing','follow','whatsapp']); if(input==='pricing')return bot(info.pricing,['recommend','follow','whatsapp']); if(input==='follow')return bot(info.follow,['recommend','pricing','whatsapp']); if(input==='aging')return bot(info.aging,['blue','recommend','whatsapp']); if(input==='blue')return bot(info.blue+'\n\n'+T.safety,['aging','recommend','whatsapp']); var text=String(input); if(score(text,['سعر','اسعار','عرض','خصم','price','pricing','cost','offer']))return bot(info.pricing,['recommend','follow','whatsapp']); if(score(text,['متابعه','متابعة','support','follow']))return bot(info.follow,['recommend','pricing','whatsapp']); if(score(text,['ميثيلين','methylene','blue']))return bot(info.blue+'\n\n'+T.safety,['aging','recommend','whatsapp']); if(score(text,['شيخوخه','anti','aging','energy','طاقه']))return bot(info.aging,['blue','recommend','whatsapp']); var ins=analyze(text); if(ins.primary!=='health'||ins.kg||ins.s.beginner||ins.s.medical||text.length>18)return bot(recommendation(ins),['whatsapp','pricing','follow','restart']); return bot(T.fallback,['recommend','pricing','follow','aging'])}
  function reset(){lastInsight=null;leadDraft='';elMessages.innerHTML='';bot(T.hello,['recommend','pricing','follow','aging','blue'])}
  elToggle.onclick=function(){root.classList.toggle('is-open');if(root.classList.contains('is-open')&&!elMessages.children.length)reset()}; elClose.onclick=function(){root.classList.remove('is-open')};
  elForm.onsubmit=function(e){e.preventDefault();if(busy)return;var text=elInput.value.trim();if(!text)return;user(text);elInput.value='';handle(text,false)};
  window.addEventListener('keydown',function(e){if(e.key==='Escape')root.classList.remove('is-open')});
})();
</script>
