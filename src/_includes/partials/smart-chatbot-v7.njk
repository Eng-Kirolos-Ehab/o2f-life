<div id="o2f-chatbot" class="o2f-chatbot" data-lang="{{ lang }}">
  <button id="o2f-chat-toggle" class="o2f-chat-toggle" type="button" aria-label="O2F Assistant"><span class="o2f-chat-dot"></span><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/><path d="M8 10h8M8 14h5"/></svg></button>
  <section id="o2f-chat-panel" class="o2f-chat-panel"><header class="o2f-chat-head"><div><strong>{{ 'مساعد O2F' if lang == 'ar' else 'O2F Assistant' }}</strong><span>{{ 'افهم الخدمات، طريقة العمل، المتابعة، واختار الباقة' if lang == 'ar' else 'Understand services, process, follow-up, and plans' }}</span></div><button id="o2f-chat-close" type="button">×</button></header><div id="o2f-chat-messages" class="o2f-chat-messages"></div><div id="o2f-chat-quick" class="o2f-chat-quick"></div><form id="o2f-chat-form" class="o2f-chat-form"><input id="o2f-chat-input" type="text" autocomplete="off" placeholder="{{ 'اكتب سؤالك أو هدفك...' if lang == 'ar' else 'Type your question or goal...' }}"><button type="submit">{{ 'إرسال' if lang == 'ar' else 'Send' }}</button></form></section>
</div>
<style>.o2f-chatbot,.o2f-chatbot *{box-sizing:border-box}.o2f-chatbot{position:fixed;z-index:80;font-family:inherit}html[dir="ltr"] .o2f-chatbot{right:1.25rem;bottom:5.9rem}html[dir="rtl"] .o2f-chatbot{right:1.25rem;bottom:1.25rem}.o2f-chat-toggle{position:relative;width:3.6rem;height:3.6rem;border:0;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;color:#07111F;background:linear-gradient(135deg,#00D9A3,#C9A84A);box-shadow:0 20px 45px rgba(0,0,0,.35)}.o2f-chat-dot{position:absolute;top:.45rem;right:.45rem;width:.65rem;height:.65rem;border-radius:999px;background:#fff;border:2px solid #0B1220}.o2f-chat-panel{position:absolute;bottom:4.4rem;right:0;width:min(430px,calc(100vw - 2rem));height:min(720px,calc(100vh - 8rem));max-height:min(720px,calc(100vh - 8rem));overflow:hidden;display:none;flex-direction:column;color:#F7F8FA;background:rgba(11,18,32,.96);border:1px solid rgba(255,255,255,.12);border-radius:1.4rem;box-shadow:0 28px 70px rgba(0,0,0,.48);backdrop-filter:blur(18px)}.o2f-chatbot.is-open .o2f-chat-panel{display:flex}.o2f-chat-head{display:flex;justify-content:space-between;gap:1rem;padding:1rem;border-bottom:1px solid rgba(255,255,255,.1);flex:0 0 auto}.o2f-chat-head strong{display:block}.o2f-chat-head span{display:block;margin-top:.25rem;font-size:.75rem;color:rgba(247,248,250,.62)}.o2f-chat-head button{width:2rem;height:2rem;border:1px solid rgba(255,255,255,.12);border-radius:999px;color:#fff;background:rgba(255,255,255,.06);cursor:pointer}.o2f-chat-messages{padding:1rem;overflow-y:auto;display:flex;flex-direction:column;gap:.7rem;min-height:0;flex:1 1 auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain}.o2f-msg{display:flex;width:100%}.o2f-msg.bot{justify-content:flex-start}.o2f-msg.user{justify-content:flex-end}.o2f-bubble{max-width:92%;padding:.78rem .9rem;border-radius:1rem;font-size:.86rem;line-height:1.7;white-space:pre-line;overflow-wrap:anywhere}.o2f-msg.bot .o2f-bubble{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.09);color:#F7F8FA}.o2f-msg.user .o2f-bubble{background:rgba(0,217,163,.16);border:1px solid rgba(0,217,163,.28);color:#F7F8FA}.o2f-typing .o2f-bubble{display:inline-flex;gap:.35rem}.o2f-typing-dot{width:.38rem;height:.38rem;border-radius:999px;background:#fff;animation:o2fDot 1s infinite}.o2f-typing-dot:nth-child(2){animation-delay:.15s}.o2f-typing-dot:nth-child(3){animation-delay:.3s}.o2f-chat-quick{padding:0 1rem .75rem;display:flex;gap:.45rem;flex-wrap:wrap;max-height:8.5rem;overflow-y:auto;flex:0 0 auto}.o2f-chip{border:1px solid rgba(0,217,163,.28);color:#00D9A3;background:rgba(0,217,163,.08);border-radius:999px;padding:.45rem .65rem;font-size:.74rem;cursor:pointer}.o2f-chip:hover{background:rgba(0,217,163,.16)}.o2f-chat-form{display:flex;gap:.5rem;padding:.85rem;border-top:1px solid rgba(255,255,255,.1);flex:0 0 auto}.o2f-chat-form input{min-width:0;flex:1;border:1px solid rgba(255,255,255,.12);border-radius:.9rem;padding:.75rem .85rem;color:#F7F8FA;background:rgba(255,255,255,.06);outline:none}.o2f-chat-form button{border:0;border-radius:.9rem;padding:.75rem .95rem;color:#07111F;background:#00D9A3;font-weight:800;cursor:pointer}@keyframes o2fDot{0%,80%,100%{opacity:.35}40%{opacity:1}}@media(max-width:640px){html[dir="ltr"] .o2f-chatbot,html[dir="rtl"] .o2f-chatbot{right:1rem;bottom:1rem}.o2f-chat-panel{position:fixed;left:.75rem;right:.75rem;bottom:5.25rem;top:auto;width:auto;height:calc(100dvh - 6.5rem);max-height:calc(100dvh - 6.5rem);border-radius:1.15rem}.o2f-chat-head{padding:.85rem}.o2f-chat-messages{padding:.85rem}.o2f-chat-quick{padding:0 .85rem .65rem;max-height:7rem}.o2f-chat-form{padding:.7rem}.o2f-chat-form input{font-size:16px}.o2f-bubble{font-size:.84rem;line-height:1.62;max-width:94%}}</style>
<script>(function(){var root=document.getElementById('o2f-chatbot'),ar=root.getAttribute('data-lang')==='ar',wa='{{ site.whatsapp | replace("+", "") | replace(" ", "") }}',msgs=document.getElementById('o2f-chat-messages'),quick=document.getElementById('o2f-chat-quick'),inp=document.getElementById('o2f-chat-input'),busy=false,lastTopic=null,S={goal:null,w:null,h:null,days:null,target:null,place:null,last:null,asked:{},notes:[],seen:{}};var L=ar?{hello:'أهلًا 👋 أنا مساعد O2F. أقدر أوضح لك الموقع كله بسرعة: الخدمات، طريقة العمل، المتابعة، الباقات، مكافحة الشيخوخة، الأعشاب، والميثيلين بلو.\n\nاختار موضوع من المقترحات أو اكتب هدفك مباشرة، مثل: عايز أخس 10 كيلو، وزني 90 وطولي 175 وبتمرن يومين.',g:'هدفك الأساسي إيه: تخسيس، زيادة عضل، تحسين صحة وطاقة؟',b:'محتاج الوزن والطول عشان الترشيح يبقى أدق.',d:'تقدر تتمرن كام يوم في الأسبوع؟',wa:'مرحبا، أريد ترشيح الباقة المناسبة. بياناتي: ',q:{how:'طريقة العمل',services:'الخدمات',why:'الأهمية',rec:'رشح لي باقة',price:'العروض',follow:'المتابعة',nut:'التغذية',train:'التدريب',anti:'مكافحة الشيخوخة',blue:'الميثيلين بلو',herbs:'الأعشاب',wa:'واتساب',reset:'ابدأ من جديد'}}:{hello:'Hi 👋 I am the O2F assistant. I can explain the whole website: services, how it works, follow-up, plans, anti-aging, herbs, and methylene blue.\n\nChoose a suggested topic or type your goal directly, like: I want to lose 10 kg, weight 90, height 175, training 2 days.',g:'What is your main goal: fat loss, muscle gain, or better health and energy?',b:'I need weight and height to tune the recommendation.',d:'How many days per week can you train?',wa:'Hi, I want the right plan recommendation. My details: ',q:{how:'How it works',services:'Services',why:'Why it matters',rec:'Recommend a plan',price:'Offers',follow:'Follow-up',nut:'Nutrition',train:'Training',anti:'Anti-aging',blue:'Methylene blue',herbs:'Herbs',wa:'WhatsApp',reset:'Start over'}};var flows={intro:['how','services','why','rec','price','anti'],how:['services','follow','why','rec','price'],services:['how','rec','price','follow','anti'],why:['how','services','follow','rec'],price:['rec','follow','services','wa'],follow:['rec','price','nut','train','wa'],nut:['train','rec','follow','price'],train:['nut','rec','follow','price'],anti:['blue','herbs','rec','follow','wa'],blue:['anti','herbs','rec','wa'],herbs:['anti','rec','follow','wa'],rec:['wa','price','follow','nut','train'],wa:['rec','price','reset']};function ordered(ids,current){var out=[],used={};(ids||flows.intro).forEach(function(id){if(id!==current&&!used[id]){out.push(id);used[id]=1}});if(!used.reset)out.push('reset');return out.slice(0,7)}function N(s){return String(s||'').toLowerCase().replace(/[أإآا]/g,'ا').replace(/ى/g,'ي').replace(/ة/g,'ه')}function has(t,a){t=N(t);return a.some(function(x){return t.indexOf(N(x))>-1})}function numNear(text,keys,min,max){var t=N(text),m=String(text).match(/\d+(\.\d+)?/g)||[];for(var i=0;i<m.length;i++){var idx=t.indexOf(m[i]),z=t.slice(Math.max(0,idx-18),idx+22);if(keys.some(function(k){return z.indexOf(N(k))>-1})){var v=parseFloat(m[i]);if(v>=min&&v<=max)return v}}return null}function learn(text){S.notes.push(text);if(has(text,['اخس','تخسيس','دهون','كرش','lose','fat','weight']))S.goal='fat';if(has(text,['عضل','ضخامه','قوه','muscle','bulk','strength']))S.goal='muscle';if(has(text,['صحه','طاقه','health','energy','شيخوخه','anti aging']))S.goal=S.goal||'health';var w=numNear(text,['وزن','وزني','weight','kg','كيلو'],30,250);if(w)S.w=w;var h=numNear(text,['طول','طولي','height','cm'],120,230);if(h)S.h=h;var d=numNear(text,['ايام','أيام','يوم','days','day'],1,7);if(d)S.days=d;var tg=numNear(text,['اخس','انزل','lose'],4,80);if(tg)S.target=tg;if(has(text,['بيت','home']))S.place='home';if(has(text,['جيم','gym']))S.place='gym'}function bmi(){return S.w&&S.h?+(S.w/Math.pow(S.h/100,2)).toFixed(1):null}function pkey(){var b=bmi();if((S.target&&S.target>=12)||(b&&b>=30)||S.goal==='health')return'advanced';if(S.goal&&(!S.target||S.target<6)&&!S.days)return'basic';return'standard'}function pname(p){return ar?{basic:'الباقة الأساسية',standard:'باقة التحول والمتابعة',advanced:'الباقة المتقدمة / الشاملة'}[p]:{basic:'Basic Plan',standard:'Transformation & Follow-up Plan',advanced:'Advanced / Complete Plan'}[p]}function dur(p){if(p==='advanced')return ar?'6 شهور':'6 months';if(p==='basic')return ar?'شهر كبداية أو 3 شهور لنتيجة أوضح':'1 month to start or 3 months for clearer progress';return S.target&&S.target>=8?(ar?'6 شهور أفضل':'6 months is better'):(ar?'3 شهور':'3 months')}function recommend(){var p=pkey(),b=bmi();S.last=pname(p);var r=[];if(ar){r.push('أنسب اختيار لك: '+pname(p)+'.');if(S.goal)r.push('واضح إن هدفك '+(S.goal==='fat'?'خسارة دهون':S.goal==='muscle'?'زيادة عضل':'تحسين صحة وطاقة')+'.');if(b)r.push('مؤشر جسمك التقريبي '+b+'؛ فالأفضل نمشي بخطة متدرجة.');if(S.days)r.push('بما إن المتاح '+S.days+' أيام، الخطة هتكون مركزة ومناسبة لوقتك.');r.push('المدة المناسبة: '+dur(p)+'.');r.push('السبب: تحتاج خطة تقدر تلتزم بها، ومع متابعة تعدل عند الثبات بدل جدول ثابت.');r.push('أقدر أجهز لك رسالة واتساب بالترشيح.')}else{r.push('Best fit: '+pname(p)+'.');if(S.goal)r.push('Your goal looks like '+S.goal+'.');if(b)r.push('Estimated BMI is '+b+', so a progressive plan is better.');if(S.days)r.push('With '+S.days+' days available, the plan should be focused and realistic.');r.push('Recommended duration: '+dur(p)+'.');r.push('Reason: you need a plan you can follow, with follow-up adjustments when progress stalls.');r.push('I can prepare a WhatsApp message with this recommendation.')}return r.join('\n')}function info(id){var A={how:'طريقة العمل بسيطة: نبدأ بفهم هدفك وبياناتك، ثم نحدد الباقة المناسبة، بعدها يتم تجهيز خطة تغذية وتدريب قابلة للتطبيق، ومع المتابعة يتم تعديل الخطة حسب النتائج والطاقة والالتزام. الهدف ليس جدول وخلاص؛ الهدف نظام يمشي مع حياتك.',services:'الخدمات تشمل: خطط تغذية، تدريب منزلي أو جيم، متابعة وتحسين عادات، باقات تحول، دعم صحة وطاقة، ومحتوى تثقيفي عن مكافحة الشيخوخة. كل خدمة هدفها تحويل الكلام لخطة واضحة قابلة للتنفيذ.',why:'أهمية O2F إنك لا تأخذ خطة عامة. كل قرار يتبني على هدفك ووقتك وبياناتك. المتابعة تقلل العشوائية، وتساعدك تعرف هل تحتاج تعديل في الأكل، التدريب، النوم أو الالتزام.',price:'العروض: شهر للتجربة، 3 شهور لنتيجة أوضح، و6 شهور للتحول الكبير. الهدف الكبير يستاهل 6 شهور بدل شهر واحد.',follow:'المتابعة تعني مراجعة الوزن والمقاسات والطاقة والالتزام ثم تعديل الخطة. هي الفرق بين جدول ثابت ونظام فعلي يتطور معك.',nut:'التغذية حسب الهدف: تخسيس بعجز ذكي، عضل بزيادة محسوبة، وصحة بجودة أكل أفضل. الخطة لازم تناسب يومك وأكلك المفضل قدر الإمكان.',train:'التدريب حسب وقتك ومكانك. 3 أيام منظمة أفضل من خطة صعبة لا تلتزم بها. نختار مقاومة، حركة وكارديو حسب الهدف.',anti:'مكافحة الشيخوخة في O2F معناها خطة كاملة للطاقة والتعافي: نوم أفضل، عضلات أقوى، تغذية أنظف، حركة منتظمة، تقليل إجهاد، ومتابعة للتغيرات. ليست منتجًا واحدًا؛ هي نظام حياة قابل للتطبيق.',blue:'الميثيلين بلو يُناقش عادةً في سياق طاقة الخلايا والتركيز والميتوكوندريا. لكنه ليس مكملًا عاديًا ولا يناسب كل الناس، وقد يتعارض مع بعض الأدوية أو الحالات. لذلك نتعامل معه كمعلومة تثقيفية فقط، وأي استخدام يحتاج مختص.',herbs:'الأعشاب قد تكون داعمة لنمط الحياة مثل الاسترخاء، الهضم، النوم أو تقليل الإجهاد، لكنها لا تعوض التغذية والتمرين والمتابعة. الأفضل اختيارها حسب الهدف والحالة بدل استخدام عشوائي، خصوصًا مع الأدوية أو الحالات الصحية.'};var E={how:'How it works: we understand your goal and details, choose the right plan, build practical nutrition and training, then adjust through follow-up based on results, energy, and adherence. It is not just a document; it is a system built around your life.',services:'Services include nutrition plans, home or gym training, follow-up, habit improvement, transformation plans, energy and health support, and educational anti-aging content. Each service turns your goal into a clear action plan.',why:'O2F matters because you do not get a generic plan. Decisions are based on your goal, time, and data. Follow-up reduces randomness and helps identify whether food, training, sleep, or adherence needs adjustment.',price:'Offers: 1 month to test, 3 months for clearer progress, and 6 months for bigger transformation.',follow:'Follow-up means reviewing weight, measurements, energy, and adherence, then adjusting the plan. It is the difference between a fixed document and a real evolving system.',nut:'Nutrition depends on the goal: smart deficit for fat loss, controlled surplus for muscle, better food quality for health. The plan should fit your day and food preferences as much as possible.',train:'Training depends on your time and place. 3 structured days can beat a hard plan you cannot follow. We choose resistance, movement, and cardio based on the goal.',anti:'Anti-aging at O2F means a complete energy and recovery system: better sleep, stronger muscle, cleaner nutrition, regular movement, stress control, and follow-up. It is not one product; it is a practical lifestyle system.',blue:'Methylene blue is often discussed around cellular energy, focus, and mitochondria. It is not a casual supplement and is not suitable for everyone. It may conflict with some medications or conditions, so this is educational only and any use needs professional guidance.',herbs:'Herbs can support lifestyle goals such as relaxation, digestion, sleep, or stress balance, but they do not replace nutrition, training, and follow-up. They should be chosen based on the goal and personal situation, especially with medications or health conditions.'};return(ar?A:E)[id]}function need(){if(!S.goal&&!S.asked.g){S.asked.g=1;return L.g}if((!S.w||!S.h)&&!S.asked.b){S.asked.b=1;return L.b}if(!S.days&&!S.asked.d){S.asked.d=1;return L.d}return null}function detect(text){if(has(text,['ازاي','طريقه','طريقة','خطوات','كيف','how','work','process']))return'how';if(has(text,['خدمات','خدمه','services','service']))return'services';if(has(text,['اهميه','أهمية','ليه','why','important','benefit']))return'why';if(has(text,['سعر','عرض','price','offer']))return'price';if(has(text,['متابعة','follow']))return'follow';if(has(text,['اكل','تغذيه','nutrition','food']))return'nut';if(has(text,['تمرين','training','workout']))return'train';if(has(text,['شيخوخه','مكافحة الشيخوخه','anti aging','longevity']))return'anti';if(has(text,['ميثيلين','بلو','methylene','blue']))return'blue';if(has(text,['اعشاب','أعشاب','herb','herbs']))return'herbs';if(has(text,['واتساب','whatsapp']))return'wa';if(has(text,['رشح','recommend']))return'rec';return null}function respond(text){learn(text);var id=detect(text);if(id==='wa')return openWa();if(id&&id!=='rec'){S.seen[id]=1;lastTopic=id;return bot(info(id),flows[id]||flows.intro,id)}if(S.goal||S.w||S.h||S.days||id==='rec'){var m=need();if(m&&(!S.goal||(!S.w&&!S.h&&!S.days)))return bot(m,['price','nut','train','reset'],'ask');lastTopic='rec';S.seen.rec=1;return bot(recommend(),flows.rec,'rec')}return bot(need()||L.g,flows.intro,'ask')}function add(type,text,anim,done){var row=document.createElement('div');row.className='o2f-msg '+type;var b=document.createElement('div');b.className='o2f-bubble';row.appendChild(b);msgs.appendChild(row);scroll();if(!anim){b.textContent=text;done&&done();return}var parts=String(text).split(/(\s+)/),i=0,tm=setInterval(function(){b.textContent+=parts[i]||'';i++;scroll();if(i>=parts.length){clearInterval(tm);done&&done()}},18)}function scroll(){msgs.scrollTop=msgs.scrollHeight}function typing(){var r=document.createElement('div');r.className='o2f-msg bot o2f-typing';var b=document.createElement('div');b.className='o2f-bubble';b.innerHTML='<span class="o2f-typing-dot"></span><span class="o2f-typing-dot"></span><span class="o2f-typing-dot"></span>';r.appendChild(b);msgs.appendChild(r);scroll();return r}function bot(text,ids,current){if(busy)return;busy=true;quick.innerHTML='';var t=typing();setTimeout(function(){t.remove();add('bot',text,true,function(){busy=false;chips(ordered(ids,current||lastTopic))})},900)}function user(text){add('user',text,false)}function chips(ids){quick.innerHTML='';ids.forEach(function(id){var bt=document.createElement('button');bt.type='button';bt.className='o2f-chip';bt.textContent=L.q[id]||id;bt.onclick=function(){if(busy)return;user(bt.textContent);if(id==='reset')return reset();if(id==='wa')return openWa();if(id==='rec')return respond(ar?'رشح لي':'recommend');S.seen[id]=1;lastTopic=id;return bot(info(id),flows[id]||flows.intro,id)};quick.appendChild(bt)})}function summary(){var a=[];if(S.goal)a.push('goal: '+S.goal);if(S.w)a.push('weight: '+S.w);if(S.h)a.push('height: '+S.h);if(S.days)a.push('days: '+S.days);if(S.last)a.push('recommendation: '+S.last);return a.join(' | ')}function openWa(){lastTopic='wa';window.open('https://wa.me/'+wa+'?text='+encodeURIComponent(L.wa+(summary()||S.notes.join(' | '))),'_blank','noopener');chips(ordered(flows.wa,'wa'))}function reset(){S={goal:null,w:null,h:null,days:null,target:null,place:null,last:null,asked:{},notes:[],seen:{}};lastTopic=null;msgs.innerHTML='';bot(L.hello,flows.intro,'intro')}document.getElementById('o2f-chat-toggle').onclick=function(){root.classList.toggle('is-open');if(root.classList.contains('is-open')&&!msgs.children.length)reset()};document.getElementById('o2f-chat-close').onclick=function(){root.classList.remove('is-open')};document.getElementById('o2f-chat-form').onsubmit=function(e){e.preventDefault();if(busy)return;var text=inp.value.trim();if(!text)return;user(text);inp.value='';respond(text)}})();</script>