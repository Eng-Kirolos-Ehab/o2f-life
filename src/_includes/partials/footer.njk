<footer class="border-t border-brand-line mt-20">
  <div class="container-x py-12 grid gap-10 md:grid-cols-4 text-sm">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-display text-lg font-bold">
        <span class="inline-block h-8 w-8 rounded-lg bg-gradient-to-br from-brand-mint to-brand-gold"></span>
        <span class="gradient-mint-text">O2F<span class="text-brand-off">.life</span></span>
      </div>
      <p class="mt-3 text-brand-off/60 max-w-sm">
        {{ "منصة الكابتن أسامة عمران للتدريب أونلاين — لياقة، تغذية، وطب طبيعي." if lang == "ar"
           else "Coach Osama Omran's online coaching platform — fitness, nutrition, and naturopathic guidance." }}
      </p>
    </div>

    <div>
      <h4 class="text-brand-off font-semibold mb-3">{{ "روابط" if lang == "ar" else "Links" }}</h4>
      <ul class="space-y-2 text-brand-off/60">
        <li><a href="/{{ lang }}/about/"    class="hover:text-brand-mint">{{ "عن الكابتن" if lang == "ar" else "About" }}</a></li>
        <li><a href="/{{ lang }}/services/" class="hover:text-brand-mint">{{ "الخدمات" if lang == "ar" else "Services" }}</a></li>
        <li><a href="/{{ lang }}/plans/"    class="hover:text-brand-mint">{{ "الباقات" if lang == "ar" else "Plans" }}</a></li>
        <li><a href="/{{ lang }}/blog/"     class="hover:text-brand-mint">{{ "المقالات" if lang == "ar" else "Blog" }}</a></li>
        <li><a href="/{{ lang }}/contact/"  class="hover:text-brand-mint">{{ "تواصل" if lang == "ar" else "Contact" }}</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-brand-off font-semibold mb-3">{{ "تواصل" if lang == "ar" else "Connect" }}</h4>
      <ul class="space-y-2 text-brand-off/60">
        <li><a class="hover:text-brand-mint" href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        {% if site.social.instagram %}<li><a class="hover:text-brand-mint" target="_blank" rel="noopener" href="{{ site.social.instagram }}">Instagram</a></li>{% endif %}
        {% if site.social.facebook  %}<li><a class="hover:text-brand-mint" target="_blank" rel="noopener" href="{{ site.social.facebook }}">Facebook</a></li>{% endif %}
        {% if site.social.youtube   %}<li><a class="hover:text-brand-mint" target="_blank" rel="noopener" href="{{ site.social.youtube }}">YouTube</a></li>{% endif %}
      </ul>
    </div>
  </div>

  <div class="border-t border-brand-line">
    <div class="container-x py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-brand-off/50">
      <span>© {{ "" | year }} {{ site.name }} — {{ "جميع الحقوق محفوظة" if lang == "ar" else "All rights reserved." }}</span>
      <span>
        <a href="/{{ lang }}/privacy/" class="hover:text-brand-mint">{{ "الخصوصية" if lang == "ar" else "Privacy" }}</a>
        <span class="mx-2">·</span>
        <a href="/{{ lang }}/terms/"   class="hover:text-brand-mint">{{ "الشروط" if lang == "ar" else "Terms" }}</a>
      </span>
    </div>
  </div>
</footer>
