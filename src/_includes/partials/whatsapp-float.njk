{# Floating WhatsApp action button — appears on every page #}
{% set waMsg = ("مرحبا كابتن أسامة، حابب أستفسر عن الخدمات" if lang == "ar"
                else "Hi Coach Osama, I'd like to ask about your coaching services") %}
{% set waHref = "https://wa.me/" + (site.whatsapp | replace("+", "") | replace(" ", "")) +
                "?text=" + (waMsg | urlencode) %}

<a href="{{ waHref }}" target="_blank" rel="noopener"
   aria-label="WhatsApp"
   class="fixed bottom-5 ltr:right-5 rtl:left-5 z-50
          inline-flex h-14 w-14 items-center justify-center
          rounded-full bg-[#25D366] text-white shadow-card
          hover:-translate-y-0.5 transition-transform">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
