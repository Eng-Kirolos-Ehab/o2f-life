---
title: "الرئيسية"
description: "تدريب، تغذية، وطب طبيعي أونلاين مع الكابتن أسامة عمران. حوّل جسمك من الداخل للخارج."
ogImage: "/assets/images/osama.jpeg"
---

{# ==================== HERO ==================== #}
<section class="grid-bg relative overflow-hidden" style="min-height:90vh;display:flex;align-items:center;">
  <div class="hero-orb hero-orb-1"></div>
  <div class="hero-orb hero-orb-2"></div>
  <div class="hero-orb hero-orb-3"></div>

  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <span class="particle" style="top:12%;right:8%"></span>
    <span class="particle" style="top:28%;left:12%"></span>
    <span class="particle" style="bottom:22%;right:22%"></span>
    <span class="particle" style="bottom:38%;left:8%"></span>
    <span class="particle" style="top:55%;right:58%"></span>
    <span class="particle" style="top:70%;left:30%"></span>
  </div>

  <div class="container-x py-20 sm:py-28 lg:py-32 relative w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      {# --- Right column (RTL = text first) --- #}
      <div>
        <div class="hero-badge" data-aos="fade-down" data-aos-duration="600">
          <span class="hero-badge-dot"></span>
          <span class="hero-badge-text">{{ pages.home.ar.hero.badge }}</span>
        </div>

        <h1 class="section-title text-balance leading-tight" data-aos="fade-up" data-aos-delay="80">
          {{ pages.home.ar.hero.title_line1 }}<br>
          <span class="gradient-mint-text">{{ pages.home.ar.hero.title_line2_gradient }}</span>
        </h1>

        <p class="mt-5 max-w-xl text-lg text-brand-off/70 leading-relaxed"
           data-aos="fade-up" data-aos-delay="160">
          {{ pages.home.ar.hero.description }}
        </p>

        <div class="mt-8 flex flex-wrap gap-3" data-aos="fade-up" data-aos-delay="240">
          <a href="{{ '/ar/plans/' | url }}" class="btn-primary group">
            {{ pages.home.ar.hero.cta_primary }}
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1 flip-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </a>
          <a href="{{ '/ar/services/' | url }}" class="btn-ghost">{{ pages.home.ar.hero.cta_secondary }}</a>
        </div>

        {# Stats #}
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-xl"
             data-aos="fade-up" data-aos-delay="320">
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.years }}</div>
            <div class="text-xs text-brand-off/55 mt-1">{{ pages.home.ar.hero.stats_years_label }}</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.clients }}</div>
            <div class="text-xs text-brand-off/55 mt-1">{{ pages.home.ar.hero.stats_clients_label }}</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.custom }}</div>
            <div class="text-xs text-brand-off/55 mt-1">{{ pages.home.ar.hero.stats_custom_label }}</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.support }}</div>
            <div class="text-xs text-brand-off/55 mt-1">{{ pages.home.ar.hero.stats_support_label }}</div>
          </div>
        </div>
      </div>

      {# --- Left column: image (RTL) --- #}
      <div class="relative" data-aos="fade-right" data-aos-delay="200" data-aos-duration="800">
        <div class="absolute -inset-10 rounded-full border border-brand-mint/8 animate-spin-slow pointer-events-none"></div>
        <div class="absolute -inset-6 rounded-full border border-brand-gold/6 animate-spin-reverse pointer-events-none"></div>
        <div class="absolute -inset-4 rounded-xl2 bg-gradient-to-bl from-brand-mint/25 to-brand-gold/15 blur-2xl"></div>
        <img src="{{ '/assets/images/817_WhatsApp_Image_2024-07-09_at_21.45.27_02e636a3.webp' | url }}"
             alt="الكابتن أسامة عمران" loading="eager"
             class="relative rounded-xl2 w-full object-cover shadow-card animate-float-img">
        <div class="absolute -bottom-5 -right-5 card py-2.5 px-4 text-sm animate-float pointer-events-none" style="animation-delay:1s;z-index:10">
          <span class="font-bold text-brand-mint">{{ pages.home.ar.hero.chip_years_value }}</span>
          <span class="text-brand-off/65 me-1">{{ pages.home.ar.hero.chip_years_label }}</span>
        </div>
        <div class="absolute -top-5 -left-5 card py-2.5 px-4 text-sm animate-float pointer-events-none" style="animation-delay:2.5s;z-index:10">
          <span class="font-bold text-brand-mint">{{ pages.home.ar.hero.chip_clients_value }}</span>
          <span class="text-brand-off/65 me-1">{{ pages.home.ar.hero.chip_clients_label }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{# ==================== PILLARS ==================== #}
<section class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.home.ar.pillars.kicker }}</p>
    <h2 class="section-title mb-2" data-aos="fade-up" data-aos-delay="80">{{ pages.home.ar.pillars.title }}</h2>
    <div class="line-accent w-16 mb-10" data-aos="fade-up" data-aos-delay="120"></div>

    <div class="grid md:grid-cols-3 gap-5">
      {% for item in pages.home.ar.pillars.items %}
      <div class="card card-hover card-glow" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="h-12 w-12 rounded-xl bg-brand-mint/12 text-brand-mint flex items-center justify-center mb-4 animate-pulse-glow" style="animation-delay:{{ (loop.index - 1) * 0.6 }}s">
          {% if loop.index == 1 %}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg>{% endif %}
          {% if loop.index == 2 %}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h3l3-8 4 16 3-8h5"/></svg>{% endif %}
          {% if loop.index == 3 %}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4l8 4-8 4-8-4 8-4zm0 8l8 4-8 4-8-4"/></svg>{% endif %}
        </div>
        <h3 class="text-xl mb-2">{{ item.title }}</h3>
        <p class="text-brand-off/65 text-sm leading-relaxed">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ==================== RESULTS ==================== #}
<section class="section bg-white/[0.02]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.home.ar.results.kicker }}</p>
    <h2 class="section-title mb-2" data-aos="fade-up" data-aos-delay="80">{{ pages.home.ar.results.title }}</h2>
    <div class="line-accent w-16 mb-10" data-aos="fade-up" data-aos-delay="120"></div>

    <div class="grid md:grid-cols-3 gap-5">
      {% for item in pages.home.ar.results.items %}
      <div class="card card-hover card-glow text-center" data-aos="zoom-in" data-aos-delay="{{ loop.index * 100 }}">
        <div class="text-5xl sm:text-6xl font-display text-brand-mint mb-3 glow-text-mint">
          {{ item.value }}<span class="text-2xl">{{ item.unit }}</span>
        </div>
        <div class="divider-mint"></div>
        <p class="text-brand-off/65 text-sm leading-relaxed mt-4">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ==================== WHAT YOU GET ==================== #}
<section class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.home.ar.what_you_get.kicker }}</p>
    <h2 class="section-title mb-2" data-aos="fade-up" data-aos-delay="80">{{ pages.home.ar.what_you_get.title }}</h2>
    <div class="line-accent w-16 mb-10" data-aos="fade-up" data-aos-delay="120"></div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {% set wyg_icons = [
        '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
        '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
        '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>',
        '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>'
      ] %}
      {% for item in pages.home.ar.what_you_get.items %}
      <div class="card card-hover card-glow" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="h-11 w-11 rounded-xl bg-brand-mint/10 text-brand-mint flex items-center justify-center mb-4 transition-transform duration-300 hover:scale-110">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">{{ wyg_icons[loop.index0] | safe }}</svg>
        </div>
        <h3 class="text-lg mb-2">{{ item.title }}</h3>
        <p class="text-brand-off/65 text-sm leading-relaxed">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ==================== PLANS PREVIEW ==================== #}
<section class="section bg-white/[0.015]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.home.ar.plans_section.kicker }}</p>
    <h2 class="section-title mb-2" data-aos="fade-up" data-aos-delay="80">{{ pages.home.ar.plans_section.title }}</h2>
    <div class="line-accent w-16 mb-10" data-aos="fade-up" data-aos-delay="120"></div>

    <div class="grid md:grid-cols-3 gap-5">
      {% for key in ["basic","standard","advanced"] %}
        {% set p = plans[key] %}
        <a href="{{ ('/ar/plans/' + p.slug + '/') | url }}"
           class="card card-hover card-glow hover:border-brand-mint/60 {% if p.highlight %}ring-1 ring-brand-mint/35{% endif %}"
           data-aos="fade-up" data-aos-delay="{{ loop.index * 120 }}">
          {% if p.highlight %}
            <span class="chip text-brand-mint mb-3 block w-fit animate-pulse-soft">{{ pages.home.ar.plans_section.most_popular }}</span>
          {% endif %}
          <h3 class="text-xl mb-1">{{ p.ar.name }}</h3>
          <p class="text-brand-mint text-sm mb-3">{{ p.ar.tagline }}</p>
          <p class="text-brand-off/65 text-sm leading-relaxed">{{ p.ar.blurb }}</p>
          <span class="inline-flex items-center gap-1.5 text-brand-mint text-sm mt-5 group">
            {{ pages.home.ar.plans_section.learn_more }}
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1 flip-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ==================== CTA ==================== #}
<section class="section">
  <div class="container-x">
    <div class="relative card text-center overflow-hidden animate-border-glow" data-aos="fade-up">
      <div class="absolute inset-0 animate-gradient pointer-events-none"
           style="background:linear-gradient(135deg,rgba(0,217,163,.06),transparent,rgba(201,168,74,.06),transparent);background-size:300% 300%"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-px"
           style="background:linear-gradient(90deg,transparent,rgba(0,217,163,.7),transparent)"></div>
      <div class="relative py-4">
        <div class="hero-badge mx-auto mb-4" style="animation-delay:.5s">
          <span class="hero-badge-dot"></span>
          <span class="hero-badge-text">{{ pages.home.ar.cta.badge }}</span>
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl mb-3 font-bold">{{ pages.home.ar.cta.title }}</h2>
        <p class="text-brand-off/65 max-w-xl mx-auto leading-relaxed">{{ pages.home.ar.cta.description }}</p>
        <a href="{{ '/ar/contact/' | url }}" class="btn-primary mt-7 inline-flex group">
          {{ pages.home.ar.cta.button }}
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1 flip-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
