---
title: "O2F الرئيسية الكلاسيكية"
description: "النسخة العربية الكلاسيكية المحفوظة من موقع O2F."
permalink: /ar/home-old/index.html
---

<style>
  body:has(.ar-home-old)>header,.ar-home-old~footer{display:none!important}
  .ar-home-old{min-height:100vh;background:#06110d;color:#fff;font-family:Tajawal,Inter,system-ui,sans-serif;position:relative;overflow:hidden;direction:rtl}
  .ar-home-old:before{content:"";position:absolute;inset:-20%;background:radial-gradient(circle at 80% 20%,rgba(168,255,120,.25),transparent 28%),radial-gradient(circle at 20% 70%,rgba(0,217,163,.18),transparent 32%),linear-gradient(135deg,#06110d,#0b2016 60%,#020705);z-index:0}
  .ar-wrap{position:relative;z-index:1;width:min(1120px,100%);margin:0 auto;padding:clamp(18px,4vh,36px) clamp(18px,5vw,72px) 100px}
  .ar-topnav{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;padding:18px 0 20px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:clamp(40px,8vh,80px)}
  .ar-brand{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-weight:950;font-size:16px}
  .ar-brand img{width:40px;height:40px;border-radius:50%;object-fit:cover}
  .ar-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .ar-links a{color:rgba(255,255,255,.8);text-decoration:none;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);border-radius:999px;padding:9px 14px;font-size:12px;font-weight:800;backdrop-filter:blur(14px);transition:all .18s}
  .ar-links a:hover{border-color:rgba(168,255,120,.5);color:#a8ff78;background:rgba(168,255,120,.1)}
  .ar-links a.lang{border-color:rgba(0,217,163,.35);color:#00d9a3}
  .ar-grid{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);gap:clamp(24px,5vw,70px);align-items:center}
  .ar-kicker{display:inline-block;color:#a8ff78;font-size:12px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;margin-bottom:16px}
  .ar-home-old h1{font-size:clamp(42px,7vw,86px);line-height:.95;letter-spacing:-.045em;margin:0 0 18px;color:#fff}
  .ar-home-old p{color:rgba(247,255,247,.78);line-height:1.8;font-size:clamp(16px,1.3vw,19px)}
  .ar-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:26px}
  .ar-btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.26);background:rgba(255,255,255,.1);border-radius:999px;padding:13px 22px;font-size:14px;font-weight:850;backdrop-filter:blur(14px);color:#fff;text-decoration:none;transition:all .18s}
  .ar-btn:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.45)}
  .ar-btn.primary{background:linear-gradient(135deg,rgba(168,255,120,.28),rgba(0,217,163,.16));border-color:rgba(168,255,120,.45)}
  .ar-card{border:1px solid rgba(255,255,255,.22);background:linear-gradient(145deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(22px);border-radius:34px;padding:26px;box-shadow:0 26px 90px rgba(0,0,0,.26)}
  .ar-card h2{margin:0 0 12px;font-size:28px;color:#fff}
  .ar-list{display:grid;gap:12px;margin-top:18px}
  .ar-list div{padding:14px;border-radius:18px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12)}
  .ar-list b{display:block;margin-bottom:4px;color:#fff}
  .ar-list span{color:rgba(247,255,247,.72);font-size:14px}
  .ar-footer{border-top:1px solid rgba(255,255,255,.1);margin-top:60px;padding-top:28px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:13px;color:rgba(255,255,255,.45)}
  .ar-footer a{color:rgba(255,255,255,.45);text-decoration:none}
  .ar-footer a:hover{color:#a8ff78}
  .ar-badge{display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(0,217,163,.25);background:rgba(0,217,163,.07);color:rgba(0,217,163,.8);border-radius:999px;padding:5px 10px;font-size:11px;font-weight:700}
  @media(max-width:860px){.ar-grid{grid-template-columns:1fr}.ar-topnav{flex-direction:column;align-items:flex-end}}
</style>

<div class="ar-home-old">
  <div class="ar-wrap">

    <nav class="ar-topnav">
      <a class="ar-brand" href="{{ '/ar/' | url }}">
        {% if site.logoUrl %}
          <img src="{{ site.logoUrl | url }}" alt="{{ site.name }}">
        {% endif %}
        <span>{{ site.name }}</span>
        <span class="ar-badge">كلاسيك</span>
      </a>
      <div class="ar-links">
        <a href="{{ '/ar/' | url }}">الرئيسية</a>
        <a href="{{ '/ar/about/' | url }}">عن الكابتن</a>
        <a href="{{ '/ar/services/' | url }}">الخدمات</a>
        <a href="{{ '/ar/plans/' | url }}">الباقات</a>
        <a href="{{ '/ar/gallery/' | url }}">المعرض</a>
        <a href="{{ '/ar/blog/' | url }}">المقالات</a>
        <a href="{{ '/ar/methylene-blue/' | url }}">ميثيلين بلو</a>
        <a href="{{ '/ar/anti-aging/' | url }}">مكافحة الشيخوخة</a>
        <a href="{{ '/ar/contact/' | url }}">تواصل</a>
        <a href="{{ '/en/home-old/' | url }}" class="lang">EN</a>
      </div>
    </nav>

    <main class="ar-grid">
      <section>
        <span class="ar-kicker">{{ pages.home.ar.hero.badge }}</span>
        <h1>{{ pages.home.ar.hero.title_line1 }} <br><span style="color:#a8ff78">{{ pages.home.ar.hero.title_line2_gradient }}</span></h1>
        <p>{{ pages.home.ar.hero.description }}</p>
        <div class="ar-actions">
          <a class="ar-btn primary" href="{{ site.googleForm }}">{{ pages.home.ar.hero.cta_primary }}</a>
          <a class="ar-btn" href="{{ '/ar/services/' | url }}">{{ pages.home.ar.hero.cta_secondary }}</a>
        </div>
      </section>

      <aside class="ar-card">
        <span class="ar-kicker">O2F Life</span>
        <h2>{{ pages.home.ar.pillars.title }}</h2>
        <p>{{ pages.home.ar.seo.description if pages.home.ar.seo else pages.home.ar.hero.description }}</p>
        <div class="ar-list">
          {% for item in pages.home.ar.pillars.items %}
          <div>
            <b>{{ item.title }}</b>
            <span>{{ item.text }}</span>
          </div>
          {% endfor %}
        </div>
        <div class="ar-actions" style="margin-top:20px">
          <a class="ar-btn primary" href="{{ '/ar/plans/' | url }}">عرض الباقات</a>
          <a class="ar-btn" href="{{ '/ar/contact/' | url }}">تواصل معنا</a>
        </div>
      </aside>
    </main>

    <footer class="ar-footer">
      <span>© {{ "" | year }} {{ site.name }} — جميع الحقوق محفوظة.</span>
      <span>
        <a href="{{ '/ar/privacy/' | url }}">الخصوصية</a>
        <span style="margin:0 8px">·</span>
        <a href="{{ '/ar/terms/' | url }}">الشروط</a>
        <span style="margin:0 8px">·</span>
        <a href="{{ site.social.instagram }}" target="_blank" rel="noopener">Instagram</a>
        {% if site.social.facebook %}
        <span style="margin:0 8px">·</span>
        <a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Facebook</a>
        {% endif %}
      </span>
    </footer>

  </div>
</div>
