---
title: "O2F الرئيسية الجديدة"
description: "صفحة عربية سينمائية جديدة لـ O2F Life تعرض البرامج، النتائج، الباقات، وخطوات البدء."
permalink: /ar/home-v2/index.html
---
{%- set d = pages.homev2.ar -%}
<style>
body:has(.o2f-v2-ar)>header,body:has(.o2f-v2-ar) .site-header,body:has(.o2f-v2-ar) .main-header,body:has(.o2f-v2-ar) .navbar,body:has(.o2f-v2-ar) .chatbot,body:has(.o2f-v2-ar) #chatbot,body:has(.o2f-v2-ar) .chat-widget,body:has(.o2f-v2-ar) .floating-chat,body:has(.o2f-v2-ar) [class*="chatbot"]{display:none!important}.o2f-v2-ar{--bg:#06110d;--text:#f7fff7;--muted:rgba(247,255,247,.76);--lime:#a8ff78;--mint:#00d9a3;--blue:#54c8ff;--line:rgba(255,255,255,.22);min-height:100vh;background:var(--bg);color:var(--text);font-family:Tajawal,Inter,system-ui,sans-serif;position:relative;overflow:hidden;direction:rtl}.o2f-v2-ar *{box-sizing:border-box;min-width:0;overflow-wrap:break-word}.o2f-bg-ar{position:fixed;inset:-14%;z-index:0;background-position:center top;background-size:cover;background-repeat:no-repeat;transform:translateY(var(--bg-y,0)) scale(var(--bg-s,1.14));filter:saturate(1.08) contrast(1.05)}.o2f-v2-ar:before{content:"";position:fixed;inset:0;z-index:1;background:radial-gradient(circle at 50% 14%,rgba(255,255,255,.15),transparent 25%),linear-gradient(90deg,rgba(0,0,0,.82),rgba(0,0,0,.42),rgba(0,0,0,.84)),linear-gradient(180deg,rgba(0,0,0,.05),rgba(6,17,13,.96));pointer-events:none}.o2f-main-ar{position:relative;z-index:3}.dock{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);z-index:30;display:flex;gap:8px;padding:8px;border-radius:999px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.28);backdrop-filter:blur(22px);box-shadow:0 22px 70px rgba(0,0,0,.32);direction:rtl}.dock a,.dock button{color:#fff;text-decoration:none;font-size:12px;font-weight:900;padding:10px 13px;border-radius:999px;white-space:nowrap;border:0;background:transparent;cursor:pointer;font-family:inherit}.dock a.active,.dock a:hover,.dock button:hover{background:rgba(255,255,255,.22)}.social-menu-ar{position:relative}.social-panel-ar{position:absolute;left:0;bottom:48px;display:none;min-width:190px;padding:10px;border-radius:22px;background:rgba(6,17,13,.86);border:1px solid rgba(255,255,255,.26);backdrop-filter:blur(20px);box-shadow:0 20px 60px rgba(0,0,0,.35)}.social-menu-ar.open .social-panel-ar{display:grid;gap:7px}.social-panel-ar a{display:flex!important;width:100%;justify-content:space-between;background:rgba(255,255,255,.1)}.section{padding:clamp(70px,10vh,120px) clamp(16px,5vw,76px);position:relative}.hero{min-height:92vh;display:grid;align-items:center;text-align:center}.container{width:min(1220px,100%);margin:0 auto}.kicker{display:inline-flex;gap:8px;align-items:center;color:var(--lime);font-size:12px;font-weight:950;letter-spacing:.05em;text-transform:uppercase;margin-bottom:14px}.kicker:before{content:"";width:8px;height:8px;border-radius:50%;background:var(--lime);box-shadow:0 0 20px rgba(168,255,120,.7)}h1{font-size:clamp(42px,8vw,104px);line-height:.95;letter-spacing:-.045em;margin:12px auto 18px;max-width:1080px;text-shadow:0 25px 75px rgba(0,0,0,.42)}h2{font-size:clamp(32px,5vw,68px);line-height:1;letter-spacing:-.035em;margin:10px 0 16px}h3{font-size:clamp(22px,2.1vw,32px);line-height:1.15;margin:0 0 12px}p,li,span{color:var(--muted);line-height:1.8}.lead{font-size:clamp(16px,1.35vw,20px);max-width:820px;margin:0 auto 24px}.btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}.btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.55);border-radius:999px;padding:13px 20px;background:rgba(255,255,255,.13);backdrop-filter:blur(18px);color:#fff;text-decoration:none;font-weight:950;line-height:1.15;text-align:center;min-height:48px}.btn.primary{background:linear-gradient(135deg,rgba(168,255,120,.28),rgba(0,217,163,.14))}.glass{position:relative;border:1px solid var(--line);border-radius:34px;background:linear-gradient(145deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(24px) saturate(150%);box-shadow:0 28px 85px rgba(0,0,0,.24);overflow:hidden}.journey{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:30px}.journey-card{padding:22px;text-align:right;min-height:170px}.num{width:36px;height:36px;border-radius:50%;display:grid;place-items:center;background:var(--lime);color:#06110d!important;font-weight:1000;margin-bottom:14px}.grid2{display:grid;grid-template-columns:minmax(520px,1.1fr) minmax(320px,.9fr);gap:clamp(22px,5vw,68px);align-items:center}.coach-photo{min-height:620px}.coach-photo img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}.coach-photo:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent,rgba(0,0,0,.65))}.stats{position:absolute;z-index:2;left:18px;right:18px;bottom:18px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.stats span{padding:12px;border-radius:18px;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.14);text-align:center;font-weight:950;backdrop-filter:blur(12px)}.panel{padding:30px}.chips{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}.chip{padding:9px 12px;border-radius:999px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.16);font-size:12px;font-weight:850;color:#fff!important}.section-head{text-align:center;max-width:900px;margin:0 auto 28px}.tabs-shell{padding:16px}.tabs-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:8px;border-radius:999px;background:rgba(255,255,255,.1);margin-bottom:16px}.tab-btn{border:0;border-radius:999px;padding:14px;color:#fff;background:transparent;font-weight:950;cursor:pointer;font-family:inherit}.tab-btn.active{background:linear-gradient(135deg,rgba(168,255,120,.26),rgba(84,200,255,.18))}.tab-panel{display:none;grid-template-columns:.95fr 1.05fr;gap:18px}.tab-panel.active{display:grid}.tab-copy{padding:28px}.cards3,.plans,.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.mini{padding:16px;border-radius:20px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15)}.mini b{display:block;color:#fff;margin-bottom:6px}.visual{position:relative;min-height:500px;display:grid;place-items:center}.tab-media{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.92}.visual:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.58));pointer-events:none}.visual-caption{position:absolute;z-index:2;left:20px;right:20px;bottom:20px;padding:16px;border-radius:20px;background:rgba(0,0,0,.34);border:1px solid rgba(255,255,255,.15);backdrop-filter:blur(12px)}.steps .glass,.plans .glass{padding:24px}.before-wrap{display:grid;grid-template-columns:.85fr 1.15fr;gap:22px;align-items:center}.ba{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:14px;min-height:520px}.ba-card{position:relative;border-radius:24px;overflow:hidden;background:rgba(255,255,255,.08)}.ba-card img{width:100%;height:100%;object-fit:cover}.label{position:absolute;top:16px;right:16px;padding:9px 13px;border-radius:999px;background:rgba(0,0,0,.45);font-weight:950}.result-list{display:grid;gap:14px}.result-card{padding:24px;display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:center}.result-card strong{font-size:54px;color:var(--lime);line-height:1}.gallery-grid{display:grid;grid-template-columns:1fr .8fr 1.2fr;grid-auto-rows:190px;gap:14px}.gallery-item{border-radius:26px;overflow:hidden;position:relative}.gallery-item.big{grid-row:span 2}.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .7s ease,filter .7s ease}.gallery-item:hover img{transform:scale(1.06);filter:brightness(1.12)}.gallery-item span{position:absolute;right:14px;bottom:14px;padding:8px 12px;border-radius:999px;background:rgba(0,0,0,.44);color:#fff!important;font-weight:900;font-size:12px}.plan{min-height:520px;display:flex;flex-direction:column;gap:12px}.plan.highlight{background:linear-gradient(145deg,rgba(168,255,120,.22),rgba(255,255,255,.08))}.price{font-size:42px;font-weight:1000;color:#fff;letter-spacing:-.04em;line-height:1}.price small{font-size:13px;color:var(--muted);font-weight:850}.month-picker{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:6px;border-radius:18px;background:rgba(255,255,255,.1)}.month-picker button{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.08);color:#fff;border-radius:14px;padding:9px 6px;font-weight:950;cursor:pointer;font-family:inherit}.month-picker button.active{background:rgba(168,255,120,.24);border-color:rgba(168,255,120,.55)}.saving{font-size:12px;color:var(--lime)!important;font-weight:900;min-height:18px}.features{padding:0;list-style:none}.features li{margin:9px 0;padding-right:14px;position:relative}.features li:before{content:"";position:absolute;right:0;top:.75em;width:5px;height:5px;border-radius:50%;background:var(--lime)}.plan .btn{margin-top:auto}.marquee{display:grid;gap:14px;overflow:hidden}.marquee-row{display:flex;gap:14px;width:max-content}.marquee-row.row-a{animation:moveRtlA 34s linear infinite}.marquee-row.row-b{animation:moveRtlB 40s linear infinite;transform:translateX(50%)}.comment-card{width:360px;padding:22px;border-radius:26px;background:linear-gradient(145deg,rgba(255,255,255,.17),rgba(255,255,255,.07));border:1px solid rgba(255,255,255,.18);box-shadow:0 20px 55px rgba(0,0,0,.22)}.quote{font-size:34px;color:var(--lime);line-height:1}.avatar{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;background:rgba(168,255,120,.18);color:#fff!important;font-weight:950;margin-top:14px}.final{padding-bottom:150px}.faq{display:grid;gap:14px}.faq .glass{padding:24px}@keyframes moveRtlA{from{transform:translateX(0)}to{transform:translateX(50%)}}@keyframes moveRtlB{from{transform:translateX(50%)}to{transform:translateX(0)}}@media(max-width:1050px){.grid2,.tab-panel,.before-wrap{grid-template-columns:1fr}.plans,.steps,.cards3{grid-template-columns:1fr 1fr}.coach-photo{min-height:520px}.gallery-grid{grid-template-columns:1fr 1fr}.dock{bottom:18px}}@media(max-width:720px){.section{padding:68px 16px}.hero{min-height:auto;padding-top:28px}.journey,.plans,.steps,.cards3,.ba,.gallery-grid{grid-template-columns:1fr}.dock{max-width:calc(100vw - 36px);overflow-x:auto;overflow-y:hidden;justify-content:flex-start;bottom:14px;top:auto}.dock a,.dock button{font-size:11px;padding:9px 10px}.social-panel-ar{left:auto;right:0;top:auto;bottom:48px}.lead{text-align:center}.btns{flex-direction:column}.btn{width:100%}.coach-photo{order:-1;min-height:430px}.stats{grid-template-columns:1fr 1fr}.tabs-nav{grid-template-columns:1fr;border-radius:26px}.visual{min-height:320px;order:-1}.tab-panel.active{display:flex;flex-direction:column}.ba{min-height:auto}.ba-card{min-height:330px}.plans .highlight{order:-1}.result-card{grid-template-columns:1fr}.month-picker{grid-template-columns:1fr 1fr 1fr}.comment-card{width:300px}.gallery-item,.gallery-item.big{grid-row:auto;height:260px}h1{font-size:clamp(42px,13vw,66px)}}
</style>

<div class="o2f-v2-ar" id="o2fV2Ar">
  <div class="o2f-bg-ar" id="o2fBgAr" style="background-image:url('{{ d.images.background }}')"></div>

  <nav class="dock">
    <a href="#hero" class="active">الرئيسية</a>
    <a href="#coach">المدرب</a>
    <a href="#programs">البرامج</a>
    <a href="#gallery">المعرض</a>
    <a href="#plans">الباقات</a>
    <a href="/en/">EN</a>
    <div class="social-menu-ar" id="socialMenuAr">
      <button type="button" id="socialToggleAr">☰</button>
      <div class="social-panel-ar">
        <a href="https://wa.me/{{ site.whatsapp | replace('+', '') }}">واتساب <span>↗</span></a>
        <a href="#contact">تواصل <span>→</span></a>
        {% if site.social.instagram %}<a href="{{ site.social.instagram }}">Instagram <span>↗</span></a>{% endif %}
        {% if site.social.facebook %}<a href="{{ site.social.facebook }}">Facebook <span>↗</span></a>{% endif %}
      </div>
    </div>
  </nav>

  <main class="o2f-main-ar">

    <!-- ── Hero ── -->
    <section class="section hero" id="hero">
      <div class="container">
        <span class="kicker">{{ d.hero.kicker }}</span>
        <h1>{{ d.hero.h1 }}</h1>
        <p class="lead">{{ d.hero.lead }}</p>
        <div class="btns">
          <a class="btn primary" href="{{ site.googleForm }}">{{ d.hero.cta_primary }}</a>
          <a class="btn" href="#programs">{{ d.hero.cta_secondary }}</a>
        </div>
        <div class="journey">
          <article class="glass journey-card">
            <span class="num">1</span>
            <b>{{ d.hero.journey_1_title }}</b>
            <p>{{ d.hero.journey_1_text }}</p>
          </article>
          <article class="glass journey-card">
            <span class="num">2</span>
            <b>{{ d.hero.journey_2_title }}</b>
            <p>{{ d.hero.journey_2_text }}</p>
          </article>
          <article class="glass journey-card">
            <span class="num">3</span>
            <b>{{ d.hero.journey_3_title }}</b>
            <p>{{ d.hero.journey_3_text }}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── Coach ── -->
    <section class="section" id="coach">
      <div class="grid2 container">
        <div class="coach-photo glass">
          <img src="{{ d.images.coach }}" alt="{{ d.coach.kicker }}">
          <div class="stats">
            <span>{{ d.coach.stat_1_value }}<br><small>{{ d.coach.stat_1_label }}</small></span>
            <span>{{ d.coach.stat_2_value }}<br><small>{{ d.coach.stat_2_label }}</small></span>
            <span>{{ d.coach.stat_3_value }}<br><small>{{ d.coach.stat_3_label }}</small></span>
            <span>{{ d.coach.stat_4_value }}<br><small>{{ d.coach.stat_4_label }}</small></span>
          </div>
        </div>
        <article class="panel glass">
          <span class="kicker">{{ d.coach.kicker }}</span>
          <h2>{{ d.coach.h2 }}</h2>
          <p>{{ d.coach.bio }}</p>
          <div class="chips">
            <span class="chip">{{ d.coach.chip_1 }}</span>
            <span class="chip">{{ d.coach.chip_2 }}</span>
            <span class="chip">{{ d.coach.chip_3 }}</span>
            <span class="chip">{{ d.coach.chip_4 }}</span>
          </div>
          <a class="btn primary" href="#how">{{ d.coach.cta }}</a>
        </article>
      </div>
    </section>

    <!-- ── Programs ── -->
    <section class="section" id="programs">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ d.programs.kicker }}</span>
          <h2>{{ d.programs.h2 }}</h2>
          <p>{{ d.programs.lead }}</p>
        </div>
        <div class="tabs-shell glass">
          <div class="tabs-nav">
            <button class="tab-btn active" data-tab="anti" type="button">{{ d.programs.tab1_label }}</button>
            <button class="tab-btn" data-tab="blue" type="button">{{ d.programs.tab2_label }}</button>
            <button class="tab-btn" data-tab="training" type="button">{{ d.programs.tab3_label }}</button>
          </div>
          <article class="tab-panel active" id="tab-anti">
            <div class="tab-copy glass">
              <span class="kicker">{{ d.programs.tab1_kicker }}</span>
              <h3>{{ d.programs.tab1_h3 }}</h3>
              <p>{{ d.programs.tab1_text }}</p>
              <div class="cards3">
                <div class="mini"><b>{{ d.programs.tab1_card1_title }}</b><span>{{ d.programs.tab1_card1_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab1_card2_title }}</b><span>{{ d.programs.tab1_card2_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab1_card3_title }}</b><span>{{ d.programs.tab1_card3_text }}</span></div>
              </div>
            </div>
            <div class="visual glass">
              <img class="tab-media" src="{{ d.images.tab_anti }}" alt="{{ d.programs.tab1_h3 }}">
              <div class="visual-caption">
                <b>{{ d.programs.tab1_caption_title }}</b>
                <p>{{ d.programs.tab1_caption_text }}</p>
              </div>
            </div>
          </article>
          <article class="tab-panel" id="tab-blue">
            <div class="tab-copy glass">
              <span class="kicker">{{ d.programs.tab2_kicker }}</span>
              <h3>{{ d.programs.tab2_h3 }}</h3>
              <p>{{ d.programs.tab2_text }}</p>
              <div class="cards3">
                <div class="mini"><b>{{ d.programs.tab2_card1_title }}</b><span>{{ d.programs.tab2_card1_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab2_card2_title }}</b><span>{{ d.programs.tab2_card2_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab2_card3_title }}</b><span>{{ d.programs.tab2_card3_text }}</span></div>
              </div>
            </div>
            <div class="visual glass">
              <img class="tab-media" src="{{ d.images.tab_blue }}" alt="{{ d.programs.tab2_h3 }}">
              <div class="visual-caption">
                <b>{{ d.programs.tab2_caption_title }}</b>
                <p>{{ d.programs.tab2_caption_text }}</p>
              </div>
            </div>
          </article>
          <article class="tab-panel" id="tab-training">
            <div class="tab-copy glass">
              <span class="kicker">{{ d.programs.tab3_kicker }}</span>
              <h3>{{ d.programs.tab3_h3 }}</h3>
              <p>{{ d.programs.tab3_text }}</p>
              <div class="cards3">
                <div class="mini"><b>{{ d.programs.tab3_card1_title }}</b><span>{{ d.programs.tab3_card1_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab3_card2_title }}</b><span>{{ d.programs.tab3_card2_text }}</span></div>
                <div class="mini"><b>{{ d.programs.tab3_card3_title }}</b><span>{{ d.programs.tab3_card3_text }}</span></div>
              </div>
            </div>
            <div class="visual glass">
              <img class="tab-media" src="{{ d.images.tab_training }}" alt="{{ d.programs.tab3_h3 }}">
              <div class="visual-caption">
                <b>{{ d.programs.tab3_caption_title }}</b>
                <p>{{ d.programs.tab3_caption_text }}</p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ── How It Works ── -->
    <section class="section" id="how">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ d.how.kicker }}</span>
          <h2>{{ d.how.h2 }}</h2>
        </div>
        <div class="steps">
          <article class="glass"><span class="num">1</span><h3>{{ d.how.step1_title }}</h3><p>{{ d.how.step1_text }}</p></article>
          <article class="glass"><span class="num">2</span><h3>{{ d.how.step2_title }}</h3><p>{{ d.how.step2_text }}</p></article>
          <article class="glass"><span class="num">3</span><h3>{{ d.how.step3_title }}</h3><p>{{ d.how.step3_text }}</p></article>
        </div>
      </div>
    </section>

    <!-- ── Results / Before-After ── -->
    <section class="section" id="results">
      <div class="container before-wrap">
        <div>
          <span class="kicker">{{ d.results.kicker }}</span>
          <h2>{{ d.results.h2 }}</h2>
          <p>{{ d.results.text }}</p>
          <div class="result-list">
            <article class="glass result-card"><strong>{{ d.results.item1_num }}</strong><p>{{ d.results.item1_text }}</p></article>
            <article class="glass result-card"><strong>{{ d.results.item2_num }}</strong><p>{{ d.results.item2_text }}</p></article>
            <article class="glass result-card"><strong>{{ d.results.item3_num }}</strong><p>{{ d.results.item3_text }}</p></article>
          </div>
        </div>
        <div class="ba glass">
          <div class="ba-card">
            <img src="{{ d.images.before }}" alt="Before">
            <span class="label">{{ d.results.before_label }}</span>
          </div>
          <div class="ba-card">
            <img src="{{ d.images.after }}" alt="After">
            <span class="label">{{ d.results.after_label }}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Gallery ── -->
    <section class="section" id="gallery">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ d.gallery.kicker }}</span>
          <h2>{{ d.gallery.h2 }}</h2>
          <p>{{ d.gallery.lead }}</p>
        </div>
        <div class="gallery-grid">
          <figure class="gallery-item big glass"><img src="{{ d.images.gallery_1 }}" alt="{{ d.gallery.label_1 }}"><span>{{ d.gallery.label_1 }}</span></figure>
          <figure class="gallery-item glass"><img src="{{ d.images.gallery_2 }}" alt="{{ d.gallery.label_2 }}"><span>{{ d.gallery.label_2 }}</span></figure>
          <figure class="gallery-item glass"><img src="{{ d.images.gallery_3 }}" alt="{{ d.gallery.label_3 }}"><span>{{ d.gallery.label_3 }}</span></figure>
          <figure class="gallery-item glass"><img src="{{ d.images.gallery_4 }}" alt="{{ d.gallery.label_4 }}"><span>{{ d.gallery.label_4 }}</span></figure>
          <figure class="gallery-item big glass"><img src="{{ d.images.gallery_5 }}" alt="{{ d.gallery.label_5 }}"><span>{{ d.gallery.label_5 }}</span></figure>
        </div>
      </div>
    </section>

    <!-- ── Plans ── -->
    <section class="section" id="plans">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ d.plans.kicker }}</span>
          <h2>{{ d.plans.h2 }}</h2>
          <p>{{ d.plans.lead }}</p>
        </div>
        <div class="plans">
          <article class="glass plan{% if d.plans.plan1_highlight %} highlight{% endif %}"
