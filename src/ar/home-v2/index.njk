---
title: "O2F الرئيسية"
description: "صفحة O2F العربية الرئيسية — الكابتن أسامة عمران، البرامج، النتائج، الباقات، وآراء العملاء."
permalink: /ar/home-v2/index.html
---
{% set hv2 = homeV2.ar %}
<style>
body:has(.o2f-v2-ar)>header,body:has(.o2f-v2-ar) .site-header,body:has(.o2f-v2-ar) .main-header,body:has(.o2f-v2-ar) .navbar,body:has(.o2f-v2-ar) .chatbot,body:has(.o2f-v2-ar) #chatbot,body:has(.o2f-v2-ar) .chat-widget,body:has(.o2f-v2-ar) .floating-chat,body:has(.o2f-v2-ar) [class*="chatbot"]{display:none!important}
.o2f-v2-ar{--bg:#06110d;--text:#f7fff7;--muted:rgba(247,255,247,.76);--lime:#a8ff78;--mint:#00d9a3;--blue:#54c8ff;--line:rgba(255,255,255,.22);min-height:100vh;background:var(--bg);color:var(--text);font-family:Tajawal,Inter,system-ui,sans-serif;position:relative;overflow:hidden;direction:rtl}
.o2f-v2-ar *{box-sizing:border-box;min-width:0;overflow-wrap:break-word}
.o2f-bg{position:fixed;inset:-14%;z-index:0;background:url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2600&q=88') center top/cover no-repeat;transform:translateY(var(--bg-y,0)) scale(var(--bg-s,1.14));filter:saturate(1.08) contrast(1.05);will-change:transform}
.o2f-v2-ar:before{content:"";position:fixed;inset:0;z-index:1;background:radial-gradient(circle at 50% 14%,rgba(255,255,255,.15),transparent 25%),linear-gradient(90deg,rgba(0,0,0,.82),rgba(0,0,0,.42),rgba(0,0,0,.84)),linear-gradient(180deg,rgba(0,0,0,.05),rgba(6,17,13,.96));pointer-events:none}
.o2f-main{position:relative;z-index:3}
.dock{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);z-index:30;display:flex;gap:8px;padding:8px;border-radius:999px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.28);backdrop-filter:blur(22px);box-shadow:0 22px 70px rgba(0,0,0,.32);direction:rtl}
.dock a,.dock button{color:#fff;text-decoration:none;font-size:12px;font-weight:900;padding:10px 13px;border-radius:999px;white-space:nowrap;border:0;background:transparent;cursor:pointer;font-family:inherit}
.dock a.active,.dock a:hover,.dock button:hover{background:rgba(255,255,255,.22)}
.dock-lang{border:1px solid rgba(255,255,255,.3)!important;border-radius:999px!important;font-size:11px!important;opacity:.85}
.social-menu{position:relative}
.social-panel{position:absolute;left:0;right:auto;bottom:48px;display:none;min-width:190px;padding:10px;border-radius:22px;background:rgba(6,17,13,.86);border:1px solid rgba(255,255,255,.26);backdrop-filter:blur(20px);box-shadow:0 20px 60px rgba(0,0,0,.35)}
.social-menu.open .social-panel{display:grid;gap:7px}
.social-panel a{display:flex!important;width:100%;justify-content:space-between;background:rgba(255,255,255,.1)}
.section{padding:clamp(70px,10vh,120px) clamp(16px,5vw,76px);position:relative}
.hero{min-height:92vh;display:grid;align-items:center;text-align:center}
.container{width:min(1220px,100%);margin:0 auto}
.kicker{display:inline-flex;gap:8px;align-items:center;color:var(--lime);font-size:12px;font-weight:950;letter-spacing:.05em;text-transform:uppercase;margin-bottom:14px}
.kicker:before{content:"";width:8px;height:8px;border-radius:50%;background:var(--lime);box-shadow:0 0 20px rgba(168,255,120,.7)}
h1{font-size:clamp(42px,8vw,104px);line-height:.95;letter-spacing:-.045em;margin:12px auto 18px;max-width:1080px;text-shadow:0 25px 75px rgba(0,0,0,.42)}
h2{font-size:clamp(32px,5vw,68px);line-height:1;letter-spacing:-.035em;margin:10px 0 16px}
h3{font-size:clamp(22px,2.1vw,32px);line-height:1.15;margin:0 0 12px}
p,li,span{color:var(--muted);line-height:1.8}
.lead{font-size:clamp(16px,1.35vw,20px);max-width:820px;margin:0 auto 24px}
.btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.55);border-radius:999px;padding:13px 20px;background:rgba(255,255,255,.13);backdrop-filter:blur(18px);color:#fff;text-decoration:none;font-weight:950;line-height:1.15;text-align:center;min-height:48px}
.btn.primary{background:linear-gradient(135deg,rgba(168,255,120,.28),rgba(0,217,163,.14))}
.glass{position:relative;border:1px solid var(--line);border-radius:34px;background:linear-gradient(145deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(24px) saturate(150%);box-shadow:0 28px 85px rgba(0,0,0,.24);overflow:hidden}
.journey{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:30px}
.journey-card{padding:22px;text-align:right;min-height:170px}
.num{width:36px;height:36px;border-radius:50%;display:grid;place-items:center;background:var(--lime);color:#06110d!important;font-weight:1000;margin-bottom:14px}
.grid2{display:grid;grid-template-columns:minmax(320px,.9fr) minmax(520px,1.1fr);gap:clamp(22px,5vw,68px);align-items:center}
.coach-photo{min-height:660px}
.coach-photo img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
.coach-photo:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent,rgba(0,0,0,.65))}
.stats{position:absolute;z-index:2;left:18px;right:18px;bottom:18px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.stats span{padding:12px;border-radius:18px;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.14);text-align:center;font-weight:950;backdrop-filter:blur(12px)}
.panel{padding:30px}
.chips{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
.chip{padding:9px 12px;border-radius:999px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.16);font-size:12px;font-weight:850;color:#fff!important}
.section-head{text-align:center;max-width:900px;margin:0 auto 28px}
.tabs-shell{padding:16px}
.tabs-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:8px;border-radius:999px;background:rgba(255,255,255,.1);margin-bottom:16px}
.tab-btn{border:0;border-radius:999px;padding:14px;color:#fff;background:transparent;font-weight:950;cursor:pointer;font-family:inherit}
.tab-btn.active{background:linear-gradient(135deg,rgba(168,255,120,.26),rgba(84,200,255,.18))}
.tab-panel{display:none;grid-template-columns:1.05fr .95fr;gap:18px}
.tab-panel.active{display:grid}
.tab-copy{padding:28px}
.cards3,.plans,.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.mini{padding:16px;border-radius:20px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15)}
.mini b{display:block;color:#fff;margin-bottom:6px}
.visual{position:relative;min-height:500px;display:grid;place-items:center}
.tab-media{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.92}
.visual:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.58));pointer-events:none}
.visual-caption{position:absolute;z-index:2;left:20px;right:20px;bottom:20px;padding:16px;border-radius:20px;background:rgba(0,0,0,.34);border:1px solid rgba(255,255,255,.15);backdrop-filter:blur(12px)}
.steps .glass,.plans .glass{padding:24px}
.before-wrap{display:grid;grid-template-columns:.85fr 1.15fr;gap:22px;align-items:center}
.ba{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:14px;min-height:520px}
.ba-card{position:relative;border-radius:24px;overflow:hidden;background:rgba(255,255,255,.08)}
.ba-card img{width:100%;height:100%;object-fit:cover}
.label{position:absolute;top:16px;right:16px;padding:9px 13px;border-radius:999px;background:rgba(0,0,0,.45);font-weight:950}
.result-list{display:grid;gap:14px}
.result-card{padding:24px;display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:center}
.result-card strong{font-size:54px;color:var(--lime);line-height:1}
.gallery-grid{display:grid;grid-template-columns:1fr .8fr 1.2fr;grid-auto-rows:190px;gap:14px}
.gallery-item{border-radius:26px;overflow:hidden;position:relative}
.gallery-item.big{grid-row:span 2}
.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .7s ease,filter .7s ease}
.gallery-item:hover img{transform:scale(1.06);filter:brightness(1.12)}
.gallery-item span{position:absolute;right:14px;bottom:14px;padding:8px 12px;border-radius:999px;background:rgba(0,0,0,.44);color:#fff!important;font-weight:900;font-size:12px}
.plan{min-height:520px;display:flex;flex-direction:column;gap:12px}
.plan.highlight{background:linear-gradient(145deg,rgba(168,255,120,.22),rgba(255,255,255,.08))}
.price{font-size:42px;font-weight:1000;color:#fff;letter-spacing:-.04em;line-height:1}
.price small{font-size:13px;color:var(--muted);font-weight:850}
.features{padding:0;list-style:none}
.features li{margin:9px 0;padding-right:14px;position:relative}
.features li:before{content:"";position:absolute;right:0;top:.75em;width:5px;height:5px;border-radius:50%;background:var(--lime)}
.plan .btn{margin-top:auto}
.month-picker{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;padding:6px;border-radius:18px;background:rgba(255,255,255,.1)}
.month-picker button{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.08);color:#fff;border-radius:14px;padding:9px 6px;font-weight:950;cursor:pointer}
.month-picker button.active{background:rgba(168,255,120,.24);border-color:rgba(168,255,120,.55)}
.saving{font-size:12px;color:var(--lime)!important;font-weight:900;min-height:18px}
.marquee{display:grid;gap:14px;overflow:hidden}
.marquee-row{display:flex;gap:14px;width:max-content;animation:moveLeft 32s linear infinite;will-change:transform}
.marquee-row:nth-child(2){animation:moveRight 38s linear infinite;transform:translateX(-50%)}
.comment-card{width:360px;padding:22px;border-radius:26px;background:linear-gradient(145deg,rgba(255,255,255,.17),rgba(255,255,255,.07));border:1px solid rgba(255,255,255,.18);box-shadow:0 20px 55px rgba(0,0,0,.22)}
.quote{font-size:34px;color:var(--lime);line-height:1}
.avatar{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;background:rgba(168,255,120,.18);color:#fff!important;font-weight:950;margin-top:14px}
.final{padding-bottom:160px}
.faq{display:grid;gap:14px}
.faq .glass{padding:24px}
.v2-footer{padding:28px clamp(16px,5vw,76px) 100px;border-top:1px solid rgba(255,255,255,.1);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:13px;color:rgba(247,255,247,.45);position:relative;z-index:3}
.v2-footer a{color:rgba(247,255,247,.45);text-decoration:none;transition:color .18s}
.v2-footer a:hover{color:var(--lime)}
.v2-footer-links{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
@keyframes moveLeft{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes moveRight{from{transform:translateX(-50%)}to{transform:translateX(0)}}
@media(max-width:1050px){.grid2,.tab-panel,.before-wrap{grid-template-columns:1fr}.plans,.steps,.cards3,.detail-grid{grid-template-columns:1fr 1fr}.coach-photo{min-height:520px}.gallery-grid{grid-template-columns:1fr 1fr}.dock{bottom:18px!important;top:auto!important}}
@media(max-width:720px){.section{padding:68px 16px}.hero{min-height:auto;padding-top:92px;padding-bottom:110px}.journey,.plans,.steps,.cards3,.ba,.gallery-grid{grid-template-columns:1fr}.dock{bottom:14px!important;top:auto!important;max-width:calc(100vw - 18px);overflow:visible;justify-content:flex-start}.dock a,.dock button{font-size:11px;padding:9px 10px}.lead{text-align:center}.btns{flex-direction:column}.btn{width:100%}.coach-photo{order:-1;min-height:430px}.stats{grid-template-columns:1fr 1fr}.tabs-nav{grid-template-columns:1fr;border-radius:26px}.visual{min-height:320px;order:-1}.tab-panel.active{display:flex;flex-direction:column}.ba{min-height:auto}.ba-card{min-height:330px}.plans .highlight{order:-1}.result-card{grid-template-columns:1fr}.month-picker{grid-template-columns:1fr 1fr}.comment-card{width:300px}.gallery-item,.gallery-item.big{grid-row:auto;height:260px}h1{font-size:clamp(42px,13vw,66px)}.v2-footer{flex-direction:column;text-align:center;gap:10px}.social-panel{left:0;right:auto;bottom:auto;top:48px}}
</style>

<div class="o2f-bg" id="o2fBg"></div>

<div class="o2f-v2-ar" id="o2fV2Ar">

  <nav class="dock">
    <a href="#hero" class="active">الرئيسية</a>
    <a href="#coach">المدرب</a>
    <a href="#programs">البرامج</a>
    <a href="#gallery">المعرض</a>
    <a href="#plans">الباقات</a>
    <a href="/en/" class="dock-lang">EN / English</a>
    <div class="social-menu" id="socialMenu">
      <button type="button" id="socialToggle">☰</button>
      <div class="social-panel" id="homeV2SocialPanel">
        {% if site.social.whatsapp %}<a href="https://wa.me/{{ site.social.whatsapp }}">واتساب <span>↗</span></a>{% else %}<a href="#contact">واتساب <span>↗</span></a>{% endif %}
        {% if site.social.facebook %}<a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Facebook <span>↗</span></a>{% endif %}
        {% if site.social.instagram %}<a href="{{ site.social.instagram }}" target="_blank" rel="noopener">Instagram <span>↗</span></a>{% endif %}
      </div>
    </div>
  </nav>

  <main class="o2f-main">

    {# ── HERO ── #}
    <section class="section hero" id="hero">
      <div class="container">
        <span class="kicker">{{ hv2.hero.kicker }}</span>
        <h1>{{ hv2.hero.title }}</h1>
        <p class="lead">{{ hv2.hero.description }}</p>
        <div class="btns">
          <a class="btn primary" href="{{ site.googleForm }}">{{ hv2.hero.cta_primary }}</a>
          <a class="btn" href="#programs">{{ hv2.hero.cta_secondary }}</a>
        </div>
        <div class="journey">
          {% for step in hv2.journey %}
          <article class="glass journey-card">
            <span class="num">{{ loop.index }}</span>
            <b>{{ step.title }}</b>
            <p>{{ step.desc }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {# ── COACH ── #}
    <section class="section" id="coach">
      <div class="grid2 container">
        <div class="coach-photo glass">
          <img src="/assets/images/hero.jpeg" alt="الكابتن أسامة عمران">
          <div class="stats">
            <span>{{ site.stats.years }}<br><small>{{ hv2.coach.stats.years_label }}</small></span>
            <span>{{ site.stats.clients }}<br><small>{{ hv2.coach.stats.clients_label }}</small></span>
            <span>{{ site.stats.custom }}<br><small>{{ hv2.coach.stats.custom_label }}</small></span>
            <span>{{ site.stats.support }}<br><small>{{ hv2.coach.stats.support_label }}</small></span>
          </div>
        </div>
        <article class="panel glass">
          <span class="kicker">{{ hv2.coach.kicker }}</span>
          <h2>{{ hv2.coach.title }}</h2>
          <p>{{ hv2.coach.bio }}</p>
          <div class="chips">
            {% for chip in hv2.coach.chips %}
            <span class="chip">{{ chip }}</span>
            {% endfor %}
          </div>
          <a class="btn primary" href="#how" style="margin-top:18px">{{ hv2.coach.cta }}</a>
        </article>
      </div>
    </section>

    {# ── PROGRAMS ── #}
    <section class="section" id="programs">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ hv2.programs.kicker }}</span>
          <h2>{{ hv2.programs.title }}</h2>
          <p>{{ hv2.programs.desc }}</p>
        </div>
        <div class="tabs-shell glass">
          <div class="tabs-nav">
            {% for tab in hv2.programs.tabs %}
            <button class="tab-btn{% if loop.first %} active{% endif %}" data-tab="{{ tab.key }}" type="button">{{ tab.label }}</button>
            {% endfor %}
          </div>
          {% for tab in hv2.programs.tabs %}
          <article class="tab-panel{% if loop.first %} active{% endif %}" id="tab-{{ tab.key }}">
            <div class="tab-copy glass">
              <span class="kicker">{{ tab.kicker }}</span>
              <h3>{{ tab.title }}</h3>
              <p>{{ tab.desc }}</p>
              <div class="cards3">
                {% for card in tab.cards %}
                <div class="mini"><b>{{ card.label }}</b><span>{{ card.text }}</span></div>
                {% endfor %}
              </div>
            </div>
            <div class="visual glass">
              <img class="tab-media" src="{{ tab.image }}" alt="{{ tab.title }}">
              <div class="visual-caption"><b>{{ tab.caption_title }}</b></div>
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {# ── HOW IT WORKS ── #}
    <section class="section" id="how">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ hv2.how_it_works.kicker }}</span>
          <h2>{{ hv2.how_it_works.title }}</h2>
        </div>
        <div class="steps">
          {% for step in hv2.how_it_works.steps %}
          <article class="glass" style="padding:24px">
            <span class="num">{{ loop.index }}</span>
            <h3>{{ step.title }}</h3>
            <p>{{ step.desc }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {# ── RESULTS ── #}
    <section class="section" id="results">
      <div class="container before-wrap">
        <div>
          <span class="kicker">{{ hv2.results.kicker }}</span>
          <h2>{{ hv2.results.title }}</h2>
          <p>{{ hv2.results.desc }}</p>
          <div class="result-list">
            {% for point in hv2.results.points %}
            <article class="glass result-card">
              <strong>{{ loop.index }}</strong>
              <p>{{ point }}</p>
            </article>
            {% endfor %}
          </div>
        </div>
        <div class="ba glass">
          <div class="ba-card">
            <img src="https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=900&q=85" alt="قبل">
            <span class="label">قبل / الأسبوع 1</span>
          </div>
          <div class="ba-card">
            <img src="https://images.unsplash.com/photo-1605296867304-46d5465a13f1?auto=format&fit=crop&w=900&q=85" alt="بعد">
            <span class="label">بعد / الأسبوع 12</span>
          </div>
        </div>
      </div>
    </section>

    {# ── GALLERY ── #}
    <section class="section" id="gallery">
      <div class="container">
        <div class="section-head">
          <span class="kicker">المعرض</span>
          <h2>لحظات تدريب، صحة، وتحول.</h2>
          <p>قسم بصري لصور البرامج، تقدم العملاء، لقطات التمرين، ولحظات المدرب.</p>
        </div>
        {% if gallery and gallery.length %}
        <div class="gallery-grid">
          {% for item in gallery %}
          {% if loop.index <= 5 %}
          <figure class="gallery-item{% if loop.index == 1 or loop.index == 5 %} big{% endif %} glass">
            <img src="{{ item.imageUrl | url }}" alt="{{ item.altAr or item.alt or 'المعرض' }}" loading="lazy">
            <span>{{ item.altAr or item.alt or '' }}</span>
          </figure>
          {% endif %}
          {% endfor %}
        </div>
        {% else %}
        <div class="gallery-grid">
          <figure class="gallery-item big glass"><img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=900&q=85" alt="تدريب"><span>تدريب</span></figure>
          <figure class="gallery-item glass"><img src="https://images.unsplash.com/photo-1494390248081-4e521a5940db?auto=format&fit=crop&w=900&q=85" alt="تغذية"><span>تغذية</span></figure>
          <figure class="gallery-item glass"><img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=900&q=85" alt="تقدم"><span>تقدم</span></figure>
          <figure class="gallery-item glass"><img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=900&q=85" alt="تعافي"><span>تعافي</span></figure>
          <figure class="gallery-item big glass"><img src="https://images.unsplash.com/photo-1605296867304-46d5465a13f1?auto=format&fit=crop&w=900&q=85" alt="تحول"><span>تحول</span></figure>
        </div>
        {% endif %}
      </div>
    </section>

    {# ── PLANS ── #}
    <section class="section" id="plans">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ hv2.plans.kicker }}</span>
          <h2>{{ hv2.plans.title }}</h2>
          <p>{{ hv2.plans.desc }}</p>
        </div>
        <div class="plans">
          {% for plan in hv2.plans.items %}
          <article class="glass plan{% if plan.highlight %} highlight{% endif %}" data-plan="{{ plan.key }}" data-price="{{ plan.price }}">
            <span class="kicker">{{ plan.kicker }}</span>
            <h3>{{ plan.name }}</h3>
            <div class="price"><span class="plan-price">${{ plan.price }}</span> <small>/ شهر</small></div>
            <div class="month-picker">
              <button type="button" class="active" data-months="1" data-discount="0">١ شهر</button>
              <button type="button" data-months="3" data-discount="10">٣ أشهر</button>
              <button type="button" data-months="6" data-discount="15">٦ أشهر</button>
              <button type="button" data-months="12" data-discount="20">١٢ شهر</button>
            </div>
            <span class="saving">الإجمالي: ${{ plan.price }}</span>
            <p>{{ plan.blurb }}</p>
            <ul class="features">
              {% for feat in plan.features %}
              <li>{{ feat }}</li>
              {% endfor %}
            </ul>
            <a class="btn{% if plan.highlight %} primary{% endif %}" href="{{ site.googleForm }}">اشترك الآن</a>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {# ── TESTIMONIALS ── #}
    <section class="section" id="stories">
      <div class="container">
        <div class="section-head">
          <span class="kicker">{{ hv2.stories.kicker }}</span>
          <h2>{{ hv2.stories.title }}</h2>
        </div>
        <div class="marquee">
          <div class="marquee-row row-a">
            {% set approved = [] %}
            {% for c in comments.items %}
              {% if c.status == "approved" %}
                {% set approved = (approved.push(c), approved) %}
              {% endif %}
            {% endfor %}
            {% set allCmts = approved if approved.length else comments.items %}
            {% for c in allCmts %}
            <article class="comment-card">
              <div class="quote">"</div>
              <p>{{ c.comment }}</p>
              <span class="avatar">{{ c.name[0] }}</span>
              <span class="comment-name" style="display:block;color:#fff;font-weight:900;font-size:14px;margin-top:6px">{{ c.name }}</span>
              <span class="comment-service" style="color:var(--lime);font-size:12px;font-weight:800">{{ c.service }}</span>
            </article>
            {% endfor %}
            {% for c in allCmts %}
            <article class="comment-card">
              <div class="quote">"</div>
              <p>{{ c.comment }}</p>
              <span class="avatar">{{ c.name[0] }}</span>
              <span class="comment-name" style="display:block;color:#fff;font-weight:900;font-size:14px;margin-top:6px">{{ c.name }}</span>
              <span class="comment-service" style="color:var(--lime);font-size:12px;font-weight:800">{{ c.service }}</span>
            </article>
            {% endfor %}
          </div>
          <div class="marquee-row row-b" style="transform:translateX(-50%)">
            {% for c in allCmts | reverse %}
            <article class="comment-card">
              <div class="quote">"</div>
              <p>{{ c.comment }}</p>
              <span class="avatar">{{ c.name[0] }}</span>
              <span class="comment-name" style="display:block;color:#fff;font-weight:900;font-size:14px;margin-top:6px">{{ c.name }}</span>
              <span class="comment-service" style="color:var(--lime);font-size:12px;font-weight:800">{{ c.service }}</span>
            </article>
            {% endfor %}
            {% for c in allCmts | reverse %}
            <article class="comment-card">
              <div class="quote">"</div>
              <p>{{ c.comment }}</p>
              <span class="avatar">{{ c.name[0] }}</span>
              <span class="comment-name" style="display:block;color:#fff;font-weight:900;font-size:14px;margin-top:6px">{{ c.name }}</span>
              <span class="comment-service" style="color:var(--lime);font-size:12px;font-weight:800">{{ c.service }}</span>
            </article>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {# ── CONTACT / FINAL ── #}
    <section class="section final" id="contact">
      <div class="container grid2">
        <article class="glass panel">
          <span class="kicker">{{ hv2.contact.kicker }}</span>
          <h2>{{ hv2.contact.title }}</h2>
          <p>{{ hv2.contact.desc }}</p>
          <div class="btns" style="justify-content:flex-start;margin-top:18px">
            <a class="btn primary" href="{{ site.googleForm }}">{{ hv2.contact.cta_primary }}</a>
            <a class="btn" href="{{ '/ar/contact/' | url }}">{{ hv2.contact.cta_secondary }}</a>
          </div>
        </article>
        <div class="faq">
          {% for item in hv2.faq %}
          <article class="glass">
            <h3>{{ item.q }}</h3>
            <p>{{ item.a }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

  </main>

  <footer class="v2-footer">
    <span>© {{ "" | year }} {{ site.name }}. جميع الحقوق محفوظة.</span>
    <nav class="v2-footer-links">
      <a href="{{ '/ar/privacy/' | url }}">الخصوصية</a>
      <a href="{{ '/ar/terms/' | url }}">الشروط</a>
      {% if site.social.instagram %}<a href="{{ site.social.instagram }}" target="_blank" rel="noopener">Instagram</a>{% endif %}
      {% if site.social.facebook %}<a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Facebook</a>{% endif %}
      <a href="/en/">English</a>
    </nav>
  </footer>

</div>

<script>
(function(){
  var root = document.getElementById('o2fV2Ar');
  var bg = document.getElementById('o2fBg');
  var tabs = [].slice.call(document.querySelectorAll('.tab-btn'));
  var panels = [].slice.call(document.querySelectorAll('.tab-panel'));
  var dockLinks = [].slice.call(document.querySelectorAll('.dock a[href^="#"]'));
  var sections = [].slice.call(document.querySelectorAll('.section[id]'));
  var social = document.getElementById('socialMenu');
  var socialToggle = document.getElementById('socialToggle');

  var rafPending = false;
  var cachedPageH = (root ? root.offsetHeight : document.body.offsetHeight) - window.innerHeight || 1;
  var cachedWinH = window.innerHeight;

  function updateParallax() {
    rafPending = false;
    if (!bg) return;
    var y = window.scrollY || 0;
    var p = Math.max(0, Math.min(1, window.scrollY / cachedPageH));
    bg.style.setProperty('--bg-y', (-p * 240) + 'px');
    bg.style.setProperty('--bg-s', (1.14 + p * 0.06).toFixed(3));
    var cur = sections[0];
    for (var i = 0; i < sections.length; i++) {
      var r = sections[i].getBoundingClientRect();
      if (r.top < cachedWinH * 0.45 && r.bottom > cachedWinH * 0.2) { cur = sections[i]; break; }
    }
    dockLinks.forEach(function(a) {
      a.classList.toggle('active', a.getAttribute('href') === '#' + cur.id);
    });
  }

  window.addEventListener('scroll', function() {
    if (!rafPending) { rafPending = true; requestAnimationFrame(updateParallax); }
  }, { passive: true });

  window.addEventListener('resize', function() {
    cachedPageH = (root ? root.offsetHeight : document.body.offsetHeight) - window.innerHeight || 1;
    cachedWinH = window.innerHeight;
    updateParallax();
  });

  tabs.forEach(function(b) {
    b.onclick = function() {
      var id = 'tab-' + b.dataset.tab;
      tabs.forEach(function(x) { x.classList.toggle('active', x === b); });
      panels.forEach(function(p) { p.classList.toggle('active', p.id === id); });
    };
  });

  dockLinks.forEach(function(a) {
    a.onclick = function(e) {
      var el = document.querySelector(a.getAttribute('href'));
      if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth' }); }
    };
  });

  if (socialToggle) {
    socialToggle.onclick = function(e) { e.stopPropagation(); social.classList.toggle('open'); };
  }
  document.addEventListener('click', function() { if (social) social.classList.remove('open'); });

  document.querySelectorAll('.plan').forEach(function(plan) {
    var base = Number(plan.dataset.price || 0);
    var priceEl = plan.querySelector('.plan-price');
    var savingEl = plan.querySelector('.saving');
    plan.querySelectorAll('.month-picker button').forEach(function(btn) {
      btn.onclick = function() {
        var months = Number(btn.dataset.months || 1);
        var discount = Number(btn.dataset.discount || 0);
        plan.querySelectorAll('.month-picker button').forEach(function(x) { x.classList.toggle('active', x === btn); });
        var total = Math.round(base * months * (1 - discount / 100));
        priceEl.textContent = '$' + base;
        savingEl.textContent = 'الإجمالي: $' + total + (discount ? ' — وفّر ' + discount + '%' : '');
      };
    });
  });

  updateParallax();
})();
</script>