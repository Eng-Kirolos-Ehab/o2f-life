<script>
(function(){
  var root=document.getElementById('o2fV2Ar');
  var bg=document.getElementById('o2fBgAr');
  var tabs=[].slice.call(document.querySelectorAll('.tab-btn'));
  var panels=[].slice.call(document.querySelectorAll('.tab-panel'));
  var dock=[].slice.call(document.querySelectorAll('.dock a'));
  var sections=[].slice.call(document.querySelectorAll('.section[id]'));
  var social=document.getElementById('socialMenuAr');
  var socialToggle=document.getElementById('socialToggleAr');

  function fx(){
    if(!root||!bg)return;
    var max=root.offsetHeight-window.innerHeight||1;
    var p=Math.max(0,Math.min(1,scrollY/max));
    bg.style.setProperty('--bg-y',(-p*240)+'px');
    bg.style.setProperty('--bg-s',(1.14+p*.06).toFixed(3));
    var cur=sections[0];
    sections.forEach(function(s){
      var r=s.getBoundingClientRect();
      if(r.top<innerHeight*.45&&r.bottom>innerHeight*.2)cur=s;
    });
    dock.forEach(function(a){
      a.classList.toggle('active',a.getAttribute('href')==='#'+cur.id);
    });
  }

  tabs.forEach(function(b){
    b.onclick=function(){
      var id='tab-'+b.dataset.tab;
      tabs.forEach(function(x){x.classList.toggle('active',x===b);});
      panels.forEach(function(p){p.classList.toggle('active',p.id===id);});
    };
  });

  dock.forEach(function(a){
    a.onclick=function(e){
      var href=a.getAttribute('href');
      if(href&&href.startsWith('#')){
        var el=document.querySelector(href);
        if(el){e.preventDefault();el.scrollIntoView({behavior:'smooth'});}
      }
    };
  });

  if(socialToggle){
    socialToggle.onclick=function(e){e.stopPropagation();social.classList.toggle('open');};
  }
  document.addEventListener('click',function(){if(social)social.classList.remove('open');});

  /* ── Plan price picker ── */
  var cards=[].slice.call(document.querySelectorAll('.plan'));
  var currency='USD', region='int';

  function regionFromCountry(c){
    if(c==='EG')return 'eg';
    if(['SA','AE','KW','QA','BH','OM'].indexOf(c)!==-1)return 'gulf';
    return 'int';
  }
  function currencyLabel(r){
    return r==='eg'?'EGP':r==='gulf'?'SAR':'USD';
  }
  function setRegion(r){
    region=r||'int';
    currency=currencyLabel(region);
    cards.forEach(function(plan){
      updatePlan(plan, plan.querySelector('.month-picker button.active')||plan.querySelector('.month-picker button'));
    });
  }
  function updatePlan(plan,btn){
    if(!plan||!btn)return;
    plan.querySelectorAll('.month-picker button').forEach(function(x){x.classList.toggle('active',x===btn);});
    var months=btn.dataset.months||'1';
    var camelKey=region+'M'+months;
    var raw=Number(plan.dataset[camelKey]||plan.dataset['intM'+months]||0);
    var monthly=Math.round(raw/Number(months));
    var price=plan.querySelector('.plan-price');
    var cur=plan.querySelector('.plan-currency');
    var saving=plan.querySelector('.saving');
    if(price)price.textContent=monthly.toLocaleString('ar-EG');
    if(cur)cur.textContent=currency+' / شهر';
    if(saving){
      var saveText=btn.dataset.save?' — وفّر '+btn.dataset.save:'';
      saving.textContent='الإجمالي: '+raw.toLocaleString('ar-EG')+' '+currency+saveText;
    }
  }
  document.querySelectorAll('.plan .month-picker button').forEach(function(btn){
    btn.onclick=function(){updatePlan(btn.closest('.plan'),btn);};
  });
  setRegion('int');
  try{
    fetch('https://ipapi.co/json/').then(function(r){return r.ok?r.json():null;}).then(function(d){
      if(d&&(d.country_code||d.country))setRegion(regionFromCountry(d.country_code||d.country));
    }).catch(function(){});
  }catch(e){}

  window.addEventListener('scroll',fx,{passive:true});
  window.addEventListener('resize',fx);
  fx();
})();
</script>
