---
title: "الخدمات"
description: "تدريب أونلاين، تغذية مخصّصة، إرشاد طب طبيعي، وباقة مكافحة الشيخوخة — كل ما يقدمه الكابتن أسامة."
---

<section class="grid-bg">
  <div class="container-x py-16 sm:py-20">
    <p class="section-kicker">{{ pages.services.ar.hero.kicker }}</p>
    <h1 class="section-title mb-4">{{ pages.services.ar.hero.title }}</h1>
    <p class="text-lg text-brand-off/70 max-w-2xl">{{ pages.services.ar.hero.description }}</p>
  </div>
</section>

<section class="section">
  <div class="container-x grid md:grid-cols-2 gap-6">
    {% for svc in pages.services.ar.services %}
    <div id="{{ svc.id }}" class="card">
      <h2 class="text-2xl mb-2">{{ svc.title }}</h2>
      <p class="text-brand-off/70">{{ svc.description }}</p>
      {% if svc.items %}
      <ul class="mt-4 space-y-1 text-sm text-brand-off/70">
        {% for item in svc.items %}
        <li>• {{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if svc.link_text %}
      <a href="{{ '/ar/anti-aging/' | url }}" class="inline-flex items-center gap-1 text-brand-mint text-sm mt-4">{{ svc.link_text }}</a>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="card text-center">
      <h2 class="text-2xl sm:text-3xl mb-3">{{ pages.services.ar.cta.title }}</h2>
      <p class="text-brand-off/70 max-w-xl mx-auto">{{ pages.services.ar.cta.description }}</p>
      <a href="{{ '/ar/contact/' | url }}" class="btn-primary mt-6">{{ pages.services.ar.cta.button }}</a>
    </div>
  </div>
</section>
