---
title: "تواصل"
description: "تواصل مع الكابتن أسامة عمران. املأ فورم التسجيل، ابعت على واتساب، أو راسلنا إيميل."
---

<section class="grid-bg">
  <div class="container-x py-16 sm:py-20">
    <p class="section-kicker">{{ pages.contact.ar.hero.kicker }}</p>
    <h1 class="section-title mb-4">{{ pages.contact.ar.hero.title }}</h1>
    <p class="text-lg text-brand-off/70 max-w-2xl">{{ pages.contact.ar.hero.description }}</p>
  </div>
</section>

<section class="section">
  <div class="container-x grid lg:grid-cols-3 gap-5">

    {# PRIMARY — Google Form #}
    <a href="{{ site.googleForm }}" target="_blank" rel="noopener"
       class="card lg:col-span-2 flex flex-col justify-between ring-1 ring-brand-mint/40 hover:border-brand-mint transition-colors">
      <div>
        <span class="chip text-brand-mint mb-3">{{ pages.contact.ar.cards.form.badge }}</span>
        <h2 class="text-2xl sm:text-3xl mb-2">{{ pages.contact.ar.cards.form.title }}</h2>
        <p class="text-brand-off/70">{{ pages.contact.ar.cards.form.description }}</p>
      </div>
      <div class="mt-6 inline-flex items-center gap-2 text-brand-mint font-semibold">
        {{ pages.contact.ar.cards.form.cta }}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
      </div>
    </a>

    {# WhatsApp #}
    <a href="https://wa.me/{{ site.whatsapp | replace('+','') }}" target="_blank" rel="noopener"
       class="card flex flex-col hover:border-brand-mint transition-colors">
      <div class="h-10 w-10 rounded-lg bg-[#25D366]/15 text-[#25D366] flex items-center justify-center mb-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.52 3.48A11.77 11.77 0 0012.06 0C5.5 0 .17 5.34.17 11.9c0 2.1.55 4.14 1.6 5.95L0 24l6.32-1.66a11.88 11.88 0 005.74 1.47h.01c6.56 0 11.9-5.34 11.9-11.9a11.82 11.82 0 00-3.45-8.43z"/></svg>
      </div>
      <h3 class="text-xl mb-1">{{ pages.contact.ar.cards.whatsapp.title }}</h3>
      <p class="text-brand-off/70 text-sm">{{ pages.contact.ar.cards.whatsapp.description }}</p>
      <span class="text-brand-mint text-sm mt-3" dir="ltr">{{ site.whatsapp }}</span>
    </a>

    {# Email #}
    <a href="mailto:{{ site.email }}"
       class="card flex flex-col hover:border-brand-mint transition-colors">
      <div class="h-10 w-10 rounded-lg bg-brand-mint/15 text-brand-mint flex items-center justify-center mb-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M4 4l8 8 8-8"/></svg>
      </div>
      <h3 class="text-xl mb-1">{{ pages.contact.ar.cards.email.title }}</h3>
      <p class="text-brand-off/70 text-sm">{{ pages.contact.ar.cards.email.description }}</p>
      <span class="text-brand-mint text-sm mt-3" dir="ltr">{{ site.email }}</span>
    </a>

    {% if site.social.instagram %}
    <a href="{{ site.social.instagram }}" target="_blank" rel="noopener"
       class="card flex flex-col hover:border-brand-mint transition-colors">
      <div class="h-10 w-10 rounded-lg bg-brand-mint/15 text-brand-mint flex items-center justify-center mb-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
      </div>
      <h3 class="text-xl mb-1">{{ pages.contact.ar.cards.instagram.title }}</h3>
      <p class="text-brand-off/70 text-sm">{{ pages.contact.ar.cards.instagram.description }}</p>
      <span class="text-brand-mint text-sm mt-3" dir="ltr">{{ pages.contact.ar.cards.instagram.handle }}</span>
    </a>
    {% endif %}
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="card text-center">
      <h3 class="text-xl mb-2">{{ pages.contact.ar.process.title }}</h3>
      <p class="text-brand-off/70 max-w-xl mx-auto">{{ pages.contact.ar.process.description }}</p>
    </div>
  </div>
</section>
