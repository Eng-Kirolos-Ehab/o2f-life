---
title: "O2F Home (Classic)"
description: "Previous English homepage kept as a hidden archive."
permalink: /en/home-old/index.html
---

<style>
  body:has(.en-home-old)>header,.en-home-old~footer{display:none!important}
  .en-home-old{min-height:100vh;background:#06110d;color:#fff;font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;position:relative;overflow:hidden}
  .en-home-old:before{content:"";position:absolute;inset:-20%;background:radial-gradient(circle at 20% 20%,rgba(168,255,120,.25),transparent 28%),radial-gradient(circle at 80% 70%,rgba(0,217,163,.18),transparent 32%),linear-gradient(135deg,#06110d,#0b2016 60%,#020705);z-index:0}
  .en-wrap{position:relative;z-index:1;width:min(1120px,100%);margin:0 auto;padding:clamp(18px,4vh,36px) clamp(18px,5vw,72px) 100px}
  .en-topnav{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;padding:18px 0 20px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:clamp(40px,8vh,80px)}
  .en-brand{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-weight:950;font-size:16px}
  .en-brand img{width:40px;height:40px;border-radius:50%;object-fit:cover}
  .en-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .en-links a{color:rgba(255,255,255,.8);text-decoration:none;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);border-radius:999px;padding:9px 14px;font-size:12px;font-weight:800;backdrop-filter:blur(14px);transition:all .18s}
  .en-links a:hover{border-color:rgba(168,255,120,.5);color:#a8ff78;background:rgba(168,255,120,.1)}
  .en-links a.lang{border-color:rgba(0,217,163,.35);color:#00d9a3}
  .en-grid{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);gap:clamp(24px,5vw,70px);align-items:center}
  .en-kicker{display:inline-block;color:#a8ff78;font-size:12px;font-weight:950;letter-spacing:.18em;text-transform:uppercase;margin-bottom:16px}
  .en-home-old h1{font-size:clamp(44px,7vw,90px);line-height:.9;letter-spacing:-.07em;margin:0 0 18px;color:#fff}
  .en-home-old p{color:rgba(247,255,247,.78);line-height:1.75;font-size:clamp(16px,1.3vw,19px)}
  .en-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:26px}
  .en-btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.26);background:rgba(255,255,255,.1);border-radius:999px;padding:13px 22px;font-size:14px;font-weight:850;backdrop-filter:blur(14px);color:#fff;text-decoration:none;transition:all .18s}
  .en-btn:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.45)}
  .en-btn.primary{background:linear-gradient(135deg,rgba(168,255,120,.28),rgba(0,217,163,.16));border-color:rgba(168,255,120,.45)}
  .en-card{border:1px solid rgba(255,255,255,.22);background:linear-gradient(145deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(22px);border-radius:34px;padding:26px;box-shadow:0 26px 90px rgba(0,0,0,.26)}
  .en-card h2{margin:0 0 12px;font-size:28px;color:#fff}
  .en-list{display:grid;gap:12px;margin-top:18px}
  .en-list div{padding:14px;border-radius:18px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12)}
  .en-list b{display:block;margin-bottom:4px;color:#fff}
  .en-list span{color:rgba(247,255,247,.72);font-size:14px}
  .en-footer{border-top:1px solid rgba(255,255,255,.1);margin-top:60px;padding-top:28px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:13px;color:rgba(255,255,255,.45)}
  .en-footer a{color:rgba(255,255,255,.45);text-decoration:none}
  .en-footer a:hover{color:#a8ff78}
  .en-badge{display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(0,217,163,.25);background:rgba(0,217,163,.07);color:rgba(0,217,163,.8);border-radius:999px;padding:5px 10px;font-size:11px;font-weight:700}
  @media(max-width:860px){.en-grid{grid-template-columns:1fr}.en-topnav{flex-direction:column;align-items:flex-start}}
</style>

<div class="en-home-old">
  <div class="en-wrap">

    <nav class="en-topnav">
      <a class="en-brand" href="{{ '/en/' | url }}">
        {% if site.logoUrl %}
          <img src="{{ site.logoUrl | url }}" alt="{{ site.name }}">
        {% endif %}
        <span>{{ site.name }}</span>
        <span class="en-badge">Classic</span>
      </a>
      <div class="en-links">
        <a href="{{ '/en/' | url }}">Home</a>
        <a href="{{ '/en/about/' | url }}">About</a>
        <a href="{{ '/en/services/' | url }}">Services</a>
        <a href="{{ '/en/plans/' | url }}">Plans</a>
        <a href="{{ '/en/gallery/' | url }}">Gallery</a>
        <a href="{{ '/en/blog/' | url }}">Blog</a>
        <a href="{{ '/en/methylene-blue/' | url }}">Methylene Blue</a>
        <a href="{{ '/en/anti-aging/' | url }}">Anti-Aging</a>
        <a href="{{ '/en/contact/' | url }}">Contact</a>
        <a href="{{ '/ar/home-old/' | url }}" class="lang">ع</a>
      </div>
    </nav>

    <main class="en-grid">
      <section>
        <span class="en-kicker">{{ pages.home.en.hero.badge }}</span>
        <h1>{{ pages.home.en.hero.title_line1 }} <br>{{ pages.home.en.hero.title_line2_gradient }}</h1>
        <p>{{ pages.home.en.hero.description }}</p>
        <div class="en-actions">
          <a class="en-btn primary" href="{{ site.googleForm }}">{{ pages.home.en.hero.cta_primary }}</a>
          <a class="en-btn" href="{{ '/en/services/' | url }}">Explore Services</a>
        </div>
      </section>

      <aside class="en-card">
        <span class="en-kicker">O2F Life</span>
        <h2>{{ pages.home.en.pillars.title }}</h2>
        <p>{{ pages.home.en.seo.description }}</p>
        <div class="en-list">
          {% for item in pages.home.en.pillars.items %}
          <div>
            <b>{{ item.title }}</b>
            <span>{{ item.text }}</span>
          </div>
          {% endfor %}
        </div>
        <div class="en-actions" style="margin-top:20px">
          <a class="en-btn primary" href="{{ '/en/plans/' | url }}">View Plans</a>
          <a class="en-btn" href="{{ '/en/contact/' | url }}">Contact Us</a>
        </div>
      </aside>
    </main>

    <footer class="en-footer">
      <span>© {{ "" | year }} {{ site.name }} — All rights reserved.</span>
      <span>
        <a href="{{ '/en/privacy/' | url }}">Privacy</a>
        <span style="margin:0 8px">·</span>
        <a href="{{ '/en/terms/' | url }}">Terms</a>
        <span style="margin:0 8px">·</span>
        <a href="{{ site.social.instagram }}" target="_blank" rel="noopener">Instagram</a>
        {% if site.social.facebook %}
        <span style="margin:0 8px">·</span>
        <a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Facebook</a>
        {% endif %}
      </span>
    </footer>

  </div>
</div>
