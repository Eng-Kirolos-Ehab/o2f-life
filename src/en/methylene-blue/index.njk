---
title: "Methylene Blue"
description: "Methylene Blue supplement — boost mental focus, cellular energy and long-term vitality. Trusted in science, medicine and wellness."
---

<section class="grid-bg relative overflow-hidden min-h-[80vh] flex items-center">
  <div class="absolute top-10 -right-32 w-[500px] h-[500px] rounded-full bg-brand-mint/10 blur-3xl animate-pulse-soft pointer-events-none"></div>
  <div class="absolute bottom-0 -left-32 w-96 h-96 rounded-full bg-brand-gold/10 blur-3xl animate-pulse-soft pointer-events-none" style="animation-delay:1.5s"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full border border-brand-mint/5 animate-spin-slow pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full border border-brand-gold/5 animate-spin-slow pointer-events-none" style="animation-direction:reverse;animation-duration:15s"></div>

  <div class="container-x py-20 sm:py-28 relative w-full">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 chip animate-border-glow mb-6" data-aos="fade-up">
        <span class="w-2 h-2 rounded-full bg-brand-mint animate-pulse"></span>
        {{ pages.methyleneblue.en.hero.badge }}
      </div>
      <h1 class="section-title text-balance mb-6 leading-tight" data-aos="fade-up" data-aos-delay="100">
        {{ pages.methyleneblue.en.hero.title_line1 }}<br><span class="gradient-mint-text animate-gradient">{{ pages.methyleneblue.en.hero.title_line2_gradient }}</span>
      </h1>
      <p class="text-xl text-brand-off/75 max-w-2xl leading-relaxed" data-aos="fade-up" data-aos-delay="200">{{ pages.methyleneblue.en.hero.description | safe }}</p>
      <div class="flex flex-wrap gap-3 mt-10" data-aos="fade-up" data-aos-delay="300">
        <a href="{{ '/en/contact/?service=methylene-blue' | url }}" class="btn-primary text-base px-8 py-4">{{ pages.methyleneblue.en.hero.cta_primary }}</a>
        <a href="#how-it-works" class="btn-ghost text-base px-8 py-4">{{ pages.methyleneblue.en.hero.cta_secondary }}</a>
      </div>
      <div class="flex flex-wrap gap-4 mt-8" data-aos="fade-up" data-aos-delay="400">
        {% for t in pages.methyleneblue.en.hero.trust_items %}
        <div class="flex items-center gap-2 text-sm text-brand-off/60"><span class="text-brand-mint">✓</span> {{ t }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section id="how-it-works" class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.methyleneblue.en.how_it_works.kicker }}</p>
    <h2 class="section-title mb-6" data-aos="fade-up" data-aos-delay="100">{{ pages.methyleneblue.en.how_it_works.title }}</h2>
    <p class="text-brand-off/70 max-w-2xl mb-10" data-aos="fade-up" data-aos-delay="200">{{ pages.methyleneblue.en.how_it_works.description | safe }}</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {% for item in pages.methyleneblue.en.how_it_works.items %}
      <div class="card card-hover card-glow" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="text-3xl mb-2">{{ item.emoji }}</div>
        <h3 class="text-lg mb-1 text-brand-mint">{{ item.title }}</h3>
        <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section bg-white/[0.02]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.methyleneblue.en.science.kicker }}</p>
    <h2 class="section-title mb-6" data-aos="fade-up" data-aos-delay="100">{{ pages.methyleneblue.en.science.title }}</h2>
    <p class="text-brand-off/70 max-w-2xl mb-10" data-aos="fade-up" data-aos-delay="200">{{ pages.methyleneblue.en.science.description }}</p>
    <div class="grid md:grid-cols-3 gap-5">
      {% for item in pages.methyleneblue.en.science.items %}
      <div class="card card-hover" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="text-3xl mb-2">{{ item.emoji }}</div>
        <h3 class="text-lg mb-1 text-brand-mint">{{ item.title }}</h3>
        <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <p class="section-kicker text-center" data-aos="fade-up">{{ pages.methyleneblue.en.stats.kicker }}</p>
    <h2 class="section-title text-center mb-10" data-aos="fade-up" data-aos-delay="100">{{ pages.methyleneblue.en.stats.title }}</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
      {% for item in pages.methyleneblue.en.stats.items %}
      <div class="stat-card" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="stat-number">{{ item.value }}</div>
        <div class="divider-mint"></div>
        <div class="text-xs text-brand-off/70 uppercase tracking-wider">{{ item.label }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section bg-white/[0.02]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.methyleneblue.en.use_cases.kicker }}</p>
    <h2 class="section-title mb-6" data-aos="fade-up" data-aos-delay="100">{{ pages.methyleneblue.en.use_cases.title }}</h2>
    <p class="text-brand-off/70 max-w-2xl mb-10" data-aos="fade-up" data-aos-delay="200">{{ pages.methyleneblue.en.use_cases.description }}</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {% for item in pages.methyleneblue.en.use_cases.items %}
      <div class="card card-hover" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="text-3xl mb-2">{{ item.emoji }}</div>
        <h3 class="text-lg mb-1 text-brand-mint">{{ item.title }}</h3>
        <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.methyleneblue.en.testimonials.kicker }}</p>
    <h2 class="section-title mb-6" data-aos="fade-up" data-aos-delay="100">{{ pages.methyleneblue.en.testimonials.title }}</h2>
    <div class="grid md:grid-cols-3 gap-5">
      {% for t in pages.methyleneblue.en.testimonials.items %}
      <div class="card card-hover border-l-4 border-l-brand-mint" data-aos="{% if loop.index == 1 %}fade-right{% elif loop.index == 2 %}fade-up{% else %}fade-left{% endif %}" data-aos-delay="{{ loop.index * 100 }}">
        <p class="text-brand-mint mb-3">⭐⭐⭐⭐⭐</p>
        <p class="text-brand-off/85 text-sm italic mb-4">"{{ t.quote }}"</p>
        <p class="text-brand-off/80 text-sm font-semibold">{{ t.name }}</p>
        <p class="text-brand-off/60 text-xs">{{ t.role }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="relative rounded-xl2 overflow-hidden bg-gradient-to-br from-brand-mint/20 via-brand-mint/10 to-brand-ink p-8 sm:p-12 border border-brand-mint/30" data-aos="zoom-in">
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-brand-mint/20 blur-3xl animate-pulse-soft"></div>
      <div class="relative text-center max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl mb-3">{{ pages.methyleneblue.en.cta.title }}</h2>
        <p class="text-brand-off/80 mb-6">{{ pages.methyleneblue.en.cta.description | safe }}</p>
        <div class="flex flex-wrap gap-2 justify-center mb-6">
          {% for chip in pages.methyleneblue.en.cta.chips %}
          <span class="chip">{{ chip }}</span>
          {% endfor %}
        </div>
        <a href="{{ '/en/contact/?service=methylene-blue' | url }}" class="btn-primary">{{ pages.methyleneblue.en.cta.button }}</a>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x max-w-3xl">
    <div class="card relative pt-12" data-aos="fade-up">
      <div class="absolute -top-6 left-6 text-6xl text-brand-mint opacity-30 font-serif leading-none">"</div>
      <p class="text-lg text-brand-off/85 italic leading-relaxed">{{ pages.methyleneblue.en.founder_quote.text }}</p>
      <div class="flex items-center gap-3 mt-6 pt-6 border-t border-brand-line">
        <img src="{{ '/assets/images/founder.jpg' | url }}" alt="{{ pages.methyleneblue.en.founder_quote.name }}"
             class="w-12 h-12 rounded-full object-cover border-2 border-brand-mint/40"
             onerror="this.style.display='none'">
        <div>
          <p class="font-semibold">{{ pages.methyleneblue.en.founder_quote.name }}</p>
          <p class="text-brand-off/60 text-xs">{{ pages.methyleneblue.en.founder_quote.role }}</p>
        </div>
      </div>
    </div>
  </div>
</section>
