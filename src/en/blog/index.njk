---
title: "Blog"
description: "Articles on training, nutrition, naturopathic medicine, and long-term health — from Coach Osama Omran."
layout: layouts/base.njk
tags: []
permalink: "/en/blog/"
---

<section class="grid-bg">
  <div class="container-x py-16 sm:py-20">
    <p class="section-kicker">Blog</p>
    <h1 class="section-title mb-4">Notes, science and practical guides.</h1>
    <p class="text-lg text-brand-off/70 max-w-2xl">
      Articles on training, nutrition, naturopathic medicine, and long-term health.
    </p>
  </div>
</section>

<section class="section">
  <div class="container-x grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {% set posts = collections.blog_en | reverse %}
    {% if posts.length == 0 %}
      <p class="text-brand-off/60">No posts yet — the first one is on the way!</p>
    {% endif %}
    {% for post in posts %}
      <a href="{{ post.url }}" class="card hover:border-brand-mint transition-colors flex flex-col">
        {% if post.data.cover %}
          <img src="{{ post.data.cover }}" alt="" class="rounded-xl mb-4 h-40 object-cover">
        {% endif %}
        <p class="text-xs text-brand-off/60 mb-1">{{ post.date.toLocaleDateString("en-US") }}</p>
        <h3 class="text-xl mb-2">{{ post.data.title }}</h3>
        <p class="text-brand-off/70 text-sm flex-1">{{ post.data.description }}</p>
        <span class="inline-flex items-center gap-1 text-brand-mint text-sm mt-4">Read →</span>
      </a>
    {% endfor %}
  </div>
</section>
