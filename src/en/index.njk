  </div>
</section>

{# ==================== PLANS PREVIEW ==================== #}
<section class="section">
  <div class="container-x">
    <p class="section-kicker">Pick your path</p>
    <h2 class="section-title mb-10">Plans that match your ambition.</h2>
    <div class="grid md:grid-cols-3 gap-5">
      {% for key in ["basic","standard","advanced"] %}
        {% set p = plans[key] %}
        <a href="{{ ('/en/plans/' + p.slug + '/') | url }}" class="card hover:border-brand-mint transition-colors {% if p.highlight %}ring-1 ring-brand-mint/40{% endif %}">
          {% if p.highlight %}<span class="chip text-brand-mint mb-3">Most popular</span>{% endif %}
          <h3 class="text-xl mb-1">{{ p.en.name }}</h3>
          <p class="text-brand-mint text-sm mb-3">{{ p.en.tagline }}</p>
          <p class="text-brand-off/70 text-sm">{{ p.en.blurb }}</p>
          <span class="inline-flex items-center gap-1 text-brand-mint text-sm mt-4">Learn more →</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

