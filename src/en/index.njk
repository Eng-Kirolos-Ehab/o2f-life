{# ==================== PLANS PREVIEW ==================== #}
<section class="section bg-white/[0.015]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">Pick your path</p>
    <h2 class="section-title mb-2" data-aos="fade-up" data-aos-delay="80">Plans that match your ambition.</h2>
    <div class="line-accent w-16 mb-10" data-aos="fade-up" data-aos-delay="120"></div>

    <div class="grid md:grid-cols-3 gap-5">
      {% for key in ["basic","standard","advanced"] %}
        {% set p = plans[key] %}
        <a href="{{ ('/en/plans/' + p.slug + '/') | url }}"
           class="card card-hover card-glow hover:border-brand-mint/60 {% if p.highlight %}ring-1 ring-brand-mint/35{% endif %}"
           data-aos="fade-up" data-aos-delay="{{ loop.index * 120 }}">
          {% if p.highlight %}
            <span class="chip text-brand-mint mb-3 block w-fit animate-pulse-soft">Most popular</span>
          {% endif %}
          <h3 class="text-xl mb-1">{{ p.en.name }}</h3>
          <p class="text-brand-mint text-sm mb-3">{{ p.en.tagline }}</p>
          <p class="text-brand-off/65 text-sm leading-relaxed">{{ p.en.blurb }}</p>
          <span class="inline-flex items-center gap-1.5 text-brand-mint text-sm mt-5 group">
            Learn more
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ==================== CTA ==================== #}
