{# ==================== HERO ==================== #}
<section class="grid-bg relative overflow-hidden">
  <div class="container-x py-20 sm:py-28 lg:py-32 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="section-kicker">Coach Osama Omran</p>
        <h1 class="section-title text-balance">
          Transform your body, <span class="gradient-mint-text">from the inside out.</span>
