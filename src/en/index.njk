---
title: "O2F Home V2"
description: "Clean cinematic home v2 rebuild."
permalink: /en/home-v2/index.html
---

<style>
/*
  HOME V2 CLEAN REBUILD
  Main idea:
  - No confusing global background switching.
  - Each section has its own cinematic background layer.
  - Each section has a clear content side + visual stage side.
  - Gym objects are visible, sized properly, and animated inside their own stage.
  - Cards are readable and organized.
*/

.home-v2-clean {
  --lime: #a8ff78;
  --mint: #00d9a3;
  --dark: #06110d;
  --text: #f7fff7;
  --muted: rgba(247, 255, 247, 0.78);
  --glass: rgba(255, 255, 255, 0.14);
  --stroke: rgba(255, 255, 255, 0.22);

  background: var(--dark);
  color: var(--text);
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  overflow: hidden;
  position: relative;
}

.home-v2-clean * {
  box-sizing: border-box;
}

/* =========================
   Global Navigation
========================= */

.hv2-nav {
  position: fixed;
  z-index: 100;
  left: clamp(18px, 4vw, 72px);
  right: clamp(18px, 4vw, 72px);
  top: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
}

.hv2-brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: #fff;
  text-decoration: none;
  font-weight: 950;
  letter-spacing: -0.02em;
}

.hv2-brand img {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 0 26px rgba(0, 217, 163, 0.28);
}

.hv2-links {
  display: flex;
  align-items: center;
  gap: 18px;
}

.hv2-links a {
  color: rgba(255, 255, 255, 0.86);
  text-decoration: none;
  font-size: 13px;
  font-weight: 850;
}

.hv2-links a:last-child,
.hv2-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  text-decoration: none;
  font-weight: 950;
  font-size: 14px;
  padding: 12px 18px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.65);
  background: rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(14px);
  box-shadow: 0 14px 38px rgba(0, 0, 0, 0.2);
}

/* =========================
   Section Base
========================= */

.hv2-section {
  position: relative;
  min-height: 100vh;
  display: grid;
  align-items: center;
  padding: clamp(100px, 13vh, 150px) clamp(18px, 5vw, 78px);
  isolation: isolate;
  overflow: hidden;
}

.hv2-section::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -3;
  background:
    radial-gradient(circle at 20% 18%, var(--bg-b, #245d35), transparent 30%),
    radial-gradient(circle at 82% 74%, var(--bg-c, #0f3420), transparent 38%),
    linear-gradient(135deg, var(--bg-a, #06160d), #03100a 75%);
}

.hv2-section::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -2;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.76), rgba(0, 0, 0, 0.28) 48%, rgba(0, 0, 0, 0.64)),
    radial-gradient(circle at 55% 38%, rgba(255, 255, 255, 0.14), transparent 26%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.03), rgba(6, 17, 13, 0.54));
}

.hv2-bg-hero {
  --bg-a: #06180f;
  --bg-b: #277747;
  --bg-c: #0f3a24;
}

.hv2-bg-nature {
  --bg-a: #07160d;
  --bg-b: #2a6f41;
  --bg-c: #103923;
}

.hv2-bg-gym {
  --bg-a: #07090b;
  --bg-b: #464b50;
  --bg-c: #162118;
}

.hv2-bg-active {
  --bg-a: #061625;
  --bg-b: #1f607c;
  --bg-c: #0b3328;
}

.hv2-bg-antiage {
  --bg-a: #10160f;
  --bg-b: #6b4728;
  --bg-c: #285c37;
}

.hv2-bg-methylene {
  --bg-a: #061527;
  --bg-b: #005f8f;
  --bg-c: #003f64;
}

.hv2-layout {
  width: min(1220px, 100%);
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(310px, 0.92fr) minmax(360px, 1.08fr);
  align-items: center;
  gap: clamp(28px, 5vw, 74px);
}

.hv2-layout.reverse {
  grid-template-columns: minmax(360px, 1.08fr) minmax(310px, 0.92fr);
}

.hv2-layout.reverse .hv2-copy {
  order: 2;
}

.hv2-layout.reverse .hv2-stage {
  order: 1;
}

/* =========================
   Typography
========================= */

.hv2-kicker {
  display: inline-block;
  color: var(--lime);
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 14px;
}

.home-v2-clean h1 {
  font-size: clamp(56px, 9vw, 138px);
  line-height: 0.82;
  letter-spacing: -0.09em;
  max-width: 1180px;
  margin: 16px auto;
  text-shadow: 0 24px 76px rgba(0, 0, 0, 0.42);
}

.home-v2-clean h2 {
  font-size: clamp(34px, 5vw, 76px);
  line-height: 0.92;
  letter-spacing: -0.07em;
  margin: 0 0 18px;
}

.home-v2-clean h3 {
  font-size: 22px;
  margin: 8px 0 8px;
}

.home-v2-clean p,
.home-v2-clean li {
  color: var(--muted);
  line-height: 1.72;
}

.hv2-hero {
  text-align: center;
}

.hv2-hero p {
  max-width: 780px;
  margin: 0 auto 26px;
  font-size: clamp(16px, 1.3vw, 19px);
}

/* =========================
   Glass Elements
========================= */

.hv2-glass {
  position: relative;
  border: 1px solid rgba(255, 255, 255, 0.28);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.08));
  backdrop-filter: blur(24px);
  box-shadow:
    0 30px 90px rgba(0, 0, 0, 0.27),
    inset 0 1px 0 rgba(255, 255, 255, 0.20);
  border-radius: 34px;
  overflow: hidden;
}

.hv2-glass::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), transparent 32%, transparent 72%, rgba(255, 255, 255, 0.04));
}

.hv2-card,
.hv2-panel,
.hv2-plan,
.hv2-bubble,
.hv2-step,
.hv2-readout {
  padding: 24px;
}

.hv2-card,
.hv2-plan,
.hv2-bubble,
.hv2-step,
.hv2-readout {
  transition: transform 0.28s ease, border-color 0.28s ease, background 0.28s ease, box-shadow 0.28s ease;
}

.hv2-card:hover,
.hv2-plan:hover,
.hv2-bubble:hover,
.hv2-step:hover,
.hv2-readout:hover {
  transform: translateY(-8px);
  border-color: rgba(255, 255, 255, 0.48);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.12));
  box-shadow:
    0 38px 100px rgba(0, 0, 0, 0.30),
    inset 0 1px 0 rgba(255, 255, 255, 0.24);
}

/* =========================
   Visual Stage
========================= */

.hv2-stage {
  position: relative;
  min-height: 560px;
  display: grid;
  place-items: center;
}

.hv2-stage-frame {
  position: relative;
  width: min(520px, 100%);
  min-height: 520px;
  border-radius: 44px;
  border: 1px solid rgba(255, 255, 255, 0.20);
  background:
    radial-gradient(circle at 50% 42%, rgba(168, 255, 120, 0.18), transparent 28%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.06));
  backdrop-filter: blur(18px);
  box-shadow: 0 32px 100px rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.hv2-stage-frame::before,
.hv2-stage-frame::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hv2-stage-frame::before {
  width: 78%;
  height: 78%;
  left: 11%;
  top: 11%;
  border: 1px solid rgba(255, 255, 255, 0.20);
  animation: hv2Spin 28s linear infinite;
}

.hv2-stage-frame::after {
  width: 52%;
  height: 52%;
  left: 24%;
  top: 24%;
  border: 1px solid rgba(168, 255, 120, 0.25);
  animation: hv2Spin 18s linear infinite reverse;
}

@keyframes hv2Spin {
  to { transform: rotate(360deg); }
}

.hv2-object {
  position: absolute;
  left: var(--object-left, 50%);
  top: var(--object-top, 50%);
  transform: translate(-50%, -50%) rotate(var(--object-rotate, -8deg)) scale(var(--object-scale, 1));
  filter: drop-shadow(0 36px 36px rgba(0,0,0,.38));
  animation: hv2Float 5.8s ease-in-out infinite;
  z-index: 4;
}

@keyframes hv2Float {
  0%, 100% {
    transform: translate(-50%, -50%) rotate(var(--object-rotate, -8deg)) scale(var(--object-scale, 1));
  }
  50% {
    transform: translate(calc(-50% + 12px), calc(-50% - 24px)) rotate(calc(var(--object-rotate, -8deg) + 4deg)) scale(calc(var(--object-scale, 1) * 1.03));
  }
}

.hv2-object-glow {
  position: absolute;
  left: var(--object-left, 50%);
  top: var(--object-top, 50%);
  width: 270px;
  height: 270px;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.24), rgba(168, 255, 120, 0.14) 38%, transparent 70%);
  filter: blur(8px);
  z-index: 2;
}

/* Object drawings */
.hv2-bottle {
  width: 120px;
  height: 330px;
  border-radius: 56px 56px 62px 62px;
  background: linear-gradient(90deg, #276d33, #75d35e 38%, #d9ffd0 50%, #58bd4e 60%, #1d6a34);
  box-shadow:
    inset 18px 0 34px rgba(255,255,255,.2),
    inset -20px 0 34px rgba(0,0,0,.24);
}

.hv2-bottle::before {
  content: "";
  position: absolute;
  left: 31px;
  right: 31px;
  top: -42px;
  height: 48px;
  border-radius: 16px 16px 10px 10px;
  background: linear-gradient(90deg, #101816, #2f3530, #111);
}

.hv2-bottle::after {
  content: "";
  position: absolute;
  left: 28px;
  right: 28px;
  top: -62px;
  height: 60px;
  border: 12px solid #111816;
  border-bottom: 0;
  border-radius: 40px 40px 0 0;
}

.hv2-dumbbell {
  width: 380px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  --object-rotate: 12deg;
}

.hv2-dumbbell span {
  width: 94px;
  height: 162px;
  border-radius: 28px;
  background: linear-gradient(180deg, #f2fff0, #74d46b 55%, #1d6d34);
  box-shadow: inset 0 0 18px rgba(255,255,255,.34);
}

.hv2-dumbbell i {
  position: absolute;
  left: 86px;
  right: 86px;
  top: 46px;
  height: 28px;
  border-radius: 999px;
  background: linear-gradient(90deg, #14221a, #eaffdf 46%, #15351e);
}

.hv2-kettle {
  width: 230px;
  height: 230px;
  border-radius: 50% 50% 44% 44%;
  background: linear-gradient(135deg, #eaffdf, #78d86c 42%, #1b7337);
  --object-rotate: -10deg;
}

.hv2-kettle::before {
  content: "";
  position: absolute;
  left: 54px;
  right: 54px;
  top: -56px;
  height: 90px;
  border: 25px solid #1b211d;
  border-bottom: 0;
  border-radius: 62px 62px 0 0;
}

.hv2-rope {
  width: 315px;
  height: 315px;
  border: 16px solid #78d86c;
  border-radius: 50%;
  --object-rotate: 18deg;
  background: radial-gradient(circle, transparent 55%, rgba(255,255,255,.14) 57%, transparent 63%);
}

.hv2-rope::before,
.hv2-rope::after {
  content: "";
  position: absolute;
  width: 28px;
  height: 106px;
  border-radius: 999px;
  background: #161d19;
  bottom: -52px;
}

.hv2-rope::before {
  left: 52px;
  transform: rotate(20deg);
}

.hv2-rope::after {
  right: 52px;
  transform: rotate(-20deg);
}

/* =========================
   Section-specific layouts
========================= */

.photo {
  position: relative;
  min-height: 620px;
}

.photo img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent, rgba(0,0,0,.58));
}

.stats {
  position: absolute;
  z-index: 2;
  left: 18px;
  right: 18px;
  bottom: 18px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.stats span {
  background: rgba(255,255,255,.16);
  border-radius: 18px;
  padding: 12px;
  text-align: center;
  backdrop-filter: blur(12px);
  font-weight: 950;
  border: 1px solid rgba(255,255,255,.18);
}

.service-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.readouts {
  display: grid;
  gap: 12px;
}

.journey {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.step span {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: rgba(168,255,120,.24);
  font-weight: 950;
  margin-bottom: 10px;
}

.gallery {
  display: grid;
  grid-template-columns: 1.15fr .85fr .85fr;
  gap: 14px;
}

.gallery .hv2-card:first-child {
  grid-row: span 2;
}

.gallery .hv2-card:nth-child(4) {
  grid-column: span 2;
}

.terrain {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}

.hv2-plan {
  color: #fff;
  text-decoration: none;
}

.hv2-plan:nth-child(2) {
  background: linear-gradient(145deg, rgba(168,255,120,.25), rgba(255,255,255,.11));
}

.price div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  border-radius: 14px;
  background: rgba(255,255,255,.12);
  padding: 10px;
  margin: 8px 0;
  border: 1px solid rgba(255,255,255,.08);
}

.features {
  padding: 0;
  list-style: none;
  margin: 12px 0 0;
}

.features li {
  padding-left: 14px;
  position: relative;
  margin: 8px 0;
}

.features li::before {
  content: "";
  position: absolute;
  left: 0;
  top: .72em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--lime);
}

.proof {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}

.signal {
  border-radius: 50%;
  aspect-ratio: 1;
  display: grid;
  place-items: center;
  text-align: center;
  padding: 22px;
}

.signal strong {
  display: block;
  font-size: clamp(42px, 6vw, 78px);
  color: var(--lime);
  line-height: .85;
}

.faq {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}

@media (max-width: 1100px) {
  .hv2-layout,
  .hv2-layout.reverse,
  .journey,
  .terrain,
  .proof,
  .faq,
  .gallery,
  .service-list {
    grid-template-columns: 1fr;
  }

  .hv2-layout.reverse .hv2-copy,
  .hv2-layout.reverse .hv2-stage {
    order: initial;
  }

  .hv2-stage {
    min-height: 460px;
  }

  .hv2-stage-frame {
    min-height: 440px;
  }

  .stats {
    grid-template-columns: 1fr 1fr;
  }

  .hv2-object {
    --object-scale: .72;
  }
}

@media (max-width: 720px) {
  .hv2-links a:not(:last-child) {
    display: none;
  }

  .home-v2-clean h1 {
    font-size: clamp(48px, 16vw, 84px);
  }

  .photo {
    min-height: 470px;
  }

  .stats,
  .proof,
  .faq,
  .terrain,
  .journey,
  .gallery {
    grid-template-columns: 1fr;
  }

  .hv2-object {
    --object-scale: .5;
    opacity: .58;
  }
}
</style>

<div class="home-v2-clean">
  <header class="hv2-nav">
    <a href="{{ '/en/' | url }}" class="hv2-brand">
      <img src="{{ site.logoUrl | url }}" alt="{{ site.name }}">
      <span>{{ site.name }}</span>
    </a>

    <nav class="hv2-links">
      <a href="#services">Services</a>
      <a href="#plans">Plans</a>
      <a href="#contact">Contact</a>
      <a href="{{ site.googleForm }}">Start Now</a>
    </nav>
  </header>

  <main>
    <section class="hv2-section hv2-bg-hero hv2-hero">
      <div>
        <span class="hv2-kicker">{{ pages.home.en.hero.badge }}</span>
        <h1>{{ pages.home.en.hero.title_line1 }} {{ pages.home.en.hero.title_line2_gradient }}</h1>
        <p>{{ pages.home.en.hero.description }}</p>
        <a class="hv2-btn" href="{{ site.googleForm }}">{{ pages.home.en.hero.cta_primary }}</a>
      </div>
    </section>

    <section class="hv2-section hv2-bg-nature">
      <div class="hv2-layout">
        <div class="hv2-copy">
          <article class="hv2-panel hv2-glass">
            <span class="hv2-kicker">The full system</span>
            <h2>{{ pages.home.en.pillars.title }}</h2>
            <p>{{ pages.home.en.seo.description }}</p>
            <p>All real O2F services, plans, results and contact routes are rebuilt here as one clear cinematic journey.</p>
          </article>
        </div>

        <div class="hv2-stage">
          <div class="hv2-stage-frame photo">
            <img src="{{ site.heroImage | url }}" alt="{{ site.owner }}">
            <div class="stats">
              <span>{{ site.stats.years }}<br><small>Experience</small></span>
              <span>{{ site.stats.clients }}<br><small>Clients</small></span>
              <span>{{ site.stats.custom }}<br><small>Plans</small></span>
              <span>{{ site.stats.support }}<br><small>Support</small></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="hv2-section hv2-bg-gym" id="services">
      <div class="hv2-layout reverse">
        <div class="hv2-copy">
          <span class="hv2-kicker">{{ pages.services.en.hero.kicker }}</span>
          <h2>{{ pages.services.en.hero.description }}</h2>
          <p>{{ pages.services.en.seo.description }}</p>
        </div>

        <div class="hv2-stage">
          <div class="hv2-stage-frame">
            <div class="hv2-object-glow" style="--object-left:52%;--object-top:47%;"></div>
            <div class="hv2-object hv2-dumbbell" style="--object-left:52%;--object-top:47%;--object-scale:.9;">
              <span></span><i></i><span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="service-list" style="width:min(1220px,100%);margin:28px auto 0;">
        {% for service in pages.services.en.services %}
        <article class="hv2-card hv2-glass">
          <span class="hv2-kicker">{{ service.id }}</span>
          <h3>{{ service.title }}</h3>
          <p>{{ service.description }}</p>
          {% if service.items %}
          <ul>
            {% for item in service.items %}
            {% if loop.index <= 3 %}
            <li>{{ item }}</li>
            {% endif %}
            {% endfor %}
          </ul>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="hv2-section hv2-bg-active">
      <div class="hv2-layout">
        <div class="hv2-copy">
          <span class="hv2-kicker">{{ pages.home.en.pillars.kicker }}</span>
          <h2>{{ pages.home.en.pillars.title }}</h2>
          <div class="readouts">
            {% for item in pages.home.en.pillars.items %}
            <div class="hv2-readout hv2-glass">
              <b>{{ item.title }}</b>
              <p>{{ item.text }}</p>
            </div>
            {% endfor %}
          </div>
        </div>

        <div class="hv2-stage">
          <div class="hv2-stage-frame">
            <div class="hv2-object-glow" style="--object-left:48%;--object-top:52%;"></div>
            <div class="hv2-object hv2-kettle" style="--object-left:48%;--object-top:52%;--object-scale:.92;"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="hv2-section hv2-bg-antiage">
      <div class="journey" style="width:min(1220px,100%);margin:0 auto;">
        <article class="hv2-step hv2-glass">
          <span>01</span>
          <h3>Assess</h3>
          <p>Current level, case, food preferences and lifestyle load.</p>
        </article>
        <article class="hv2-step hv2-glass">
          <span>02</span>
          <h3>Build</h3>
          <p>Training, nutrition and guidance are combined into one plan.</p>
        </article>
        <article class="hv2-step hv2-glass">
          <span>03</span>
          <h3>Follow</h3>
          <p>Weekly check-ins keep the plan adjustable and alive.</p>
        </article>
        <article class="hv2-step hv2-glass">
          <span>04</span>
          <h3>Upgrade</h3>
          <p>The system evolves as the body responds and improves.</p>
        </article>
      </div>
    </section>

    <section class="hv2-section hv2-bg-antiage">
      <div class="gallery" style="width:min(1220px,100%);margin:0 auto;">
        {% for item in pages.home.en.what_you_get.items %}
        <article class="hv2-card hv2-glass">
          <span class="hv2-kicker">Output 0{{ loop.index }}</span>
          <h3>{{ item.title }}</h3>
          <p>{{ item.text }}</p>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="hv2-section hv2-bg-gym" id="plans">
      <div class="hv2-layout">
        <div class="hv2-copy">
          <span class="hv2-kicker">{{ pages.home.en.plans_section.kicker }}</span>
          <h2>{{ pages.home.en.plans_section.title }}</h2>
          <p>Plans are displayed as clear levels using the real pricing and features from the site data.</p>
        </div>

        <div class="hv2-stage">
          <div class="hv2-stage-frame">
            <div class="hv2-object-glow" style="--object-left:52%;--object-top:55%;"></div>
            <div class="hv2-object hv2-rope" style="--object-left:52%;--object-top:55%;--object-scale:.78;"></div>
          </div>
        </div>
      </div>

      <div class="terrain" style="width:min(1220px,100%);margin:28px auto 0;">
        {% for key in ["basic","standard","advanced"] %}
        {% set p = plans[key] %}
        <a class="hv2-plan hv2-glass" href="{{ ('/en/plans/' + p.slug + '/') | url }}">
          <span class="hv2-kicker">{{ "Most popular" if p.highlight else "Access level" }}</span>
          <h3>{{ p.en.name }}</h3>
          <p>{{ p.en.blurb }}</p>

          <div class="price">
            <div><span>1 month</span><b>{{ p.pricing.egypt.m1.amount }} {{ p.pricing.egypt.m1.currency }}</b></div>
            <div><span>3 months</span><b>{{ p.pricing.egypt.m3.amount }} {{ p.pricing.egypt.m3.currency }}/mo</b></div>
            <div><span>6 months</span><b>{{ p.pricing.egypt.m6.amount }} {{ p.pricing.egypt.m6.currency }}/mo</b></div>
          </div>

          <ul class="features">
            {% for feature in p.en.features %}
            {% if loop.index <= 5 %}
            <li>{{ feature }}</li>
            {% endif %}
            {% endfor %}
          </ul>
        </a>
        {% endfor %}
      </div>
    </section>

    <section class="hv2-section hv2-bg-nature">
      <div class="proof" style="width:min(1220px,100%);margin:0 auto;">
        {% for item in pages.home.en.results.items %}
        <div class="signal hv2-glass">
          <div>
            <span class="hv2-kicker">Signal</span>
            <strong>{{ item.value }}{{ item.unit }}</strong>
            <p>{{ item.text }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>

    <section class="hv2-section hv2-bg-hero" id="contact">
      <div class="hv2-layout">
        <article class="hv2-panel hv2-glass">
          <span class="hv2-kicker">{{ pages.home.en.cta.badge }}</span>
          <h2>{{ pages.home.en.cta.title }}</h2>
          <p>{{ pages.home.en.cta.description }}</p>
          <a class="hv2-btn" href="{{ site.googleForm }}">{{ pages.home.en.cta.button }}</a>
        </article>

        <div class="faq">
          <article class="hv2-bubble hv2-glass">
            <b>Is this only training?</b>
            <p>No. It combines training, nutrition and ongoing follow-up.</p>
          </article>
          <article class="hv2-bubble hv2-glass">
            <b>Not sure where to start?</b>
            <p>{{ pages.services.en.cta.description }}</p>
          </article>
          <article class="hv2-bubble hv2-glass">
            <b>What makes it different?</b>
            <p>It is built around your goals, schedule, lifestyle and health status.</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</div>
