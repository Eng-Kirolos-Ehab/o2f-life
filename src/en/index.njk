{# ==================== PLANS PREVIEW ==================== #}
<section class="section bg-white/[0.02]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">Pick your path</p>
    <h2 class="section-title mb-10" data-aos="fade-up" data-aos-delay="100">Plans that match your ambition.</h2>
    <div class="grid md:grid-cols-3 gap-5">
      {% for key in ["basic","standard","advanced"] %}
        {% set p = plans[key] %}
        <a href="{{ ('/en/plans/' + p.slug + '/') | url }}"
           class="card card-hover block {% if p.highlight %}ring-1 ring-brand-mint/40{% endif %}"
           data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
          {% if p.highlight %}<span class="chip text-brand-mint mb-3">Most popular</span>{% endif %}
          <h3 class="text-xl mb-1">{{ p.en.name }}</h3>
          <p class="text-brand-mint text-sm mb-3">{{ p.en.tagline }}</p>
          <p class="text-brand-off/70 text-sm leading-relaxed">{{ p.en.blurb }}</p>
          <span class="inline-flex items-center gap-1 text-brand-mint text-sm mt-4">Learn more →</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

