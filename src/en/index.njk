---

{# ==================== HERO ==================== #}
<section class="grid-bg relative overflow-hidden" style="min-height:90vh;display:flex;align-items:center;">
  {# Animated orbs #}
  <div class="hero-orb hero-orb-1"></div>
  <div class="hero-orb hero-orb-2"></div>
  <div class="hero-orb hero-orb-3"></div>

  {# Floating particles #}
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <span class="particle" style="top:12%;left:8%"></span>
    <span class="particle" style="top:28%;right:12%"></span>
    <span class="particle" style="bottom:22%;left:22%"></span>
    <span class="particle" style="bottom:38%;right:8%"></span>
    <span class="particle" style="top:55%;left:58%"></span>
    <span class="particle" style="top:70%;right:30%"></span>
  </div>

  <div class="container-x py-20 sm:py-28 lg:py-32 relative w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      {# --- Left column --- #}
      <div>
        <div class="hero-badge" data-aos="fade-down" data-aos-duration="600">
          <span class="hero-badge-dot"></span>
          <span class="hero-badge-text">Coach Osama Omran &mdash; O2F.life</span>
        </div>

        <h1 class="section-title text-balance leading-tight" data-aos="fade-up" data-aos-delay="80">
          Transform your body,<br>
          <span class="gradient-mint-text">from the inside out.</span>
        </h1>

        <p class="mt-5 max-w-xl text-lg text-brand-off/70 leading-relaxed"
           data-aos="fade-up" data-aos-delay="160">
          Personalized online coaching that blends training, nutrition and
          naturopathic medicine — built around your goals, schedule and lifestyle.
        </p>

        <div class="mt-8 flex flex-wrap gap-3" data-aos="fade-up" data-aos-delay="240">
          <a href="{{ '/en/plans/' | url }}" class="btn-primary group">
            Start today
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </a>
          <a href="{{ '/en/services/' | url }}" class="btn-ghost">Explore services</a>
        </div>

        {# Stats #}
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-xl"
             data-aos="fade-up" data-aos-delay="320">
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.years }}</div>
            <div class="text-xs text-brand-off/55 mt-1">Years experience</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.clients }}</div>
            <div class="text-xs text-brand-off/55 mt-1">Clients coached</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.custom }}</div>
            <div class="text-xs text-brand-off/55 mt-1">Personalized</div>
          </div>
          <div class="card card-hover text-center">
            <div class="text-2xl font-bold text-brand-mint glow-text-mint">{{ site.stats.support }}</div>
            <div class="text-xs text-brand-off/55 mt-1">Support</div>
          </div>
        </div>
      </div>

      {# --- Right column: image --- #}
      <div class="relative" data-aos="fade-left" data-aos-delay="200" data-aos-duration="800">
        {# Rotating rings #}
        <div class="absolute -inset-10 rounded-full border border-brand-mint/8 animate-spin-slow pointer-events-none"></div>
        <div class="absolute -inset-6 rounded-full border border-brand-gold/6 animate-spin-reverse pointer-events-none"></div>

        {# Glow blur behind image #}
        <div class="absolute -inset-4 rounded-xl2 bg-gradient-to-br from-brand-mint/25 to-brand-gold/15 blur-2xl"></div>

        {# Image #}
        <img src="{{ '/assets/images/817_WhatsApp_Image_2024-07-09_at_21.45.27_02e636a3.webp' | url }}"
             alt="Coach Osama Omran" loading="eager"
             class="relative rounded-xl2 w-full object-cover shadow-card animate-float-img">

        {# Floating info chips #}
        <div class="absolute -bottom-5 -left-5 card py-2.5 px-4 text-sm animate-float pointer-events-none" style="animation-delay:1s;z-index:10">
          <span class="font-bold text-brand-mint">10+</span>
          <span class="text-brand-off/65 ms-1">Years</span>
        </div>
        <div class="absolute -top-5 -right-5 card py-2.5 px-4 text-sm animate-float pointer-events-none" style="animation-delay:2.5s;z-index:10">
          <span class="font-bold text-brand-mint">1000+</span>
          <span class="text-brand-off/65 ms-1">Clients</span>
        </div>
      </div>
    </div>
  </div>
</section>

