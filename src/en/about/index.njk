---
title: "About Coach Osama"
description: "Meet Coach Osama Omran — online fitness coach with a naturopathic background, helping you transform from the inside out."
---

<section class="grid-bg">
  <div class="container-x py-16 sm:py-20">
    <p class="section-kicker">{{ pages.about.en.hero.kicker }}</p>
    <h1 class="section-title text-balance mb-6">{{ pages.about.en.hero.title }}</h1>

    <div class="grid lg:grid-cols-[1.1fr,1fr] gap-10 items-start">
      <div class="prose prose-invert max-w-none">
        <p class="text-lg text-brand-off/80">{{ pages.about.en.hero.intro | safe }}</p>
        <p class="text-brand-off/75">{{ pages.about.en.hero.bio1 | safe }}</p>
        <p class="text-brand-off/75">{{ pages.about.en.hero.bio2 }}</p>

        <h2 class="text-2xl font-bold mt-8 mb-3">{{ pages.about.en.hero.promise_title }}</h2>
        <ul class="text-brand-off/75 space-y-2">
          {% for item in pages.about.en.hero.promise_items %}
          <li>✓ {{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-xl2 bg-gradient-to-br from-brand-mint/30 to-brand-gold/20 blur-2xl"></div>
        <img src="{{ '/assets/images/817_WhatsApp_Image_2024-07-09_at_21.45.27_02e636a3.webp' | url }}"
             alt="{{ pages.about.en.hero.photo_alt }}"
             class="relative rounded-xl2 w-full object-cover shadow-card">
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <h2 class="section-title mb-8">{{ pages.about.en.philosophy.title }}</h2>
    <div class="grid md:grid-cols-3 gap-5">
      {% for item in pages.about.en.philosophy.items %}
      <div class="card">
        <h3 class="text-xl mb-2">{{ item.title }}</h3>
        <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="card text-center">
      <h2 class="text-2xl sm:text-3xl mb-3">{{ pages.about.en.cta.title }}</h2>
      <a href="{{ '/en/contact/' | url }}" class="btn-primary mt-6">{{ pages.about.en.cta.button }}</a>
    </div>
  </div>
</section>
