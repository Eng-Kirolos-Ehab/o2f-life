---
title: "Anti-aging Package"
description: "Restore your youth and radiance with our innovative anti-aging program — skin, energy, mood, memory, hormones, and biological age."
---

<section class="grid-bg relative overflow-hidden">
  <div class="absolute top-10 -right-20 w-96 h-96 rounded-full bg-brand-mint/10 blur-3xl animate-pulse-soft pointer-events-none"></div>
  <div class="absolute bottom-10 -left-20 w-80 h-80 rounded-full bg-brand-gold/15 blur-3xl animate-pulse-soft pointer-events-none" style="animation-delay:1.5s"></div>
  <div class="container-x py-16 sm:py-24 relative">
    <p class="section-kicker" data-aos="fade-up">{{ pages.antiaging.en.hero.kicker }}</p>
    <h1 class="section-title text-balance mb-4" data-aos="fade-up" data-aos-delay="100">
      <span class="gradient-mint-text animate-gradient">{{ pages.antiaging.en.hero.title_gradient }}</span> {{ pages.antiaging.en.hero.title_rest }}<br>
      {{ pages.antiaging.en.hero.title_line2 }}
    </h1>
    <p class="text-lg text-brand-off/75 max-w-2xl" data-aos="fade-up" data-aos-delay="200">{{ pages.antiaging.en.hero.description }}</p>
    <div class="flex flex-wrap gap-3 mt-8" data-aos="fade-up" data-aos-delay="300">
      <a href="{{ '/en/contact/?service=anti-aging' | url }}" class="btn-primary">{{ pages.antiaging.en.hero.cta_primary }}</a>
      <a href="#package-details" class="btn-ghost">{{ pages.antiaging.en.hero.cta_secondary }}</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.antiaging.en.results.kicker }}</p>
    <h2 class="section-title mb-6" data-aos="fade-up" data-aos-delay="100">{{ pages.antiaging.en.results.title }}</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {% for item in pages.antiaging.en.results.items %}
      <div class="card card-hover" data-aos="fade-up" data-aos-delay="{{ loop.index * 50 }}">
        <div class="text-2xl mb-2">{{ item.emoji }}</div>
        <h3 class="text-lg mb-2 text-brand-mint">{{ item.title }}</h3>
        <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section bg-white/[0.02]">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.antiaging.en.what_we_offer.kicker }}</p>
    <h2 class="section-title mb-10" data-aos="fade-up" data-aos-delay="100">{{ pages.antiaging.en.what_we_offer.title }}</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {% for item in pages.antiaging.en.what_we_offer.items %}
      <div class="card card-hover overflow-hidden p-0" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="aspect-video bg-gradient-to-br from-brand-mint/20 to-brand-gold/20 flex items-center justify-center text-5xl">{{ item.emoji }}</div>
        <div class="p-6">
          <h3 class="text-xl mb-2 text-brand-mint">{{ item.title }}</h3>
          <p class="text-brand-off/70 text-sm">{{ item.text }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x max-w-4xl">
    <h2 class="section-title mb-4" data-aos="fade-up">{{ pages.antiaging.en.timeline.title }}</h2>
    <p class="text-brand-off/75 max-w-2xl mb-10" data-aos="fade-up" data-aos-delay="100">{{ pages.antiaging.en.timeline.description }}</p>
    <div class="space-y-4">
      {% for item in pages.antiaging.en.timeline.items %}
      <div class="card card-hover flex gap-4 items-start" data-aos="fade-right" data-aos-delay="{{ loop.index * 100 }}">
        <div class="shrink-0 w-14 h-14 rounded-xl {% if loop.index == 1 %}bg-brand-mint/20 border border-brand-mint/40 text-brand-mint{% else %}bg-brand-gold/20 border border-brand-gold/40 text-brand-gold{% endif %} flex items-center justify-center font-bold">{{ item.label }}</div>
        <div>
          <h3 class="text-lg text-brand-mint mb-1">{{ item.title }}</h3>
          <p class="text-brand-off/75 text-sm">{{ item.text }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
    <p class="text-center text-brand-mint italic mt-8 text-lg" data-aos="fade-up">{{ pages.antiaging.en.timeline.closing }}</p>
  </div>
</section>

<section class="section bg-white/[0.02]">
  <div class="container-x">
    <h2 class="section-title mb-4" data-aos="fade-up">{{ pages.antiaging.en.founder.title }}</h2>
    <div class="max-w-3xl space-y-4">
      {% for p in pages.antiaging.en.founder.paragraphs %}
      <p class="text-brand-off/80" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">{{ p | safe }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section id="package-details" class="section">
  <div class="container-x">
    <p class="section-kicker" data-aos="fade-up">{{ pages.antiaging.en.package.kicker }}</p>
    <h2 class="section-title mb-10" data-aos="fade-up" data-aos-delay="100">{{ pages.antiaging.en.package.title }}</h2>
    <div class="grid md:grid-cols-2 gap-5">
      {% for item in pages.antiaging.en.package.items %}
      <div class="card card-hover" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
        <div class="text-3xl mb-3">{{ item.emoji }}</div>
        <h3 class="text-xl mb-3 text-brand-mint">{{ item.title }}</h3>
        <ul class="space-y-3 text-brand-off/80 text-sm">
          {% for pt in item.points %}
          <li class="flex gap-2"><span class="text-brand-mint">✓</span><div><strong>{{ pt.bold }}</strong> {{ pt.text }}</div></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section bg-white/[0.02]">
  <div class="container-x max-w-4xl">
    <p class="section-kicker text-center" data-aos="fade-up">{{ pages.antiaging.en.pricing.kicker }}</p>
    <h2 class="section-title text-center mb-10" data-aos="fade-up" data-aos-delay="100">{{ pages.antiaging.en.pricing.title }}</h2>
    <div class="grid sm:grid-cols-2 gap-5">
      {% for plan in pages.antiaging.en.pricing.plans %}
      <div class="card card-hover text-center {% if plan.highlight %}ring-2 ring-brand-mint/50 relative{% endif %}" data-aos="{% if loop.index == 1 %}fade-right{% else %}fade-left{% endif %}">
        {% if plan.badge %}<span class="absolute -top-3 left-1/2 -translate-x-1/2 chip bg-brand-mint text-brand-ink border-brand-mint text-xs font-bold">{{ plan.badge }}</span>{% endif %}
        <div class="text-sm text-brand-off/60 uppercase tracking-wider mb-2">{{ plan.label }}</div>
        <div class="text-5xl font-bold text-brand-mint mb-2">{{ plan.price }} <span class="text-xl">{{ plan.currency }}</span></div>
        <p class="text-brand-off/70 text-sm mb-6">{{ plan.description }}</p>
        <a href="{{ ('/en/contact/?service=anti-aging-' + loop.index + 'm') | url }}" class="{% if plan.highlight %}btn-primary{% else %}btn-ghost{% endif %} w-full justify-center">{{ plan.cta }}</a>
      </div>
      {% endfor %}
    </div>
    <p class="text-center text-brand-off/60 text-xs mt-6" data-aos="fade-up">{{ pages.antiaging.en.pricing.note }}</p>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="relative rounded-xl2 overflow-hidden bg-gradient-to-br from-brand-mint/20 via-brand-mint/10 to-brand-ink p-8 sm:p-12 border border-brand-mint/30" data-aos="zoom-in">
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-brand-mint/20 blur-3xl animate-pulse-soft"></div>
      <div class="relative text-center max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl mb-3">{{ pages.antiaging.en.cta.title }}</h2>
        <p class="text-brand-off/80 mb-6">{{ pages.antiaging.en.cta.description }}</p>
        <a href="{{ '/en/contact/?service=anti-aging' | url }}" class="btn-primary">{{ pages.antiaging.en.cta.button }}</a>
      </div>
    </div>
  </div>
</section>
