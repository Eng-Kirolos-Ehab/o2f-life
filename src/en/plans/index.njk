---
title: "Plans"
description: "Choose the right coaching plan — Basic, Standard or Advanced — with regional pricing for Egypt, the Gulf, and international clients."
---

<section class="grid-bg relative overflow-hidden">
  <div class="absolute top-10 -right-20 w-96 h-96 rounded-full bg-brand-mint/10 blur-3xl animate-pulse-soft pointer-events-none"></div>
  <div class="container-x py-16 sm:py-20 relative">
    <p class="section-kicker" data-aos="fade-up">Choose your plan</p>
    <h1 class="section-title mb-4" data-aos="fade-up" data-aos-delay="100">Plans built <span class="gradient-mint-text">around you.</span></h1>
    <p class="text-lg text-brand-off/70 max-w-2xl" data-aos="fade-up" data-aos-delay="200">
      Every plan is fully personalized. Pick the level of support that matches where you are right now.
    </p>
  </div>
</section>

{# REGION SWITCHER #}
<section class="pt-4">
  <div class="container-x">
    <div class="flex flex-wrap items-center justify-center gap-2" data-aos="fade-up">
      <span class="text-brand-off/60 text-sm mr-2">Pricing for:</span>
      <div id="region-switcher" class="inline-flex rounded-xl2 border border-brand-line bg-white/5 p-1 gap-1" role="tablist">
        <button type="button" data-region="egypt"
                class="region-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">
          🇪🇬 Egypt
        </button>
        <button type="button" data-region="gulf"
                class="region-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">
          🇸🇦 Gulf / Arab
        </button>
        <button type="button" data-region="international"
                class="region-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">
          🌍 International
        </button>
      </div>
    </div>
  </div>
</section>

<section class="section pt-10">
  <div class="container-x grid md:grid-cols-3 gap-5 items-stretch">
    {% set orderedKeys = ["basic","standard","advanced"] %}
    {% for key in orderedKeys %}
      {% set p = plans[key] %}
      {% if p.visible !== false %}
      <div class="card card-hover flex flex-col relative {% if p.highlight %}ring-2 ring-brand-mint/50{% endif %}"
           data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 + 100 }}">
        {% if p.highlight %}
          <span class="chip bg-brand-mint text-brand-ink border-brand-mint mb-3 self-start text-xs font-bold">★ Most popular</span>
        {% endif %}
        <h2 class="text-2xl mb-1">{{ p.en.name }}</h2>
        <p class="text-brand-mint text-sm mb-4">{{ p.en.tagline }}</p>

        {# Regional price #}
        <div class="mb-4 price-container"
             data-egypt-amount="{{ p.pricing.egypt.amount }}"
             data-egypt-currency="{{ p.pricing.egypt.currency }}"
             data-gulf-amount="{{ p.pricing.gulf.amount }}"
             data-gulf-currency="{{ p.pricing.gulf.currency }}"
             data-intl-amount="{{ p.pricing.international.amount }}"
             data-intl-currency="{{ p.pricing.international.currency }}">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-brand-mint price-amount">{{ p.pricing.egypt.amount }}</span>
            <span class="text-brand-off/70 text-sm price-currency">{{ p.pricing.egypt.currency }}</span>
          </div>
          <div class="text-brand-off/50 text-xs price-period">{{ p.pricing.egypt.period }}</div>
        </div>

        <p class="text-brand-off/70 text-sm">{{ p.en.blurb }}</p>
        <ul class="mt-5 space-y-1.5 text-sm text-brand-off/75 flex-1">
          {% for f in p.en.features %}<li class="flex gap-2"><span class="text-brand-mint">✓</span>{{ f }}</li>{% endfor %}
        </ul>
        <a href="/en/plans/{{ p.slug }}/"
           class="{% if p.highlight %}btn-primary{% else %}btn-ghost{% endif %} mt-6 justify-center">
          {{ p.en.cta }}
        </a>
      </div>
      {% endif %}
    {% endfor %}

    {# CUSTOM PLANS #}
    {% if customPlans.items %}
      {% for p in customPlans.items %}
        {% if p.visible !== false and p.en %}
        <div class="card card-hover flex flex-col relative border-brand-gold/30"
             data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 + 400 }}">
          <span class="chip text-brand-gold mb-3 self-start">✨ Special</span>
          <h2 class="text-2xl mb-1">{{ p.en.name }}</h2>
          <p class="text-brand-gold text-sm mb-4">{{ p.en.tagline }}</p>
          {% if p.pricing %}
          <div class="mb-4 price-container"
               data-egypt-amount="{{ p.pricing.egypt.amount }}"
               data-egypt-currency="{{ p.pricing.egypt.currency }}"
               data-gulf-amount="{{ p.pricing.gulf.amount }}"
               data-gulf-currency="{{ p.pricing.gulf.currency }}"
               data-intl-amount="{{ p.pricing.international.amount }}"
               data-intl-currency="{{ p.pricing.international.currency }}">
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-bold text-brand-gold price-amount">{{ p.pricing.egypt.amount }}</span>
              <span class="text-brand-off/70 text-sm price-currency">{{ p.pricing.egypt.currency }}</span>
            </div>
            <div class="text-brand-off/50 text-xs price-period">{{ p.pricing.egypt.period }}</div>
          </div>
          {% endif %}
          <p class="text-brand-off/70 text-sm">{{ p.en.blurb }}</p>
          {% if p.en.features %}
          <ul class="mt-5 space-y-1.5 text-sm text-brand-off/75 flex-1">
            {% for f in p.en.features %}<li class="flex gap-2"><span class="text-brand-gold">✓</span>{{ f }}</li>{% endfor %}
          </ul>
          {% endif %}
          <a href="/en/contact/?service={{ p.slug }}" class="btn-ghost mt-6 justify-center border-brand-gold/50 text-brand-gold hover:border-brand-gold">
            {{ p.en.cta or "Request this plan" }}
          </a>
        </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="card card-hover text-center" data-aos="fade-up">
      <h3 class="text-xl mb-2">Looking for the Anti-aging program?</h3>
      <p class="text-brand-off/70">A separate holistic package focused on rejuvenation and long-term vitality.</p>
      <a href="/en/anti-aging/" class="btn-ghost mt-6">Explore Anti-aging →</a>
    </div>
  </div>
</section>

<style>
  .region-btn { color: rgba(247,248,250,0.6); }
  .region-btn.active { background-color: rgba(0,217,163,0.15); color: #00D9A3; }
  .region-btn:hover:not(.active) { color: #F7F8FA; background: rgba(255,255,255,0.05); }
</style>

<script>
(function () {
  const KEY = 'o2f_region';
  const DEFAULT = 'egypt';
  const regionMap = {
    egypt: { amount: 'egyptAmount', currency: 'egyptCurrency' },
    gulf: { amount: 'gulfAmount', currency: 'gulfCurrency' },
    international: { amount: 'intlAmount', currency: 'intlCurrency' }
  };

  function setRegion(region) {
    if (!regionMap[region]) region = DEFAULT;
    try { localStorage.setItem(KEY, region); } catch (e) {}
    document.querySelectorAll('.region-btn').forEach(function (b) {
      b.classList.toggle('active', b.dataset.region === region);
    });
    document.querySelectorAll('.price-container').forEach(function (el) {
      const amount = el.dataset[regionMap[region].amount];
      const currency = el.dataset[regionMap[region].currency];
      const a = el.querySelector('.price-amount');
      const c = el.querySelector('.price-currency');
      if (a && amount) a.textContent = amount;
      if (c && currency) c.textContent = currency;
    });
  }

  let saved = DEFAULT;
  try { saved = localStorage.getItem(KEY) || DEFAULT; } catch (e) {}
  setRegion(saved);

  document.querySelectorAll('.region-btn').forEach(function (b) {
    b.addEventListener('click', function () { setRegion(b.dataset.region); });
  });
})();
</script>
