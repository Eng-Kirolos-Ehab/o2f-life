<div class="cmd-page" id="cmdPage">
  <div class="scroll-dumbbell" id="scrollDumbbell" aria-hidden="true"><div class="dumbbell-shape"><span></span><i></i><span></span></div><small>O2F</small></div>
  <section class="cmd-hero"><div class="cmd-orbital" aria-hidden="true"><span></span><span></span><span></span></div><div class="container-x cmd-grid"><div class="cmd-left" data-aos="fade-up"><div class="cmd-status"><i></i> O2F Transformation OS / Online</div><h1>Enter the system that rebuilds the body.</h1><p>{{ pages.home.en.hero.description }}</p><div class="cmd-buttons"><a href="{{ '/en/plans/' | url }}" class="cmd-primary">Launch protocol</a><a href="{{ '/en/contact/' | url }}" class="cmd-secondary">Request access</a></div><div class="cmd-mini-proof"><span>{{ site.stats.years }} experience</span><span>{{ site.stats.clients }} clients</span><span>{{ site.stats.custom }} custom plans</span></div></div><div class="cmd-console" data-aos="zoom-in" data-aos-delay="120"><div class="cmd-topbar"><span></span><span></span><span></span><b>O2F_CONTROL_PANEL</b></div><div class="cmd-body"><div class="cmd-scan"><img src="{{ (site.heroImage or '/assets/images/817_WhatsApp_Image_2024-07-09_at_21.45.27_02e636a3.webp') | url }}" alt="Coach Osama Omran"></div><div class="cmd-readouts"><div><small>COACHING</small><strong>{{ site.stats.years }}</strong></div><div><small>CLIENTS</small><strong>{{ site.stats.clients }}</strong></div><div><small>SUPPORT</small><strong>{{ site.stats.support }}</strong></div></div></div></div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-overview-card"><span>SYSTEM OVERVIEW</span><h2>One dashboard for training, nutrition, natural health and follow-up.</h2><p>Instead of separating your goal into random advice, the O2F experience connects every part of the journey into one operating system: assessment, plan design, execution, review and adjustment.</p></div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title"><span>CORE MODULES</span><h2>Everything runs inside one transformation dashboard.</h2></div><div class="cmd-modules">{% for item in pages.home.en.pillars.items %}<article><b>MODULE_0{{ loop.index }}</b><h3>{{ item.title }}</h3><p>{{ item.text }}</p><div class="cmd-bar"><i style="width:{{ 60 + loop.index * 12 }}%"></i></div></article>{% endfor %}</div></div></section>
  <section class="cmd-section"><div class="container-x cmd-diag-grid"><div class="cmd-section-title"><span>LIVE DIAGNOSTICS</span><h2>Before the plan starts, the system reads the problem.</h2><p class="cmd-muted">O2F studies patterns, builds rules, and tracks the response so the plan stays practical and personal.</p></div><div class="cmd-diag-panel"><div class="cmd-topbar"><span></span><span></span><span></span><b>BODY_DIAGNOSTIC.exe</b></div><div class="cmd-diag-list"><p><b>01</b> Lifestyle load <i>SCANNING</i></p><p><b>02</b> Nutrition gaps <i>DETECTED</i></p><p><b>03</b> Training capacity <i>READY</i></p><p><b>04</b> Recovery signal <i>MONITORING</i></p><p><b>05</b> Adherence risk <i>CALCULATING</i></p></div></div></div></section>
  <section class="cmd-section"><div class="container-x cmd-protocol-grid"><div class="cmd-section-title"><span>PROTOCOL FLOW</span><h2>Not a page. A mission sequence.</h2><p class="cmd-muted">The user understands what happens after joining before they click.</p></div><div class="cmd-sequence">{% set seq = [{"t":"Diagnose","d":"Analyze the current body, habits and target."},{"t":"Encode","d":"Build training and nutrition rules into one plan."},{"t":"Execute","d":"Follow weekly commands with clarity."},{"t":"Evolve","d":"Update the system as your body responds."}] %}{% for s in seq %}<article><span>0{{ loop.index }}</span><div><h3>{{ s.t }}</h3><p>{{ s.d }}</p></div></article>{% endfor %}</div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title center"><span>TRANSFORMATION MAP</span><h2>The visitor sees the full route before joining.</h2></div><div class="cmd-map-line"><div><b>Start</b><p>Assessment</p></div><div><b>Week 1</b><p>Protocol setup</p></div><div><b>Week 4</b><p>First calibration</p></div><div><b>Week 8+</b><p>Visible system response</p></div></div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title"><span>WHAT YOU GET</span><h2>The system outputs practical tools, not vague motivation.</h2></div><div class="cmd-deliver-grid">{% for item in pages.home.en.what_you_get.items %}<article><b>OUTPUT_0{{ loop.index }}</b><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title center"><span>OUTPUT DATA</span><h2>Progress shown like performance metrics.</h2></div><div class="cmd-results-grid">{% for item in pages.home.en.results.items %}<article><strong>{{ item.value }}<small>{{ item.unit }}</small></strong><p>{{ item.text }}</p></article>{% endfor %}</div></div></section>
  <section class="cmd-section"><div class="container-x cmd-before-grid"><div class="cmd-before-card bad"><span>BEFORE / RANDOM MODE</span><h3>Scattered effort</h3><ul><li>Random workouts</li><li>No food structure</li><li>No progress feedback</li><li>Motivation-only decisions</li></ul></div><div class="cmd-before-card good"><span>AFTER / SYSTEM MODE</span><h3>Controlled progress</h3><ul><li>Clear training rules</li><li>Nutrition strategy</li><li>Weekly calibration</li><li>Coach-led direction</li></ul></div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title"><span>ACCESS LEVELS</span><h2>Choose your operating mode.</h2></div><div class="cmd-plan-grid">{% for key in ["basic","standard","advanced"] %}{% set p = plans[key] %}<a href="{{ ('/en/plans/' + p.slug + '/') | url }}" class="cmd-plan {% if p.highlight %}active{% endif %}"><em>{{ "RECOMMENDED" if p.highlight else "ACCESS" }}</em><h3>{{ p.en.name }}</h3><b>{{ p.en.tagline }}</b><p>{{ p.en.blurb }}</p><span>Enter mode →</span></a>{% endfor %}</div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-section-title"><span>COMMON SIGNALS</span><h2>Questions before activation.</h2></div><div class="cmd-faq-grid"><article><b>Is this only training?</b><p>No. The concept combines training, nutrition, follow-up and natural health direction.</p></article><article><b>Do I need gym experience?</b><p>No. The system should scale based on your current level and routine.</p></article><article><b>What makes it different?</b><p>The difference is structure: assessment, protocol, execution, calibration.</p></article></div></div></section>
  <section class="cmd-section"><div class="container-x"><div class="cmd-final-box"><span>READY_SIGNAL</span><h2>Your next version needs a system.</h2><p>{{ pages.home.en.cta.description }}</p><a href="{{ '/en/contact/' | url }}" class="cmd-primary">Activate transformation</a></div></div></section>
</div>

<script>
(function(){
  const page=document.getElementById('cmdPage');
  const db=document.getElementById('scrollDumbbell');
  if(!page||!db)return;
  const path=[
    [0.00,74,22,1.05,-18],[0.09,18,38,.78,18],[0.18,84,48,.95,45],[0.29,68,64,1.18,-38],
    [0.39,14,60,.85,70],[0.50,50,25,.72,0],[0.60,88,32,1.08,-15],[0.70,18,30,1.25,28],
    [0.80,50,72,.9,-68],[0.90,80,68,1.04,38],[1.00,50,30,1.35,0]
  ];
  function lerp(a,b,t){return a+(b-a)*t}
  function clamp(v){return Math.max(0,Math.min(1,v))}
  function update(){
    const rect=page.getBoundingClientRect();
    const total=rect.height-window.innerHeight;
    const progress=clamp((-rect.top)/(total||1));
    let a=path[0],b=path[path.length-1];
    for(let i=0;i<path.length-1;i++){if(progress>=path[i][0]&&progress<=path[i+1][0]){a=path[i];b=path[i+1];break}}
    const local=clamp((progress-a[0])/(b[0]-a[0]||1));
    const ease=local*local*(3-2*local);
    const x=lerp(a[1],b[1],ease), y=lerp(a[2],b[2],ease), s=lerp(a[3],b[3],ease), r=lerp(a[4],b[4],ease);
    db.style.transform=`translate3d(${x}vw,${y}vh,0) translate(-50%,-50%) scale(${s}) rotate(${r}deg)`;
  }
  let ticking=false;
  function request(){if(!ticking){requestAnimationFrame(()=>{update();ticking=false});ticking=true}}
  update(); window.addEventListener('scroll',request,{passive:true}); window.addEventListener('resize',request);
})();
</script>
