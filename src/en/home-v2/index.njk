---

<style>
.o2f-xp{--lime:#a8ff78;--mint:#00d9a3;--forest:#06110d;--white:#f7fff7;--muted:rgba(247,255,247,.76);--glass:rgba(255,255,255,.13);--stroke:rgba(255,255,255,.22);min-height:100vh;background:var(--forest);color:var(--white);font-family:Inter,system-ui,sans-serif;overflow:hidden}.o2f-xp *{box-sizing:border-box}.xp-world{position:sticky;top:0;height:100vh;z-index:1;overflow:hidden;background:#06110d}.xp-bg{position:absolute;inset:-12%;background-image:var(--scene,url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=85'));background-size:cover;background-position:center;transform:translate3d(var(--px,0),var(--py,0),0) scale(1.08);filter:saturate(1.02) contrast(1.04);transition:background-image .7s ease}.xp-world:before{content:"";position:absolute;inset:0;z-index:1;background:radial-gradient(circle at 50% 42%,rgba(255,255,255,.16),transparent 25%),linear-gradient(90deg,rgba(0,0,0,.72),rgba(0,0,0,.22) 48%,rgba(0,0,0,.58)),linear-gradient(180deg,rgba(0,0,0,.08),rgba(2,14,9,.72));pointer-events:none}.xp-world:after{content:"";position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(115deg,transparent 0 20%,rgba(255,255,255,.12) 23%,transparent 30% 70%,rgba(168,255,120,.1) 76%,transparent 84%);mix-blend-mode:screen}.xp-top{position:absolute;z-index:12;left:clamp(1rem,4vw,4rem);right:clamp(1rem,4vw,4rem);top:clamp(1rem,3vw,2.4rem);display:flex;align-items:center;justify-content:space-between;gap:1rem}.xp-brand{display:flex;align-items:center;gap:.7rem;text-decoration:none;color:#fff;font-weight:950;letter-spacing:-.04em}.xp-brand img{width:42px;height:42px;border-radius:50%;object-fit:cover;box-shadow:0 0 35px rgba(0,217,163,.35)}.xp-nav{display:flex;align-items:center;gap:1rem}.xp-nav a{color:rgba(255,255,255,.84);text-decoration:none;font-size:.82rem;font-weight:850}.xp-nav a:last-child{border:1px solid rgba(255,255,255,.62);border-radius:999px;padding:.62rem 1.05rem;background:rgba(255,255,255,.08);backdrop-filter:blur(14px);color:#fff}.xp-hero-text{position:absolute;inset:0;z-index:6;display:grid;place-items:center;text-align:center;padding:7rem clamp(1rem,5vw,5rem) 4rem;transition:.35s ease}.xp-hero-text.is-product{opacity:.08;transform:translateY(-44px) scale(.92)}.xp-kicker{display:inline-block;color:var(--lime);font-size:.75rem;font-weight:950;letter-spacing:.18em;text-transform:uppercase}.xp-hero-text h1{font-size:clamp(3.3rem,9vw,9.8rem);line-height:.82;letter-spacing:-.09em;max-width:1200px;margin:1rem 0;text-shadow:0 22px 70px rgba(0,0,0,.42)}.xp-hero-text p{max-width:720px;margin:0 auto 1.8rem;color:rgba(255,255,255,.84);line-height:1.75;font-size:clamp(1rem,1.45vw,1.2rem)}.xp-btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.78);border-radius:999px;padding:.9rem 1.35rem;color:#fff;text-decoration:none;font-size:.86rem;font-weight:950;background:rgba(0,0,0,.08);backdrop-filter:blur(14px)}.xp-decor{position:absolute;inset:0;z-index:4;pointer-events:none;overflow:hidden}.decor{position:absolute;opacity:.75;will-change:transform}.decor.orb{width:140px;height:140px;border-radius:999px;background:radial-gradient(circle at 32% 24%,rgba(255,255,255,.92),rgba(168,255,120,.28) 34%,rgba(0,0,0,.04) 72%)}.decor.ring{width:190px;height:190px;border:2px solid rgba(255,255,255,.24);border-radius:50%;box-shadow:0 0 45px rgba(168,255,120,.14)}.decor.leaf{width:82px;height:34px;border-radius:80% 0 80% 0;background:linear-gradient(135deg,rgba(255,255,255,.82),rgba(168,255,120,.45));transform:rotate(-28deg)}.decor.line{width:270px;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.6),transparent)}.decor:nth-child(1){left:8vw;top:24vh}.decor:nth-child(2){right:9vw;top:16vh}.decor:nth-child(3){left:18vw;bottom:18vh}.decor:nth-child(4){right:18vw;bottom:25vh}.decor:nth-child(5){right:22vw;bottom:10vh;width:90px;height:90px}.decor:nth-child(6){left:38vw;top:68vh;width:96px;height:96px}.xp-object-layer{position:absolute;inset:0;z-index:7;display:grid;place-items:center;pointer-events:none;perspective:1200px}.fitness-object{position:relative;opacity:0;transform:translate3d(0,80px,0) rotate(-10deg) scale(.65);transition:opacity .45s ease,transform .75s cubic-bezier(.2,.9,.2,1);filter:drop-shadow(0 36px 34px rgba(0,0,0,.36))}.fitness-object.show{opacity:1;transform:translate3d(var(--ox,0),var(--oy,0),0) rotate(var(--r,-8deg)) scale(var(--s,1))}.obj-bottle{width:115px;height:330px;border-radius:52px 52px 58px 58px;background:linear-gradient(90deg,#276d33,#75d35e 36%,#d9ffd0 48%,#5bbb4c 58%,#1d6a34);box-shadow:inset 18px 0 34px rgba(255,255,255,.2),inset -20px 0 34px rgba(0,0,0,.22)}.obj-bottle:before{content:"";position:absolute;left:31px;right:31px;top:-43px;height:50px;border-radius:18px 18px 9px 9px;background:linear-gradient(90deg,#101816,#2f3530,#111)}.obj-bottle:after{content:"";position:absolute;left:29px;right:29px;top:-63px;height:62px;border:13px solid #111816;border-bottom:0;border-radius:42px 42px 0 0}.obj-dumbbell{width:370px;height:120px;display:flex;align-items:center;justify-content:space-between;--r:12deg;--s:1}.obj-dumbbell span{width:92px;height:160px;border-radius:28px;background:linear-gradient(180deg,#f2fff0,#74d46b 55%,#1d6d34);box-shadow:inset 0 0 22px rgba(255,255,255,.44),inset 0 -20px 24px rgba(0,0,0,.2)}.obj-dumbbell i{position:absolute;left:86px;right:86px;height:28px;border-radius:999px;background:linear-gradient(90deg,#14221a,#eaffdf 46%,#15351e)}.obj-kettle{width:230px;height:230px;border-radius:50% 50% 44% 44%;background:linear-gradient(135deg,#eaffdf,#78d86c 40%,#1b7337 78%);--r:-9deg}.obj-kettle:before{content:"";position:absolute;left:54px;right:54px;top:-58px;height:92px;border:26px solid #1b211d;border-bottom:0;border-radius:68px 68px 0 0}.obj-rope{width:310px;height:310px;border:16px solid #78d86c;border-radius:50%;--r:22deg;background:radial-gradient(circle,transparent 55%,rgba(255,255,255,.16) 56%,transparent 62%)}.obj-rope:before,.obj-rope:after{content:"";position:absolute;width:28px;height:108px;border-radius:999px;background:#161d19;bottom:-52px}.obj-rope:before{left:50px;transform:rotate(20deg)}.obj-rope:after{right:50px;transform:rotate(-20deg)}.xp-track{position:relative;z-index:3;margin-top:-100vh;padding-top:100vh}.scene{min-height:100vh;padding:12vh clamp(1rem,5vw,4.5rem);display:grid;align-items:center}.glass{border:1px solid var(--stroke);background:var(--glass);backdrop-filter:blur(24px);box-shadow:0 30px 90px rgba(0,0,0,.18);border-radius:34px;color:#fff}.scene-title h2,.intro-panel h2,.service-title h2,.plan-title h2{font-size:clamp(2.15rem,4.7vw,5rem);line-height:.9;letter-spacing:-.075em;margin:.75rem 0 1rem}.scene-title p,.intro-panel p,.service-title p,.plan-title p{color:rgba(255,255,255,.78);line-height:1.75}.intro-layout{display:grid;grid-template-columns:minmax(320px,540px) 1fr;gap:clamp(1rem,5vw,5rem);align-items:center}.intro-panel{padding:1.7rem}.hero-photo{position:relative;min-height:620px;border-radius:46px;overflow:hidden}.hero-photo img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(1.05) contrast(1.05)}.hero-photo:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent,rgba(0,0,0,.55))}.photo-caption{position:absolute;z-index:2;left:1.2rem;right:1.2rem;bottom:1.2rem;display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem}.photo-caption span{border-radius:20px;background:rgba(255,255,255,.14);backdrop-filter:blur(14px);padding:.8rem;text-align:center;font-weight:950}.service-system{display:grid;grid-template-columns:minmax(320px,420px) minmax(480px,1fr);gap:clamp(1rem,5vw,5rem);align-items:center}.service-orbit{position:relative;min-height:700px}.service-orbit:before,.service-orbit:after{content:"";position:absolute;inset:6%;border:1px solid rgba(255,255,255,.22);border-radius:50%;animation:spin 34s linear infinite}.service-orbit:after{inset:19%;animation-duration:21s;animation-direction:reverse}.orbit-core{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:220px;height:220px;border-radius:50%;display:grid;place-items:center;text-align:center;padding:1.2rem;background:radial-gradient(circle,rgba(168,255,120,.35),rgba(255,255,255,.12));border:1px solid rgba(255,255,255,.28);box-shadow:0 0 70px rgba(168,255,120,.18)}.orbit-core b{font-size:2.2rem;letter-spacing:-.08em}.service-node{position:absolute;width:260px;padding:1.1rem;border-radius:30px}.service-node h3,.deliver-card h3,.plan-card h3{margin:.35rem 0 .45rem;font-size:1.28rem}.service-node p,.deliver-card p,.plan-card p,.detail-list li,.proof-signal span{margin:0;color:rgba(255,255,255,.74);line-height:1.62;font-size:.94rem}.service-node strong,.deliver-card strong,.plan-card em,.proof-signal b{display:block;color:var(--lime);font-size:.72rem;letter-spacing:.13em;text-transform:uppercase}.service-node ul{margin:.8rem 0 0;padding:0;list-style:none;display:grid;gap:.42rem}.service-node li{color:rgba(255,255,255,.78);font-size:.82rem;line-height:1.35;padding-left:1rem;position:relative}.service-node li:before{content:"";position:absolute;left:0;top:.55em;width:5px;height:5px;border-radius:50%;background:var(--lime)}.service-node:nth-child(2){left:0;top:5%}.service-node:nth-child(3){right:0;top:14%}.service-node:nth-child(4){left:8%;bottom:8%}.service-node:nth-child(5){right:5%;bottom:4%}.cockpit-layout{display:grid;grid-template-columns:1fr minmax(340px,520px);gap:clamp(1rem,5vw,5rem);align-items:center}.cockpit{padding:1rem;border-radius:36px}.cockpit-top{height:48px;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid rgba(255,255,255,.16);margin:-1rem -1rem 1rem;padding:0 1rem}.cockpit-top i{width:10px;height:10px;border-radius:50%;background:var(--lime)}.cockpit-screen{display:grid;grid-template-columns:1.1fr .9fr;gap:1rem}.body-radar{min-height:420px;border-radius:26px;background:radial-gradient(circle at 50% 50%,rgba(168,255,120,.28),transparent 14%),repeating-radial-gradient(circle at 50% 50%,rgba(255,255,255,.18) 0 1px,transparent 1px 44px);position:relative;overflow:hidden}.body-radar:before{content:"OSAMA / BODY MAP";position:absolute;left:1rem;top:1rem;color:rgba(255,255,255,.52);font-size:.72rem;font-weight:950;letter-spacing:.16em}.body-radar:after{content:"";position:absolute;left:50%;top:50%;width:2px;height:46%;background:linear-gradient(var(--lime),transparent);transform-origin:bottom;animation:sweep 5s linear infinite}.readouts{display:grid;gap:.75rem}.readout{padding:.9rem;border-radius:20px;background:rgba(255,255,255,.12)}.readout span{display:flex;justify-content:space-between;gap:1rem;color:rgba(255,255,255,.78);font-size:.9rem}.readout i{font-style:normal;color:var(--lime);font-weight:950}.journey-river{position:relative;min-height:760px;padding:2rem}.journey-river:before{content:"";position:absolute;left:7%;right:7%;top:50%;height:2px;background:linear-gradient(90deg,transparent,var(--lime),var(--mint),transparent);opacity:.65}.journey-step{position:absolute;width:min(310px,40vw);padding:1.15rem;border-radius:30px}.journey-step span{width:44px;height:44px;display:grid;place-items:center;border-radius:50%;background:rgba(168,255,120,.22);font-weight:950;margin-bottom:.8rem}.journey-step:nth-child(1){left:2%;top:8%}.journey-step:nth-child(2){right:9%;top:15%}.journey-step:nth-child(3){left:16%;bottom:16%}.journey-step:nth-child(4){right:4%;bottom:5%}.deliver-gallery{display:grid;grid-template-columns:1.2fr .8fr .8fr;grid-auto-rows:minmax(220px,auto);gap:1rem}.deliver-card{padding:1.25rem;border-radius:34px;position:relative;overflow:hidden}.deliver-card:nth-child(1){grid-row:span 2}.deliver-card:nth-child(4){grid-column:span 2}.deliver-card:before{content:"";position:absolute;right:-25%;bottom:-35%;width:75%;height:70%;border-radius:50%;background:rgba(168,255,120,.16)}.deliver-card>*{position:relative}.plan-layout{display:grid;grid-template-columns:minmax(320px,430px) 1fr;gap:clamp(1rem,5vw,5rem);align-items:center}.plan-terrain{position:relative;min-height:720px}.plan-card{position:absolute;width:32%;min-width:240px;padding:1.3rem;border-radius:36px;text-decoration:none;color:#fff;transition:.25s ease}.plan-card:hover{transform:translateY(-10px) rotate(0deg)!important;background:rgba(255,255,255,.2)}.plan-card:nth-child(1){left:0;bottom:8%;transform:rotate(-5deg)}.plan-card:nth-child(2){left:34%;top:7%;transform:rotate(3deg);min-height:360px;background:rgba(168,255,120,.18)}.plan-card:nth-child(3){right:0;bottom:16%;transform:rotate(5deg)}.price-strip{margin:1rem 0;display:grid;gap:.45rem}.price-strip div{display:flex;justify-content:space-between;border-radius:16px;background:rgba(255,255,255,.12);padding:.55rem .7rem;font-size:.82rem}.detail-list{margin:1rem 0 0;padding:0;list-style:none;display:grid;gap:.45rem}.detail-list li{padding-left:1rem;position:relative}.detail-list li:before{content:"";position:absolute;left:0;top:.62em;width:5px;height:5px;background:var(--lime);border-radius:50%}.plan-card span{display:block;margin-top:1rem;font-weight:950}.proof-board{position:relative;min-height:560px}.proof-board:before{content:"";position:absolute;left:8%;right:8%;top:50%;height:1px;background:linear-gradient(90deg,transparent,var(--lime),transparent);opacity:.65}.proof-signal{position:absolute;width:230px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;text-align:center;padding:1.1rem}.proof-signal strong{display:block;font-size:clamp(2.5rem,5vw,4.4rem);line-height:.82;color:var(--lime);letter-spacing:-.08em}.proof-signal:nth-child(1){left:5%;top:5%}.proof-signal:nth-child(2){right:12%;top:14%;transform:scale(.94)}.proof-signal:nth-child(3){left:38%;bottom:2%;transform:scale(1.08)}.contact-panel{display:grid;grid-template-columns:1.1fr .9fr;gap:1rem;align-items:stretch}.contact-card{padding:1.5rem}.contact-card h2{font-size:clamp(2rem,4.5vw,4.5rem);line-height:.9;letter-spacing:-.075em;margin:.8rem 0}.contact-actions{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:1.2rem}.contact-actions a{border-radius:999px;padding:.85rem 1.1rem;text-decoration:none;font-weight:950;color:#06110d;background:#fff}.contact-actions a.alt{color:#fff;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.25)}.faq-cloud{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.faq-bubble{padding:1.25rem;border-radius:42px 42px 42px 16px}.faq-bubble b{display:block;margin-bottom:.55rem}.faq-bubble p{color:rgba(255,255,255,.74);line-height:1.65;margin:0}.xp-final{position:relative;z-index:4;min-height:85vh;display:grid;place-items:center;text-align:center;padding:5rem 1rem;background:linear-gradient(180deg,rgba(6,17,13,0),#06110d 28%,#06110d)}.xp-final h2{font-size:clamp(2.8rem,8vw,7rem);line-height:.86;letter-spacing:-.08em;margin:0}.xp-final p{max-width:700px;color:rgba(255,255,255,.74);line-height:1.8}@media(max-width:1100px){.intro-layout,.service-system,.cockpit-layout,.plan-layout,.contact-panel{grid-template-columns:1fr}.service-orbit,.plan-terrain,.proof-board{min-height:auto;display:grid;grid-template-columns:1fr 1fr;gap:1rem}.service-orbit:before,.service-orbit:after,.proof-board:before{display:none}.orbit-core,.service-node,.plan-card,.proof-signal,.journey-step{position:relative!important;left:auto!important;right:auto!important;top:auto!important;bottom:auto!important;width:auto!important;transform:none!important}.orbit-core{width:auto;height:auto;border-radius:34px}.journey-river{min-height:auto;display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:0}.journey-river:before{display:none}.deliver-gallery{grid-template-columns:1fr 1fr}.deliver-card:nth-child(1),.deliver-card:nth-child(4){grid-row:auto;grid-column:auto}.obj-bottle{transform:scale(.74)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.72)}}@media(max-width:720px){.xp-nav a:not(:last-child){display:none}.xp-hero-text h1{font-size:clamp(3rem,16vw,6rem)}.xp-hero-text{padding:6rem 1rem 3rem}.photo-caption,.service-orbit,.journey-river,.deliver-gallery,.plan-terrain,.proof-board,.faq-cloud,.cockpit-screen{grid-template-columns:1fr}.hero-photo{min-height:460px}.obj-bottle{transform:scale(.58)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.56)}}@media(prefers-reduced-motion:reduce){.xp-bg,.fitness-object,.xp-hero-text,.decor,.service-orbit:before,.service-orbit:after,.body-radar:after{transition:none!important;animation:none!important}}
@keyframes spin{to{transform:rotate(360deg)}}@keyframes sweep{to{transform:rotate(360deg)}}
</style>

<div class="o2f-xp" id="o2fXp">
  <div class="xp-world">
    <div class="xp-bg" id="xpBg"></div>
    <div class="xp-decor" aria-hidden="true"><span class="decor orb"></span><span class="decor ring"></span><span class="decor leaf"></span><span class="decor line"></span><span class="decor orb"></span><span class="decor ring"></span></div>
    <div class="xp-top"><a href="{{ '/en/' | url }}" class="xp-brand"><img src="{{ site.logoUrl | url }}" alt="{{ site.name }} logo"><span>{{ site.name }}</span></a><nav class="xp-nav"><a href="#services">Services</a><a href="#plans">Plans</a><a href="#contact">Contact</a><a href="{{ site.googleForm }}">Start Now</a></nav></div>
    <div class="xp-hero-text" id="xpHeroText"><div><small class="xp-kicker" id="stageEyebrow">{{ pages.home.en.hero.badge }}</small><h1 id="stageTitle">{{ pages.home.en.hero.title_line1 }} {{ pages.home.en.hero.title_line2_gradient }}</h1><p id="stageDesc">{{ pages.home.en.hero.description }}</p><a href="{{ site.googleForm }}" class="xp-btn">{{ pages.home.en.hero.cta_primary }}</a></div></div>
    <div class="xp-object-layer"><div class="fitness-object obj-bottle" id="fitnessObject"></div></div>
  </div>

  <div class="xp-track">
    <section class="scene" data-object="none" data-scene="forest" data-eyebrow="{{ pages.home.en.hero.badge | escape }}" data-title="{{ pages.home.en.hero.title_line1 | escape }} {{ pages.home.en.hero.title_line2_gradient | escape }}" data-desc="{{ pages.home.en.hero.description | escape }}">
      <div class="intro-layout">
        <article class="intro-panel glass"><span class="xp-kicker">The complete picture</span><h2>{{ pages.home.en.pillars.title }}</h2><p>{{ pages.home.en.seo.description }}</p><p>Everything on this page is pulled from the real O2F content: services, plans, pricing, features, results and contact routes — rebuilt as one cinematic experience.</p></article>
        <div class="hero-photo glass"><img src="{{ site.heroImage | url }}" alt="{{ site.owner }}"><div class="photo-caption"><span>{{ site.stats.years }}<br><small>{{ pages.home.en.hero.stats_years_label }}</small></span><span>{{ site.stats.clients }}<br><small>{{ pages.home.en.hero.stats_clients_label }}</small></span><span>{{ site.stats.custom }}<br><small>{{ pages.home.en.hero.stats_custom_label }}</small></span><span>{{ site.stats.support }}<br><small>{{ pages.home.en.hero.stats_support_label }}</small></span></div></div>
      </div>
    </section>

    <section class="scene" id="services" data-object="bottle" data-scene="waterfall" data-eyebrow="{{ pages.services.en.hero.kicker | escape }}" data-title="{{ pages.services.en.hero.description | escape }}" data-desc="{{ pages.services.en.seo.description | escape }}">
      <div class="service-system">
        <div class="service-title"><span class="xp-kicker">{{ pages.services.en.hero.kicker }}</span><h2>{{ pages.services.en.hero.description }}</h2><p>Each service becomes a layer in one transformation system: training, food, natural health, and anti-aging support.</p></div>
        <div class="service-orbit"><div class="orbit-core"><b>{{ site.owner }}</b></div>{% for service in pages.services.en.services %}<article class="service-node glass"><strong>{{ service.id }}</strong><h3>{{ service.title }}</h3><p>{{ service.description }}</p>{% if service.items %}<ul>{% for item in service.items %}<li>{{ item }}</li>{% endfor %}</ul>{% endif %}</article>{% endfor %}</div>
      </div>
    </section>

    <section class="scene" data-object="dumbbell" data-scene="forest" data-eyebrow="{{ pages.home.en.pillars.kicker | escape }}" data-title="{{ pages.home.en.pillars.title | escape }}" data-desc="Training, nutrition and naturopathic support are shown as one connected method.">
      <div class="cockpit-layout">
        <div class="cockpit glass"><div class="cockpit-top"><i></i><i></i><i></i><b>BODY_DIAGNOSTIC</b></div><div class="cockpit-screen"><div class="body-radar"></div><div class="readouts">{% for item in pages.home.en.pillars.items %}<div class="readout"><span>{{ item.title }} <i>ACTIVE</i></span></div>{% endfor %}<div class="readout"><span>Weekly adjustments <i>READY</i></span></div><div class="readout"><span>Medical supervision <i>OPTIONAL</i></span></div></div></div></div>
        <div class="scene-title"><span class="xp-kicker">{{ pages.home.en.pillars.kicker }}</span><h2>{{ pages.home.en.pillars.title }}</h2>{% for item in pages.home.en.pillars.items %}<p><b>{{ item.title }}:</b> {{ item.text }}</p>{% endfor %}</div>
      </div>
    </section>

    <section class="scene" data-object="kettle" data-scene="valley" data-eyebrow="Transformation Journey" data-title="From assessment to evolution" data-desc="A clear route that turns health, training and nutrition into weekly decisions.">
      <div class="journey-river glass"><article class="journey-step glass"><span>01</span><h3>Assess</h3><p>Current level, mobility, medical case, food preferences and lifestyle load.</p></article><article class="journey-step glass"><span>02</span><h3>Build</h3><p>Training, nutrition, naturopathic guidance and support rules are combined.</p></article><article class="journey-step glass"><span>03</span><h3>Follow</h3><p>Daily or weekly check-ins keep the plan alive and adjustable.</p></article><article class="journey-step glass"><span>04</span><h3>Upgrade</h3><p>Every change in the body updates the system, so progress does not stall.</p></article></div>
    </section>

    <section class="scene" data-object="rope" data-scene="mist" data-eyebrow="{{ pages.home.en.what_you_get.kicker | escape }}" data-title="{{ pages.home.en.what_you_get.title | escape }}" data-desc="The actual deliverables are presented as a cinematic product gallery.">
      <div class="deliver-gallery">{% for item in pages.home.en.what_you_get.items %}<article class="deliver-card glass"><strong>O2F OUTPUT 0{{ loop.index }}</strong><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div>
    </section>

    <section class="scene" id="plans" data-object="dumbbell" data-scene="forest" data-eyebrow="{{ pages.home.en.plans_section.kicker | escape }}" data-title="{{ pages.home.en.plans_section.title | escape }}" data-desc="All plan data, features and pricing are arranged as levels inside one ecosystem.">
      <div class="plan-layout">
        <div class="plan-title"><span class="xp-kicker">{{ pages.home.en.plans_section.kicker }}</span><h2>{{ pages.home.en.plans_section.title }}</h2><p>Prices below use the Egypt monthly and multi-month options from your data file. Each plan keeps its own real features and CTA.</p></div>
        <div class="plan-terrain">{% for key in ["basic","standard","advanced"] %}{% set p = plans[key] %}<a class="plan-card glass" href="{{ ('/en/plans/' + p.slug + '/') | url }}"><em>{{ "Most popular" if p.highlight else "Access level" }}</em><h3>{{ p.en.name }}</h3><b>{{ p.en.tagline }}</b><p>{{ p.en.blurb }}</p><div class="price-strip"><div><span>1 month</span><strong>{{ p.pricing.egypt.m1.amount }} {{ p.pricing.egypt.m1.currency }}</strong></div><div><span>3 months</span><strong>{{ p.pricing.egypt.m3.amount }} {{ p.pricing.egypt.m3.currency }}/mo</strong></div><div><span>6 months</span><strong>{{ p.pricing.egypt.m6.amount }} {{ p.pricing.egypt.m6.currency }}/mo</strong></div></div><ul class="detail-list">{% for feature in p.en.features | slice(0,4) %}<li>{{ feature }}</li>{% endfor %}</ul><span>{{ p.en.cta }} →</span></a>{% endfor %}</div>
      </div>
    </section>

    <section class="scene" data-object="bottle" data-scene="waterfall" data-eyebrow="{{ pages.home.en.results.kicker | escape }}" data-title="{{ pages.home.en.results.title | escape }}" data-desc="Numbers are displayed as floating signals inside the same visual system.">
      <div class="proof-board">{% for item in pages.home.en.results.items %}<div class="proof-signal glass"><div><b>Signal 0{{ loop.index }}</b><strong>{{ item.value }}<small>{{ item.unit }}</small></strong><span>{{ item.text }}</span></div></div>{% endfor %}</div>
    </section>

    <section class="scene" id="contact" data-object="kettle" data-scene="valley" data-eyebrow="{{ pages.services.en.cta.title | escape }}" data-title="{{ pages.home.en.cta.title | escape }}" data-desc="{{ pages.home.en.cta.description | escape }}">
      <div class="contact-panel"><article class="contact-card glass"><span class="xp-kicker">{{ pages.home.en.cta.badge }}</span><h2>{{ pages.home.en.cta.title }}</h2><p>{{ pages.home.en.cta.description }}</p><div class="contact-actions"><a href="{{ site.googleForm }}">{{ pages.home.en.cta.button }}</a><a class="alt" href="https://wa.me/{{ site.whatsapp | replace('+','') | replace(' ','') }}">WhatsApp {{ site.whatsapp }}</a><a class="alt" href="mailto:{{ site.email }}">{{ site.email }}</a></div></article><div class="faq-cloud"><article class="faq-bubble glass"><b>Is this only training?</b><p>No. It combines training, nutrition, naturopathic guidance and ongoing follow-up.</p></article><article class="faq-bubble glass"><b>Not sure where to start?</b><p>{{ pages.services.en.cta.description }}</p></article><article class="faq-bubble glass"><b>What makes it different?</b><p>It is built around your goals, schedule, lifestyle and health status.</p></article></div></div>
    </section>
  </div>

  <section class="xp-final"><div><span class="xp-kicker">{{ pages.home.en.cta.badge }}</span><h2>{{ pages.home.en.cta.title }}</h2><p>{{ pages.home.en.cta.description }}</p><a href="{{ site.googleForm }}" class="xp-btn">{{ pages.home.en.cta.button }}</a></div></section>
</div>

<script>
(function(){
  const root=document.getElementById('o2fXp');
  const bg=document.getElementById('xpBg');
  const obj=document.getElementById('fitnessObject');
  const copy=document.getElementById('xpHeroText');
  const title=document.getElementById('stageTitle');
  const desc=document.getElementById('stageDesc');
  const eyebrow=document.getElementById('stageEyebrow');
  const scenesEls=[...document.querySelectorAll('.scene')];
  const decor=[...document.querySelectorAll('.decor')];
  if(!root||!bg||!obj||!copy||!scenesEls.length)return;
  const scenes={forest:"url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=85')",waterfall:"url('https://images.unsplash.com/photo-1432405972618-c60b0225b8f9?auto=format&fit=crop&w=2400&q=85')",valley:"url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2400&q=85')",mist:"url('https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=2400&q=85')"};
  const classes={none:'',bottle:'obj-bottle',dumbbell:'obj-dumbbell',kettle:'obj-kettle',rope:'obj-rope'};
  const html={none:'',bottle:'',dumbbell:'<span></span><i></i><span></span>',kettle:'',rope:''};
  let current='';
  function active(){let a=scenesEls[0];scenesEls.forEach(s=>{const r=s.getBoundingClientRect();if(r.top<innerHeight*.58&&r.bottom>innerHeight*.25)a=s;});return a;}
  function render(s){const type=s.dataset.object||'none';if(type!==current){obj.className='fitness-object '+(classes[type]||'');obj.innerHTML=html[type]||'';obj.classList.remove('show');copy.classList.toggle('is-product',type!=='none');requestAnimationFrame(()=>obj.classList.toggle('show',type!=='none'));current=type;}bg.style.setProperty('--scene',scenes[s.dataset.scene]||scenes.forest);title.textContent=s.dataset.title||title.textContent;desc.textContent=s.dataset.desc||desc.textContent;eyebrow.textContent=s.dataset.eyebrow||eyebrow.textContent;}
  function update(){const r=root.getBoundingClientRect();const p=Math.max(0,Math.min(1,(-r.top)/(r.height-innerHeight||1)));bg.style.setProperty('--px',`${Math.sin(p*5.6)*24}px`);bg.style.setProperty('--py',`${-p*135}px`);obj.style.setProperty('--ox',`${Math.sin(p*8)*26}px`);obj.style.setProperty('--oy',`${Math.cos(p*5)*-14}px`);decor.forEach((el,i)=>{el.style.transform=`translate3d(${Math.sin(p*5+i)*34}px,${Math.cos(p*4+i)*26}px,0) rotate(${p*180+i*18}deg)`;});render(active());}
  let ticking=false;function request(){if(!ticking){requestAnimationFrame(()=>{update();ticking=false});ticking=true}}
  update();addEventListener('scroll',request,{passive:true});addEventListener('resize',request);
})();
</script>
