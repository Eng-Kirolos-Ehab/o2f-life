d:radial-gradient(circle,rgba(166,255,152,.35),rgba(255,255,255,.12));border:1px solid rgba(255,255,255,.28);box-shadow:0 0 70px rgba(114,211,107,.18)}.orbit-core b{font-size:2.3rem;letter-spacing:-.08em}.orbit-item{position:absolute;width:240px;padding:1.05rem;border-radius:28px}.orbit-item h3,.detail-panel h3,.plan-island h3,.faq-bubble b{margin:.25rem 0 .45rem;font-size:1.25rem}.orbit-item p,.detail-panel p,.plan-island p,.faq-bubble p{margin:0;color:rgba(255,255,255,.74);line-height:1.65;font-size:.94rem}.orbit-item strong,.detail-panel strong,.plan-island em{display:block;color:#a6ff98;font-size:.72rem;letter-spacing:.13em}.orbit-item:nth-child(2){left:0;top:8%}.orbit-item:nth-child(3){right:0;top:16%}.orbit-item:nth-child(4){left:8%;bottom:9%}.orbit-item:nth-child(5){right:6%;bottom:5%}.diagnostic-cockpit{display:grid;grid-template-columns:1fr minmax(340px,520px);gap:clamp(1rem,5vw,5rem);align-items:center}.cockpit{padding:1rem;border-radius:36px}.cockpit-top{height:48px;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid rgba(255,255,255,.16);margin:-1rem -1rem 1rem;padding:0 1rem}.cockpit-top i{width:10px;height:10px;border-radius:50%;background:#a6ff98}.cockpit-screen{display:grid;grid-template-columns:1.2fr .8fr;gap:1rem}.body-radar{min-height:380px;border-radius:26px;background:radial-gradient(circle at 50% 50%,rgba(166,255,152,.28),transparent 14%),repeating-radial-gradient(circle at 50% 50%,rgba(255,255,255,.18) 0 1px,transparent 1px 44px);position:relative}.body-radar:after{content:"";position:absolute;left:50%;top:50%;width:2px;height:46%;background:linear-gradient(#a6ff98,transparent);transform-origin:bottom;animation:sweep 5s linear infinite}.readouts{display:grid;gap:.75rem}.readout{padding:.9rem;border-radius:20px;background:rgba(255,255,255,.12)}.readout span{display:flex;justify-content:space-between;gap:1rem;color:rgba(255,255,255,.78);font-size:.9rem}.readout i{font-style:normal;color:#a6ff98;font-weight:950}.river-journey{position:relative;min-height:760px;padding:2rem}.river-path{position:absolute;inset:8% 4%;border-radius:50%;border:2px solid transparent;background:linear-gradient(120deg,transparent,#a6ff98,transparent) border-box;mask:linear-gradient(#000 0 0) padding-box,linear-gradient(#000 0 0);opacity:.5}.journey-step{position:absolute;width:min(310px,40vw);padding:1.1rem;border-radius:28px}.journey-step span{width:44px;height:44px;display:grid;place-items:center;border-radius:50%;background:rgba(166,255,152,.22);font-weight:950;margin-bottom:.8rem}.journey-step:nth-child(2){left:3%;top:9%}.journey-step:nth-child(3){right:7%;top:20%}.journey-step:nth-child(4){left:14%;bottom:18%}.journey-step:nth-child(5){right:5%;bottom:6%}.deliver-gallery{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.detail-panel{min-height:230px;padding:1.25rem;border-radius:32px;position:relative;overflow:hidden}.detail-panel:nth-child(1){grid-row:span 2;min-height:480px}.detail-panel:before{content:"";position:absolute;inset:auto -20% -35% 30%;height:70%;border-radius:50%;background:rgba(166,255,152,.16)}.plan-ecosystem{display:grid;grid-template-columns:minmax(320px,430px) 1fr;gap:clamp(1rem,5vw,5rem);align-items:center}.plan-terrain{position:relative;min-height:640px}.plan-island{position:absolute;width:32%;min-width:230px;padding:1.25rem;border-radius:34px;text-decoration:none;color:#fff;transition:.25s ease}.plan-island:hover{transform:translateY(-10px) rotate(0deg)!important;background:rgba(255,255,255,.2)}.plan-island:nth-child(1){left:0;bottom:8%;transform:rotate(-5deg)}.plan-island:nth-child(2){left:34%;top:10%;transform:rotate(3deg);min-height:310px;background:rgba(166,255,152,.18)}.plan-island:nth-child(3){right:0;bottom:18%;transform:rotate(5deg)}.plan-island span{display:block;margin-top:1rem;font-weight:950}.faq-cloud{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.faq-bubble{padding:1.25rem;border-radius:42px 42px 42px 16px}.final-cta{position:relative;z-index:4;min-height:85vh;display:grid;place-items:center;text-align:center;padding:5rem 1rem;background:linear-gradient(180deg,rgba(6,17,13,0),#06110d 30%,#06110d)}.final-cta h2{font-size:clamp(2.8rem,8vw,7rem);line-height:.86;letter-spacing:-.08em;margin:0;color:#fff}.final-cta p{max-width:680px;color:rgba(255,255,255,.74);line-height:1.8}@media(max-width:1050px){.intro-layout,.service-orbit,.diagnostic-cockpit,.plan-ecosystem{grid-template-columns:1fr}.signal-board,.orbit-map,.plan-terrain{min-height:auto;display:grid;grid-template-columns:1fr 1fr;gap:1rem}.signal,.orbit-item,.plan-island,.journey-step{position:relative;left:auto!important;right:auto!important;top:auto!important;bottom:auto!important;width:auto;transform:none!important}.orbit-map:before,.orbit-map:after,.signal-board:before,.river-path{display:none}.orbit-core{position:relative;left:auto;top:auto;transform:none;width:auto;height:auto;border-radius:32px}.river-journey{min-height:auto;display:grid;gap:1rem;padding:0}.deliver-gallery,.faq-cloud{grid-template-columns:1fr 1fr}.detail-panel:nth-child(1){grid-row:auto;min-height:230px}.obj-bottle{transform:scale(.74)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.72)}}@media(max-width:700px){.nav-links a:not(:last-child){display:none}.hero-copy h1{font-size:clamp(3rem,16vw,6rem)}.hero-copy{padding:6rem 1rem 3rem}.signal-board,.orbit-map,.plan-terrain,.deliver-gallery,.faq-cloud,.cockpit-screen{grid-template-columns:1fr}.obj-bottle{transform:scale(.58)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.56)}}@media(prefers-reduced-motion:reduce){.nature-bg,.fitness-object,.hero-copy,.decor,.orbit-map:before,.orbit-map:after,.body-radar:after{transition:none!important;animation:none!important}}
@keyframes slowSpin{to{transform:rotate(360deg)}}@keyframes sweep{to{transform:rotate(360deg)}}
</style>

<div class="o2f-art" id="o2fArt">
  <div class="fixed-world">
    <div class="nature-bg" id="natureBg"></div>
    <div class="motion-decor" aria-hidden="true"><span class="decor orb"></span><span class="decor ring"></span><span class="decor leaf"></span><span class="decor line"></span><span class="decor orb"></span><span class="decor ring"></span></div>
    <div class="top-nav"><a href="{{ '/en/' | url }}" class="brand"><i></i><span>O2F.life</span></a><nav class="nav-links"><a href="#services">Services</a><a href="#journey">Journey</a><a href="#plans">Plans</a><a href="{{ '/en/contact/' | url }}">Start Now</a></nav></div>
    <div class="hero-copy" id="heroCopy"><div><small id="stageEyebrow">O2F / Nature Performance</small><h1 id="stageTitle">Hydration, Strength, Recovery</h1><p id="stageDesc">A calm cinematic system for training, nutrition, follow-up and natural health direction.</p><a href="{{ '/en/plans/' | url }}">Launch protocol</a></div></div>
    <div class="product-layer"><div class="fitness-object obj-bottle" id="fitnessObject"></div></div>
  </div>

  <div class="content-track">
    <section class="scene" data-object="none" data-scene="forest" data-eyebrow="O2F / Nature Performance" data-title="Hydration, Strength, Recovery" data-desc="{{ pages.home.en.hero.description | escape }}">
      <div class="intro-layout">
        <article class="intro-card glass"><span class="kicker">The Idea</span><h2>A living health system, not a normal landing page.</h2><p>بدل ما نرمي معلومات في كروت، الصفحة بتعرض O2F كرحلة: جسم بيتقاس، خدمات بتدور حوالين الهدف، وخطط بتطلع كمستويات داخل نفس النظام.</p></article>
        <div class="signal-board"><div class="signal glass"><div><strong>{{ site.stats.years }}</strong><span>Experience</span></div></div><div class="signal glass"><div><strong>{{ site.stats.clients }}</strong><span>Clients</span></div></div><div class="signal glass"><div><strong>{{ site.stats.custom }}</strong><span>Custom Plans</span></div></div></div>
      </div>
    </section>

    <section class="scene" id="services" data-object="bottle" data-scene="waterfall" data-eyebrow="Service Orbit" data-title="Services move around one clear goal" data-desc="Training, nutrition, follow-up and recovery are shown as connected layers, not separate cards.">
      <div class="service-orbit">
        <div class="section-title"><span class="kicker">Service Orbit</span><h2>Every service rotates around the transformation goal.</h2><p>الخدمات مش boxes؛ هي طبقات حوالين مركز واحد: جسم أفضل، التزام أوضح، ونتيجة قابلة للمتابعة.</p></div>
        <div class="orbit-map"><div class="orbit-core"><b>O2F System</b></div>{% for item in pages.home.en.pillars.items %}<article class="orbit-item glass"><strong>ORBIT_0{{ loop.index }}</strong><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div>
      </div>
    </section>

    <section class="scene" data-object="dumbbell" data-scene="forest" data-eyebrow="Body Cockpit" data-title="The body is read before the plan is built" data-desc="The page presents diagnosis like a calm performance cockpit, matching the premium motion language.">
      <div class="diagnostic-cockpit">
        <div class="cockpit glass"><div class="cockpit-top"><i></i><i></i><i></i><b>BODY_DIAGNOSTIC</b></div><div class="cockpit-screen"><div class="body-radar"></div><div class="readouts"><div class="readout"><span>Lifestyle load <i>SCANNING</i></span></div><div class="readout"><span>Nutrition gaps <i>DETECTED</i></span></div><div class="readout"><span>Training capacity <i>READY</i></span></div><div class="readout"><span>Recovery signal <i>MONITOR</i></span></div><div class="readout"><span>Adherence risk <i>CALC</i></span></div></div></div></div>
        <div class="section-title"><span class="kicker">Diagnostics</span><h2>Before pushing harder, the system understands the body.</h2><p>O2F studies patterns, habits, training capacity and recovery signal so the plan feels personal and practical.</p></div>
      </div>
    </section>

    <section class="scene" id="journey" data-object="kettle" data-scene="valley" data-eyebrow="Journey River" data-title="A natural path from assessment to evolution" data-desc="The process is shown as a flowing route instead of four repeated boxes.">
      <div class="river-journey glass"><div class="river-path"></div><article class="journey-step glass"><span>01</span><h3>Diagnose</h3><p>Analyze the current body, habits and target.</p></article><article class="journey-step glass"><span>02</span><h3>Encode</h3><p>Build training and nutrition rules into one plan.</p></article><article class="journey-step glass"><span>03</span><h3>Execute</h3><p>Follow weekly commands with clarity.</p></article><article class="journey-step glass"><span>04</span><h3>Evolve</h3><p>Update the system as your body responds.</p></article></div>
    </section>

    <section class="scene" data-object="rope" data-scene="mist" data-eyebrow="Deliverables Gallery" data-title="Useful outputs, arranged like a premium product gallery" data-desc="Plans, food structure and follow-up are displayed with hierarchy, not identical cards.">
      <div class="deliver-gallery">{% for item in pages.home.en.what_you_get.items %}<article class="detail-panel glass"><strong>OUTPUT_0{{ loop.index }}</strong><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div>
    </section>

    <section class="scene" id="plans" data-object="dumbbell" data-scene="forest" data-eyebrow="Plan Ecosystem" data-title="Choose your level inside the same system" data-desc="Plans are displayed like natural terrain levels, each with its own height and importance.">
      <div class="plan-ecosystem">
        <div class="section-title"><span class="kicker">Plan Ecosystem</span><h2>Plans should feel like levels, not pricing boxes.</h2><p>كل خطة ليها مكان وشخصية داخل النظام: بداية، تطور، أو متابعة مكثفة.</p></div>
        <div class="plan-terrain">{% for key in ["basic","standard","advanced"] %}{% set p = plans[key] %}<a class="plan-island glass" href="{{ ('/en/plans/' + p.slug + '/') | url }}"><em>{{ "RECOMMENDED" if p.highlight else "ACCESS" }}</em><h3>{{ p.en.name }}</h3><b>{{ p.en.tagline }}</b><p>{{ p.en.blurb }}</p><span>Enter mode →</span></a>{% endfor %}</div>
      </div>
    </section>

    <section class="scene" data-object="bottle" data-scene="waterfall" data-eyebrow="Proof Signals" data-title="Progress becomes visible through signals" data-desc="Metrics appear as floating signals rather than a normal statistics row.">
      <div class="signal-board">{% for item in pages.home.en.results.items %}<div class="signal glass"><div><strong>{{ item.value }}<small>{{ item.unit }}</small></strong><span>{{ item.text }}</span></div></div>{% endfor %}</div>
    </section>

    <section class="scene" data-object="kettle" data-scene="valley" data-eyebrow="Questions" data-title="Before activation, remove friction" data-desc="The FAQ is shown as soft bubbles, keeping the organic visual language.">
      <div class="faq-cloud"><article class="faq-bubble glass"><b>Is this only training?</b><p>No. It combines training, nutrition, follow-up and natural health direction.</p></article><article class="faq-bubble glass"><b>Do I need gym experience?</b><p>No. The system scales based on your current level and routine.</p></article><article class="faq-bubble glass"><b>What makes it different?</b><p>The difference is structure: assessment, protocol, execution and calibration.</p></article></div>
    </section>
  </div>

  <section class="final-cta"><div><h2>Your next version needs a calm system.</h2><p>{{ pages.home.en.cta.description }}</p><a href="{{ '/en/contact/' | url }}">Activate transformation</a></div></section>
</div>

<script>
(function(){
  const root=document.getElementById('o2fArt');
  const bg=document.getElementById('natureBg');
  const obj=document.getElementById('fitnessObject');
  const copy=document.getElementById('heroCopy');
  const title=document.getElementById('stageTitle');
  const desc=document.getElementById('stageDesc');
  const eyebrow=document.getElementById('stageEyebrow');
  const scenesEls=[...document.querySelectorAll('.scene')];
  const decor=[...document.querySelectorAll('.decor')];
  if(!root||!bg||!obj||!copy||!scenesEls.length)return;
  const scenes={forest:"url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=85')",waterfall:"url('https://images.unsplash.com/photo-1432405972618-c60b0225b8f9?auto=format&fit=crop&w=2400&q=85')",valley:"url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2400&q=85')",mist:"url('https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=2400&q=85')"};
  const classes={none:'',bottle:'obj-bottle',dumbbell:'obj-dumbbell',kettle:'obj-kettle',rope:'obj-rope'};
  const html={none:'',bottle:'',dumbbell:'<span></span><i></i><span></span>',kettle:'',rope:''};
  let current='';
  function active(){let a=scenesEls[0];scenesEls.forEach(s=>{const r=s.getBoundingClientRect();if(r.top<innerHeight*.58&&r.bottom>innerHeight*.25)a=s;});return a;}
  function render(s){const type=s.dataset.object||'none';if(type!==current){obj.className='fitness-object '+(classes[type]||'');obj.innerHTML=html[type]||'';obj.classList.remove('show');copy.classList.toggle('is-product',type!=='none');requestAnimationFrame(()=>obj.classList.toggle('show',type!=='none'));current=type;}bg.style.setProperty('--scene',scenes[s.dataset.scene]||scenes.forest);title.textContent=s.dataset.title||title.textContent;desc.textContent=s.dataset.desc||desc.textContent;eyebrow.textContent=s.dataset.eyebrow||eyebrow.textContent;}
  function update(){const r=root.getBoundingClientRect();const p=Math.max(0,Math.min(1,(-r.top)/(r.height-innerHeight||1)));bg.style.setProperty('--px',`${Math.sin(p*5.6)*24}px`);bg.style.setProperty('--py',`${-p*130}px`);obj.style.setProperty('--ox',`${Math.sin(p*8)*26}px`);obj.style.setProperty('--oy',`${Math.cos(p*5)*-14}px`);decor.forEach((el,i)=>{el.style.transform=`translate3d(${Math.sin(p*5+i)*34}px,${Math.cos(p*4+i)*26}px,0) rotate(${p*180+i*18}deg)`;});render(active());}
  let ticking=false;function request(){if(!ticking){requestAnimationFrame(()=>{update();ticking=false});ticking=true}}
  update();addEventListener('scroll',request,{passive:true});addEventListener('resize',request);
})();
</script>
