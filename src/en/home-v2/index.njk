t:48px;transform:rotate(20deg)}.rope:after{right:48px;transform:rotate(-20deg)}.hv-main{position:relative;z-index:10}.scene{min-height:100vh;padding:13vh clamp(18px,5vw,76px);display:grid;align-items:center;position:relative}.scene:before{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(180deg,rgba(6,17,13,.04),rgba(6,17,13,.2))}.hero{text-align:center}.kicker{color:var(--lime);font-size:12px;font-weight:950;letter-spacing:.18em;text-transform:uppercase}h1{font-size:clamp(54px,9vw,140px);line-height:.82;letter-spacing:-.09em;max-width:1200px;margin:16px auto;text-shadow:0 22px 70px rgba(0,0,0,.42)}h2{font-size:clamp(34px,5vw,78px);line-height:.9;letter-spacing:-.07em;margin:12px 0 16px}h3{font-size:22px;margin:8px 0}p,li{color:rgba(247,255,247,.8);line-height:1.72}.hero p{max-width:760px;margin:0 auto 24px}.glass{border:1px solid rgba(255,255,255,.24);background:linear-gradient(135deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(24px);box-shadow:0 30px 90px rgba(0,0,0,.24);border-radius:34px}.panel,.card,.plan,.bubble{padding:24px}.split,.services,.diagnostic,.plans,.contact{display:grid;grid-template-columns:minmax(310px,440px) 1fr;gap:clamp(18px,5vw,70px);align-items:center}.photo{position:relative;min-height:620px;overflow:hidden}.photo img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.photo:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent,rgba(0,0,0,.58))}.stats{position:absolute;z-index:2;left:18px;right:18px;bottom:18px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.stats span{background:rgba(255,255,255,.14);border-radius:18px;padding:12px;text-align:center;backdrop-filter:blur(12px);font-weight:950}.orbit{position:relative;min-height:670px}.orbit:before,.orbit:after{content:"";position:absolute;inset:7%;border:1px solid rgba(255,255,255,.22);border-radius:50%;animation:spin 32s linear infinite}.orbit:after{inset:20%;animation-direction:reverse;animation-duration:20s}.core{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:210px;height:210px;border-radius:50%;display:grid;place-items:center;text-align:center;background:rgba(168,255,120,.18)}.node{position:absolute;width:270px}.node:nth-child(2){left:0;top:5%}.node:nth-child(3){right:0;top:14%}.node:nth-child(4){left:8%;bottom:8%}.node:nth-child(5){right:5%;bottom:4%}.radar{min-height:420px;background:radial-gradient(circle at 50% 50%,rgba(168,255,120,.28),transparent 14%),repeating-radial-gradient(circle at 50% 50%,rgba(255,255,255,.18) 0 1px,transparent 1px 44px);position:relative;overflow:hidden}.radar:after{content:"";position:absolute;left:50%;top:50%;width:2px;height:46%;background:linear-gradient(var(--lime),transparent);transform-origin:bottom;animation:sweep 5s linear infinite}.readouts{display:grid;gap:10px}.readout{padding:14px;border-radius:18px;background:rgba(255,255,255,.12)}.journey{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.step span{width:44px;height:44px;border-radius:50%;display:grid;place-items:center;background:rgba(168,255,120,.22);font-weight:950}.gallery{display:grid;grid-template-columns:1.2fr .8fr .8fr;gap:14px}.gallery .card:first-child{grid-row:span 2}.gallery .card:nth-child(4){grid-column:span 2}.terrain{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.plan{color:#fff;text-decoration:none}.plan:nth-child(2){background:rgba(168,255,120,.18)}.price div{display:flex;justify-content:space-between;border-radius:14px;background:rgba(255,255,255,.12);padding:10px;margin:8px 0}.features{padding:0;list-style:none}.features li{padding-left:14px;position:relative}.features li:before{content:"";position:absolute;left:0;top:.7em;width:5px;height:5px;border-radius:50%;background:var(--lime)}.proof{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.signal{border-radius:50%;aspect-ratio:1;display:grid;place-items:center;text-align:center}.signal strong{display:block;font-size:clamp(42px,6vw,78px);color:var(--lime);line-height:.85}.faq{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}@media(max-width:1050px){.split,.services,.diagnostic,.plans,.contact,.journey,.terrain,.proof,.faq,.gallery{grid-template-columns:1fr}.orbit{min-height:auto;display:grid;gap:14px}.orbit:before,.orbit:after{display:none}.core,.node{position:relative;left:auto!important;right:auto!important;top:auto!important;bottom:auto!important;transform:none!important;width:auto}.stats{grid-template-columns:1fr 1fr}.gym.show{--s:.62}}@media(max-width:720px){.hv-links a:not(:last-child){display:none}h1{font-size:clamp(48px,16vw,82px)}.photo{min-height:460px}.gym.show{--s:.45;opacity:.45}}@keyframes spin{to{transform:rotate(360deg)}}@keyframes sweep{to{transform:rotate(360deg)}}
