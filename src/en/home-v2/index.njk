---
title: "O2F Home V2"
description: "Stable cinematic home v2."
permalink: /en/home-v2/index.html
---
<style>
.safev2{background:#06110d;color:#fff;font-family:Inter,system-ui,sans-serif;overflow:hidden}.safev2:before{content:"";position:fixed;inset:0;background:linear-gradient(90deg,rgba(0,0,0,.78),rgba(0,0,0,.2),rgba(0,0,0,.68)),url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1800&q=80') center/cover;z-index:0}.safev2>*{position:relative;z-index:1}.safev2 .nav{position:fixed;z-index:5;left:4vw;right:4vw;top:28px;display:flex;justify-content:space-between}.safev2 a{color:#fff;text-decoration:none;font-weight:800}.safev2 .brand{display:flex;gap:10px;align-items:center}.safev2 img{width:42px;height:42px;border-radius:50%;object-fit:cover}.safev2 section{min-height:100vh;padding:120px 6vw;display:grid;align-items:center}.safev2 .hero{text-align:center}.safev2 h1{font-size:clamp(50px,9vw,130px);line-height:.85;letter-spacing:-.08em;margin:14px auto;max-width:1100px}.safev2 h2{font-size:clamp(34px,5vw,76px);line-height:.9;letter-spacing:-.06em;margin:10px 0}.safev2 p{color:rgba(255,255,255,.8);line-height:1.75}.safev2 .k{color:#a8ff78;font-size:12px;font-weight:900;letter-spacing:.16em;text-transform:uppercase}.safev2 .btn{display:inline-flex;margin-top:22px;border:1px solid rgba(255,255,255,.7);border-radius:999px;padding:14px 22px;background:rgba(255,255,255,.1);backdrop-filter:blur(12px)}.safev2 .grid{display:grid;grid-template-columns:minmax(300px,430px) 1fr;gap:38px;align-items:center}.safev2 .glass{border:1px solid rgba(255,255,255,.24);background:rgba(255,255,255,.14);backdrop-filter:blur(18px);border-radius:30px;padding:24px;box-shadow:0 25px 70px rgba(0,0,0,.25)}.safev2 .cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.safev2 .plans{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.safev2 .plans .glass:nth-child(2){background:rgba(168,255,120,.18)}.safev2 .float{position:fixed;right:8vw;bottom:10vh;width:140px;height:140px;border-radius:38px;background:linear-gradient(135deg,rgba(255,255,255,.5),rgba(168,255,120,.2));animation:f 5s ease-in-out infinite;z-index:1}@keyframes f{50%{transform:translateY(-28px) rotate(8deg)}}@media(max-width:850px){.safev2 .grid,.safev2 .cards,.safev2 .plans{grid-template-columns:1fr}.safev2 .nav{left:18px;right:18px}.safev2 .float{opacity:.4}}
</style>
<div class="safev2"><div class="float"></div><header class="nav"><a class="brand" href="{{ '/en/' | url }}"><img src="{{ site.logoUrl | url }}" alt="{{ site.name }}"><span>{{ site.name }}</span></a><a href="{{ site.googleForm }}">Start Now</a></header><main><section class="hero"><div><span class="k">{{ pages.home.en.hero.badge }}</span><h1>{{ pages.home.en.hero.title_line1 }} {{ pages.home.en.hero.title_line2_gradient }}</h1><p>{{ pages.home.en.hero.description }}</p><a class="btn" href="{{ site.googleForm }}">{{ pages.home.en.hero.cta_primary }}</a></div></section><section><div class="grid"><article class="glass"><span class="k">System</span><h2>{{ pages.home.en.pillars.title }}</h2><p>{{ pages.home.en.seo.description }}</p></article><div class="cards">{% for service in pages.services.en.services %}<article class="glass"><span class="k">{{ service.id }}</span><h3>{{ service.title }}</h3><p>{{ service.description }}</p></article>{% endfor %}</div></div></section><section><div><span class="k">{{ pages.home.en.what_you_get.kicker }}</span><h2>{{ pages.home.en.what_you_get.title }}</h2><div class="cards">{% for item in pages.home.en.what_you_get.items %}<article class="glass"><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div></div></section><section><div><span class="k">{{ pages.home.en.plans_section.kicker }}</span><h2>{{ pages.home.en.plans_section.title }}</h2><div class="plans">{% for key in ["basic","standard","advanced"] %}{% set p=plans[key] %}<a class="glass" href="{{ ('/en/plans/' + p.slug + '/') | url }}"><h3>{{ p.en.name }}</h3><p>{{ p.en.blurb }}</p><b>{{ p.pricing.egypt.m1.amount }} {{ p.pricing.egypt.m1.currency }}</b></a>{% endfor %}</div></div></section></main></div>
