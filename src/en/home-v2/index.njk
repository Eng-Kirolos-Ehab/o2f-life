<style>
.o2f-cinema{--green:#72d36b;--mint:#00d9a3;--deep:#06110d;--ink:#f7fff7;--muted:rgba(247,255,247,.76);--glass:rgba(255,255,255,.14);min-height:100vh;background:#06110d;color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow:hidden}.o2f-cinema *{box-sizing:border-box}.cinema-shell{position:sticky;top:0;z-index:2;height:100vh;overflow:hidden;background:#06110d}.cinema-bg{position:absolute;inset:-12%;background-image:var(--scene,url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=85'));background-size:cover;background-position:center;filter:saturate(.98) contrast(1.04);transform:translate3d(var(--px,0),var(--py,0),0) scale(1.08);transition:background-image .65s ease,transform .18s linear}.cinema-shell:before{content:"";position:absolute;inset:0;z-index:1;background:radial-gradient(circle at 50% 45%,rgba(255,255,255,.16),transparent 25%),linear-gradient(90deg,rgba(0,0,0,.66),rgba(0,0,0,.2) 46%,rgba(0,0,0,.52)),linear-gradient(180deg,rgba(0,0,0,.16),rgba(2,14,9,.68));pointer-events:none}.cinema-shell:after{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(120deg,transparent 0 18%,rgba(255,255,255,.13) 22%,transparent 30% 68%,rgba(114,211,107,.1) 73%,transparent 82%);mix-blend-mode:screen;opacity:.85}.cinema-top{position:absolute;left:clamp(1rem,4vw,4.5rem);right:clamp(1rem,4vw,4.5rem);top:clamp(1rem,3vw,2.5rem);z-index:9;display:flex;align-items:center;justify-content:space-between;gap:1rem}.cinema-logo{display:inline-flex;align-items:center;gap:.65rem;color:#fff;text-decoration:none;font-weight:950;letter-spacing:-.04em}.cinema-logo i{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--mint),var(--green));box-shadow:0 0 34px rgba(0,217,163,.35)}.cinema-menu{display:flex;gap:1rem;align-items:center}.cinema-menu a{color:rgba(255,255,255,.82);text-decoration:none;font-size:.82rem;font-weight:850}.cinema-pill{border:1px solid rgba(255,255,255,.58);border-radius:999px;padding:.62rem 1.05rem!important;color:#fff!important;background:rgba(255,255,255,.08);backdrop-filter:blur(14px)}.cinema-copy{position:absolute;inset:0;z-index:5;display:grid;place-items:center;text-align:center;padding:7rem clamp(1.2rem,5vw,5rem) 4rem;color:#fff;transition:opacity .35s ease,transform .35s ease}.cinema-copy.is-product{opacity:.08;transform:translateY(-42px) scale(.92)}.cinema-copy small{display:inline-block;margin-bottom:1rem;font-size:.78rem;font-weight:950;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.82)}.cinema-title{font-size:clamp(3.2rem,9vw,9.4rem);line-height:.82;letter-spacing:-.09em;max-width:1180px;margin:0;text-wrap:balance;text-shadow:0 22px 70px rgba(0,0,0,.42)}.cinema-desc{max-width:660px;margin:1.35rem auto 1.8rem;color:rgba(255,255,255,.84);line-height:1.7;font-size:clamp(1rem,1.4vw,1.18rem)}.cinema-cta{display:inline-flex;align-items:center;justify-content:center;min-width:150px;border:1px solid rgba(255,255,255,.78);border-radius:999px;padding:.86rem 1.35rem;color:#fff;text-decoration:none;font-size:.86rem;font-weight:950;background:rgba(0,0,0,.06);backdrop-filter:blur(14px)}.motion-decor{position:absolute;inset:0;z-index:4;pointer-events:none;overflow:hidden}.decor-orb,.decor-ring,.decor-leaf,.decor-line{position:absolute;will-change:transform;opacity:.75}.decor-orb{width:140px;height:140px;border-radius:999px;background:radial-gradient(circle at 32% 24%,rgba(255,255,255,.9),rgba(114,211,107,.28) 32%,rgba(0,0,0,.06) 70%);filter:blur(.2px);animation:floatDecor 12s ease-in-out infinite}.decor-ring{width:180px;height:180px;border:2px solid rgba(255,255,255,.22);border-radius:50%;box-shadow:0 0 45px rgba(114,211,107,.12);animation:spinDecor 26s linear infinite}.decor-leaf{width:76px;height:32px;border-radius:80% 0 80% 0;background:linear-gradient(135deg,rgba(255,255,255,.8),rgba(114,211,107,.45));transform:rotate(-28deg);animation:leafDrift 16s ease-in-out infinite}.decor-line{width:260px;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.55),transparent);animation:lineMove 9s ease-in-out infinite}.decor-orb.one{left:8vw;top:24vh}.decor-ring.two{right:9vw;top:16vh}.decor-leaf.three{left:18vw;bottom:18vh}.decor-line.four{right:18vw;bottom:25vh}.decor-orb.five{right:22vw;bottom:10vh;width:90px;height:90px;animation-delay:-6s}.decor-ring.six{left:38vw;top:68vh;width:96px;height:96px;animation-delay:-10s}.product-layer{position:absolute;inset:0;z-index:6;display:grid;place-items:center;pointer-events:none;perspective:1200px}.fitness-object{position:relative;opacity:0;transform:translate3d(0,80px,0) rotate(-10deg) scale(.65);transition:opacity .45s ease,transform .75s cubic-bezier(.2,.9,.2,1);filter:drop-shadow(0 36px 34px rgba(0,0,0,.36))}.fitness-object.show{opacity:1;transform:translate3d(var(--ox,0),var(--oy,0),0) rotate(var(--r,-8deg)) scale(var(--s,1))}.obj-bottle{width:115px;height:330px;border-radius:52px 52px 58px 58px;background:linear-gradient(90deg,#276d33,#75d35e 36%,#d9ffd0 48%,#5bbb4c 58%,#1d6a34);box-shadow:inset 18px 0 34px rgba(255,255,255,.2),inset -20px 0 34px rgba(0,0,0,.22)}.obj-bottle:before{content:"";position:absolute;left:31px;right:31px;top:-43px;height:50px;border-radius:18px 18px 9px 9px;background:linear-gradient(90deg,#101816,#2f3530,#111);box-shadow:0 8px 0 rgba(255,255,255,.08) inset}.obj-bottle:after{content:"";position:absolute;left:29px;right:29px;top:-63px;height:62px;border:13px solid #111816;border-bottom:0;border-radius:42px 42px 0 0}.obj-dumbbell{width:370px;height:120px;display:flex;align-items:center;justify-content:space-between;--r:12deg;--s:1}.obj-dumbbell span{width:92px;height:160px;border-radius:28px;background:linear-gradient(180deg,#f2fff0,#74d46b 55%,#1d6d34);box-shadow:inset 0 0 22px rgba(255,255,255,.44),inset 0 -20px 24px rgba(0,0,0,.2)}.obj-dumbbell i{position:absolute;left:86px;right:86px;height:28px;border-radius:999px;background:linear-gradient(90deg,#14221a,#eaffdf 46%,#15351e)}.obj-kettle{width:230px;height:230px;border-radius:50% 50% 44% 44%;background:linear-gradient(135deg,#eaffdf,#78d86c 40%,#1b7337 78%);--r:-9deg;box-shadow:inset -22px -32px 40px rgba(0,0,0,.2),inset 24px 18px 34px rgba(255,255,255,.24)}.obj-kettle:before{content:"";position:absolute;left:54px;right:54px;top:-58px;height:92px;border:26px solid #1b211d;border-bottom:0;border-radius:68px 68px 0 0}.obj-rope{width:310px;height:310px;border:16px solid #78d86c;border-radius:50%;--r:22deg;background:radial-gradient(circle,transparent 55%,rgba(255,255,255,.16) 56%,transparent 62%)}.obj-rope:before,.obj-rope:after{content:"";position:absolute;width:28px;height:108px;border-radius:999px;background:#161d19;bottom:-52px}.obj-rope:before{left:50px;transform:rotate(20deg)}.obj-rope:after{right:50px;transform:rotate(-20deg)}.story-track{position:relative;z-index:3;margin-top:-100vh;padding-top:100vh}.story-panel{min-height:100vh;display:grid;align-items:center;padding:13vh clamp(1rem,6vw,5rem)}.story-panel.wide{align-items:center}.story-content{display:grid;grid-template-columns:minmax(320px,520px) minmax(360px,1fr);gap:clamp(1rem,4vw,4rem);align-items:center;width:100%}.story-panel:nth-child(even) .story-content{grid-template-columns:minmax(360px,1fr) minmax(320px,520px)}.story-panel:nth-child(even) .story-card{order:2}.story-card,.feature-card,.metric-card,.timeline-step,.faq-card,.plan-card,.diag-card{border:1px solid rgba(255,255,255,.22);border-radius:30px;background:rgba(255,255,255,.14);backdrop-filter:blur(24px);box-shadow:0 30px 90px rgba(0,0,0,.18);color:#fff}.story-card{padding:1.55rem}.story-card b,.section-kicker{display:block;color:#a6ff98;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;margin-bottom:.7rem;font-weight:950}.story-card h2{font-size:clamp(1.9rem,3.5vw,3.35rem);line-height:.94;letter-spacing:-.065em;margin:0 0 .9rem}.story-card p{margin:0;color:rgba(255,255,255,.78);line-height:1.75}.mini-grid,.feature-grid,.metric-grid,.diag-grid,.timeline-grid,.plans-grid,.faq-grid{display:grid;gap:.85rem}.mini-grid{grid-template-columns:repeat(3,1fr);margin-top:1rem}.mini-grid span{border-radius:18px;background:rgba(255,255,255,.14);padding:.76rem;text-align:center;font-weight:950;color:#fff}.feature-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.feature-card{padding:1.2rem;position:relative;overflow:hidden}.feature-card:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 15% 0,rgba(166,255,152,.18),transparent 42%);pointer-events:none}.feature-card strong,.diag-card strong,.timeline-step strong{position:relative;display:block;color:#a6ff98;font-size:.72rem;letter-spacing:.13em;margin-bottom:.65rem}.feature-card h3{position:relative;margin:.3rem 0 .5rem;font-size:1.25rem}.feature-card p,.diag-card p,.timeline-step p,.faq-card p,.plan-card p{position:relative;color:rgba(255,255,255,.76);line-height:1.65;margin:0}.diag-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.diag-card{padding:1rem}.diag-card p{display:flex;justify-content:space-between;gap:1rem}.diag-card i{font-style:normal;color:#dfffcc;font-weight:950;font-size:.72rem}.timeline-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.timeline-step{padding:1.1rem;min-height:160px}.timeline-step span{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;background:rgba(166,255,152,.2);font-weight:950;margin-bottom:1rem}.metric-grid{grid-template-columns:repeat(3,1fr)}.metric-card{text-align:center;padding:1.35rem}.metric-card strong{display:block;font-size:clamp(2.3rem,5vw,4rem);line-height:.85;letter-spacing:-.06em;color:#a6ff98}.metric-card p{color:rgba(255,255,255,.76);line-height:1.6;margin:.7rem 0 0}.plans-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.plan-card{display:flex;flex-direction:column;min-height:260px;padding:1.25rem;text-decoration:none;color:#fff;transition:.25s ease}.plan-card:hover{transform:translateY(-8px);background:rgba(255,255,255,.2)}.plan-card em{font-style:normal;color:#a6ff98;font-size:.72rem;font-weight:950;letter-spacing:.14em}.plan-card h3{font-size:1.55rem;margin:.75rem 0 .4rem}.plan-card b{color:#e6ffd9}.plan-card span{margin-top:auto;font-weight:950;color:#fff}.faq-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.faq-card{padding:1.2rem}.faq-card b{display:block;font-size:1.05rem;margin-bottom:.55rem}.final-space{position:relative;z-index:4;min-height:80vh;display:grid;place-items:center;text-align:center;padding:5rem 1rem;background:linear-gradient(180deg,rgba(6,17,13,0),#06110d 28%,#06110d)}.final-space h2{font-size:clamp(2.8rem,8vw,7rem);line-height:.86;letter-spacing:-.08em;margin:0;color:#fff}.final-space p{max-width:680px;color:rgba(255,255,255,.74);line-height:1.8}.final-space a{display:inline-flex;margin-top:1rem;border-radius:999px;background:#fff;color:#132018;text-decoration:none;padding:1rem 1.35rem;font-weight:950}@media(max-width:1050px){.story-content,.story-panel:nth-child(even) .story-content{grid-template-columns:1fr}.story-panel:nth-child(even) .story-card{order:0}.feature-grid,.diag-grid,.timeline-grid,.plans-grid,.faq-grid{grid-template-columns:1fr 1fr}.metric-grid{grid-template-columns:1fr 1fr}.story-panel{padding:12vh 1rem}.story-card{max-width:620px}.obj-bottle{transform:scale(.74)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.72)}.fitness-object.show{transform:translate3d(0,5vh,0) rotate(var(--r,-8deg)) scale(.78)}}@media(max-width:700px){.cinema-menu a:not(.cinema-pill){display:none}.cinema-title{font-size:clamp(3rem,16vw,6rem)}.cinema-copy{padding:6rem 1rem 3rem}.cinema-desc{font-size:.94rem}.feature-grid,.diag-grid,.timeline-grid,.plans-grid,.faq-grid,.metric-grid,.mini-grid{grid-template-columns:1fr}.story-card{padding:1.08rem}.obj-bottle{transform:scale(.58)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.56)}.fitness-object.show{transform:translate3d(0,7vh,0) rotate(var(--r,-8deg)) scale(.56)}.decor-orb,.decor-ring{opacity:.38}}@media(prefers-reduced-motion:reduce){.fitness-object,.cinema-bg,.cinema-copy,.decor-orb,.decor-ring,.decor-leaf,.decor-line{transition:none!important;animation:none!important}}
@keyframes floatDecor{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(26px,-34px,0) scale(1.08)}}@keyframes spinDecor{to{transform:rotate(360deg)}}@keyframes leafDrift{0%,100%{transform:translate3d(0,0,0) rotate(-28deg)}50%{transform:translate3d(40px,-28px,0) rotate(12deg)}}@keyframes lineMove{0%,100%{transform:translateX(0) rotate(-12deg);opacity:.25}50%{transform:translateX(-70px) rotate(8deg);opacity:.8}}
</style>

<div class="o2f-cinema" id="o2fCinema">
  <div class="cinema-shell" aria-hidden="false">
    <div class="cinema-bg" id="cinemaBg"></div>
    <div class="motion-decor" aria-hidden="true">
      <span class="decor-orb one"></span><span class="decor-ring two"></span><span class="decor-leaf three"></span><span class="decor-line four"></span><span class="decor-orb five"></span><span class="decor-ring six"></span>
    </div>
    <div class="cinema-top">
      <a href="{{ '/en/' | url }}" class="cinema-logo"><i></i><span>O2F.life</span></a>
      <nav class="cinema-menu"><a href="#modules">Modules</a><a href="#plans">Plans</a><a href="{{ '/en/contact/' | url }}" class="cinema-pill">Start Now</a></nav>
    </div>
    <div class="cinema-copy" id="cinemaCopy">
      <div>
        <small id="stageEyebrow">O2F / Nature Performance</small>
        <h1 class="cinema-title" id="stageTitle">Hydration, Strength, Recovery</h1>
        <p class="cinema-desc" id="stageDesc">A calm cinematic system for training, nutrition, follow-up and natural health direction.</p>
        <a href="{{ '/en/plans/' | url }}" class="cinema-cta">Launch protocol</a>
      </div>
    </div>
    <div class="product-layer"><div class="fitness-object obj-bottle" id="fitnessObject"></div></div>
  </div>

  <div class="story-track">
    <section class="story-panel wide" data-object="none" data-scene="forest" data-eyebrow="O2F / Nature Performance" data-title="Hydration, Strength, Recovery" data-desc="{{ pages.home.en.hero.description | escape }}">
      <div class="story-content">
        <div class="story-card"><b>Intro Scene</b><h2>Full-screen cinematic website.</h2><p>نفس روح الفيديو، لكن من غير فريم جهاز: الخلفية واخدة الشاشة كلها، والعناصر بتظهر فوقها كأنها product animation داخل الموقع نفسه.</p><div class="mini-grid"><span>{{ site.stats.years }}</span><span>{{ site.stats.clients }}</span><span>{{ site.stats.support }}</span></div></div>
        <div class="metric-grid"><div class="metric-card"><strong>{{ site.stats.years }}</strong><p>Coaching experience</p></div><div class="metric-card"><strong>{{ site.stats.clients }}</strong><p>Clients supported</p></div><div class="metric-card"><strong>{{ site.stats.custom }}</strong><p>Custom plans</p></div></div>
      </div>
    </section>

    <section class="story-panel wide" id="modules" data-object="bottle" data-scene="waterfall" data-eyebrow="Hydration Layer" data-title="A green bottle floats into the scene" data-desc="Hydration becomes the first visual product moment, with the object floating in front of a cinematic natural background.">
      <div class="story-content">
        <div class="story-card"><b>Object 01</b><h2>Green bottle moment.</h2><p>الزجاجة الخضرا تظهر كبيرة وواضحة في نص الشاشة، ومعاها محتوى حقيقي مش مجرد هيرو.</p></div>
        <div class="feature-grid">{% for item in pages.home.en.pillars.items %}<article class="feature-card"><strong>MODULE_0{{ loop.index }}</strong><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div>
      </div>
    </section>

    <section class="story-panel wide" data-object="dumbbell" data-scene="forest" data-eyebrow="Strength Layer" data-title="Training appears as a premium object" data-desc="The dumbbell replaces the bottle as the user scrolls, so every section has its own gym signal without breaking the same visual world.">
      <div class="story-content">
        <div class="story-card"><b>Core Structure</b><h2>Training, nutrition and follow-up.</h2><p>Each module is presented like a premium fitness product layer, while the moving background keeps the page alive.</p></div>
        <div class="diag-grid"><article class="diag-card"><strong>01</strong><p>Lifestyle load <i>SCANNING</i></p></article><article class="diag-card"><strong>02</strong><p>Nutrition gaps <i>DETECTED</i></p></article><article class="diag-card"><strong>03</strong><p>Training capacity <i>READY</i></p></article><article class="diag-card"><strong>04</strong><p>Recovery signal <i>MONITORING</i></p></article></div>
      </div>
    </section>

    <section class="story-panel wide" data-object="kettle" data-scene="valley" data-eyebrow="Power Layer" data-title="The system reads the body before it pushes" data-desc="Assessment, lifestyle load, recovery signal and adherence risk are presented with a calmer premium mood instead of a hard tech dashboard.">
      <div class="story-content">
        <div class="story-card"><b>Diagnostics</b><h2>Before the plan starts, the system reads the problem.</h2><p>O2F studies patterns, builds rules, and tracks the response so the plan stays practical and personal.</p></div>
        <div class="timeline-grid"><article class="timeline-step"><span>01</span><strong>Diagnose</strong><p>Analyze the current body, habits and target.</p></article><article class="timeline-step"><span>02</span><strong>Encode</strong><p>Build training and nutrition rules into one plan.</p></article><article class="timeline-step"><span>03</span><strong>Execute</strong><p>Follow weekly commands with clarity.</p></article><article class="timeline-step"><span>04</span><strong>Evolve</strong><p>Update the system as your body responds.</p></article></div>
      </div>
    </section>

    <section class="story-panel wide" data-object="rope" data-scene="mist" data-eyebrow="Outputs" data-title="Practical tools, not vague motivation" data-desc="Plans, weekly calibration, nutrition structure and follow-up are presented as clean product outputs.">
      <div class="story-content">
        <div class="story-card"><b>What you get</b><h2>Clear deliverables.</h2><p>The visitor sees useful outputs immediately: plans, food structure, guidance, review and calibration.</p></div>
        <div class="feature-grid">{% for item in pages.home.en.what_you_get.items %}<article class="feature-card"><strong>OUTPUT_0{{ loop.index }}</strong><h3>{{ item.title }}</h3><p>{{ item.text }}</p></article>{% endfor %}</div>
      </div>
    </section>

    <section class="story-panel wide" data-object="bottle" data-scene="waterfall" data-eyebrow="Progress Data" data-title="Progress shown like performance metrics" data-desc="The page adds numbers and visible performance signals, not only visual effects.">
      <div class="story-content">
        <div class="story-card"><b>Results</b><h2>Performance metrics.</h2><p>Use strong numbers to make the service feel measurable and reliable.</p></div>
        <div class="metric-grid">{% for item in pages.home.en.results.items %}<article class="metric-card"><strong>{{ item.value }}<small>{{ item.unit }}</small></strong><p>{{ item.text }}</p></article>{% endfor %}</div>
      </div>
    </section>

    <section class="story-panel wide" id="plans" data-object="dumbbell" data-scene="forest" data-eyebrow="Access Levels" data-title="Choose your operating mode" data-desc="Each plan becomes an access level inside the same transformation journey.">
      <div class="story-content">
        <div class="story-card"><b>Plans</b><h2>Choose your mode.</h2><p>Plans appear as clean glass cards while the cinematic gym object remains in the background.</p></div>
        <div class="plans-grid">{% for key in ["basic","standard","advanced"] %}{% set p = plans[key] %}<a class="plan-card" href="{{ ('/en/plans/' + p.slug + '/') | url }}"><em>{{ "RECOMMENDED" if p.highlight else "ACCESS" }}</em><h3>{{ p.en.name }}</h3><b>{{ p.en.tagline }}</b><p>{{ p.en.blurb }}</p><span>Enter mode →</span></a>{% endfor %}</div>
      </div>
    </section>

    <section class="story-panel wide" data-object="kettle" data-scene="valley" data-eyebrow="FAQ" data-title="Questions before activation" data-desc="The final content layer answers doubts before the visitor reaches the call to action.">
      <div class="story-content">
        <div class="story-card"><b>Common Signals</b><h2>Questions before activation.</h2><p>Quick answers keep the visitor moving without killing the cinematic experience.</p></div>
        <div class="faq-grid"><article class="faq-card"><b>Is this only training?</b><p>No. It combines training, nutrition, follow-up and natural health direction.</p></article><article class="faq-card"><b>Do I need gym experience?</b><p>No. The system scales based on your current level and routine.</p></article><article class="faq-card"><b>What makes it different?</b><p>The difference is structure: assessment, protocol, execution and calibration.</p></article></div>
      </div>
    </section>
  </div>

  <div class="final-space">
    <div><h2>Your next version needs a calm system.</h2><p>{{ pages.home.en.cta.description }}</p><a href="{{ '/en/contact/' | url }}">Activate transformation</a></div>
  </div>
</div>

<script>
(function(){
  const root=document.getElementById('o2fCinema');
  const bg=document.getElementById('cinemaBg');
  const obj=document.getElementById('fitnessObject');
  const copy=document.getElementById('cinemaCopy');
  const title=document.getElementById('stageTitle');
  const desc=document.getElementById('stageDesc');
  const eyebrow=document.getElementById('stageEyebrow');
  const panels=[...document.querySelectorAll('.story-panel')];
  const decor=[...document.querySelectorAll('.motion-decor span')];
  if(!root||!bg||!obj||!copy||!panels.length)return;
  const scenes={
    forest:"url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2400&q=85')",
    waterfall:"url('https://images.unsplash.com/photo-1432405972618-c60b0225b8f9?auto=format&fit=crop&w=2400&q=85')",
    valley:"url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2400&q=85')",
    mist:"url('https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=2400&q=85')"
  };
  const objectClasses={none:'',bottle:'obj-bottle',dumbbell:'obj-dumbbell',kettle:'obj-kettle',rope:'obj-rope'};
  const objectHTML={none:'',bottle:'',dumbbell:'<span></span><i></i><span></span>',kettle:'',rope:''};
  let current='';
  function activePanel(){let active=panels[0];panels.forEach(panel=>{const r=panel.getBoundingClientRect();if(r.top<innerHeight*.58&&r.bottom>innerHeight*.25)active=panel;});return active;}
  function render(panel){
    const object=panel.dataset.object||'none';
    if(current!==object){
      obj.className='fitness-object '+(objectClasses[object]||'');
      obj.innerHTML=objectHTML[object]||'';
      obj.classList.remove('show');
      copy.classList.toggle('is-product',object!=='none');
      requestAnimationFrame(()=>obj.classList.toggle('show',object!=='none'));
      current=object;
    }
    bg.style.setProperty('--scene',scenes[panel.dataset.scene]||scenes.forest);
    title.textContent=panel.dataset.title||title.textContent;
    desc.textContent=panel.dataset.desc||desc.textContent;
    eyebrow.textContent=panel.dataset.eyebrow||eyebrow.textContent;
  }
  function update(){
    const rootRect=root.getBoundingClientRect();
    const progress=Math.max(0,Math.min(1,(-rootRect.top)/(rootRect.height-innerHeight||1)));
    bg.style.setProperty('--px',`${Math.sin(progress*5.6)*24}px`);
    bg.style.setProperty('--py',`${-progress*130}px`);
    obj.style.setProperty('--ox',`${Math.sin(progress*8)*26}px`);
    obj.style.setProperty('--oy',`${Math.cos(progress*5)*-14}px`);
    decor.forEach((el,i)=>{el.style.transform=`translate3d(${Math.sin(progress*5+i)*34}px,${Math.cos(progress*4+i)*26}px,0) rotate(${progress*180+i*18}deg)`;});
    render(activePanel());
  }
  let ticking=false;function request(){if(!ticking){requestAnimationFrame(()=>{update();ticking=false});ticking=true}}
  update();addEventListener('scroll',request,{passive:true});addEventListener('resize',request);
})();
</script>
