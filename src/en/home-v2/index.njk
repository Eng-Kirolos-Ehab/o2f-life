)}.hero-copy small,.kicker{display:inline-block;color:#a6ff98;font-size:.75rem;font-weight:950;letter-spacing:.18em;text-transform:uppercase}.hero-copy h1{font-size:clamp(3.2rem,9vw,9.6rem);line-height:.82;letter-spacing:-.09em;max-width:1200px;margin:1rem 0;text-wrap:balance;text-shadow:0 22px 70px rgba(0,0,0,.42)}.hero-copy p{max-width:680px;margin:0 auto 1.8rem;color:rgba(255,255,255,.84);line-height:1.75;font-size:clamp(1rem,1.4vw,1.18rem)}.hero-copy a,.final-cta a{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.78);border-radius:999px;padding:.9rem 1.35rem;color:#fff;text-decoration:none;font-size:.86rem;font-weight:950;background:rgba(0,0,0,.08);backdrop-filter:blur(14px)}.motion-decor{position:absolute;inset:0;z-index:4;pointer-events:none;overflow:hidden}.decor{position:absolute;will-change:transform;opacity:.75}.decor.orb{width:140px;height:140px;border-radius:999px;background:radial-gradient(circle at 32% 24%,rgba(255,255,255,.92),rgba(114,211,107,.28) 34%,rgba(0,0,0,.04) 72%)}.decor.ring{width:190px;height:190px;border:2px solid rgba(255,255,255,.24);border-radius:50%;box-shadow:0 0 45px rgba(114,211,107,.14)}.decor.leaf{width:82px;height:34px;border-radius:80% 0 80% 0;background:linear-gradient(135deg,rgba(255,255,255,.82),rgba(114,211,107,.45));transform:rotate(-28deg)}.decor.line{width:270px;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.6),transparent)}.decor:nth-child(1){left:8vw;top:24vh}.decor:nth-child(2){right:9vw;top:16vh}.decor:nth-child(3){left:18vw;bottom:18vh}.decor:nth-child(4){right:18vw;bottom:25vh}.decor:nth-child(5){right:22vw;bottom:10vh;width:90px;height:90px}.decor:nth-child(6){left:38vw;top:68vh;width:96px;height:96px}.product-layer{position:absolute;inset:0;z-index:6;display:grid;place-items:center;pointer-events:none;perspective:1200px}.fitness-object{position:relative;opacity:0;transform:translate3d(0,80px,0) rotate(-10deg) scale(.65);transition:opacity .