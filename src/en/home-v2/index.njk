---
title: "O2F Home V2"
description: "Cinematic home v2."
permalink: /en/home-v2/index.html
---
<style>
/* ─────────────────────────────────────────
   BASE
───────────────────────────────────────── */
.o2{
  --lime:#a8ff78;
  --bg:#060c08;
  --card:rgba(255,255,255,0.05);
  --border:rgba(255,255,255,0.10);
  --muted:rgba(232,255,234,0.62);
  font-family:Inter,system-ui,-apple-system,sans-serif;
  background:var(--bg);
  color:#fff;
  overflow-x:hidden;
}
.o2 *{box-sizing:border-box;margin:0;padding:0}

/* ─────────────────────────────────────────
   NAV
───────────────────────────────────────── */
.o2-nav{
  position:fixed;z-index:200;
  top:0;left:0;right:0;
  padding:20px clamp(20px,5vw,72px);
  display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(180deg,rgba(6,12,8,0.88) 0%,transparent 100%);
  pointer-events:none;
}
.o2-nav>*{pointer-events:auto}
.o2-brand{
  display:flex;align-items:center;gap:10px;
  color:#fff;text-decoration:none;
  font-weight:900;font-size:15px;letter-spacing:-0.02em;
}
.o2-brand img{
  width:38px;height:38px;border-radius:50%;object-fit:cover;
  box-shadow:0 0 16px rgba(168,255,120,0.30);
}
.o2-links{display:flex;align-items:center;gap:22px}
.o2-links a{
  color:rgba(255,255,255,0.72);text-decoration:none;
  font-size:13px;font-weight:700;
  transition:color .2s;
}
.o2-links a:hover{color:var(--lime)}
.o2-pill{
  display:inline-flex;align-items:center;
  padding:9px 22px;border-radius:999px;
  border:1px solid rgba(255,255,255,0.32);
  background:rgba(255,255,255,0.08);
  backdrop-filter:blur(14px);
  color:#fff;text-decoration:none;
  font-weight:800;font-size:13px;
  transition:background .22s,border-color .22s;
}
.o2-pill:hover{background:rgba(168,255,120,0.16);border-color:var(--lime)}
.o2-pill.big{
  font-size:16px;padding:15px 38px;margin-top:26px;
  font-weight:900;letter-spacing:-0.01em;
}

/* ─────────────────────────────────────────
   HERO  — Ken Burns + scroll parallax
───────────────────────────────────────── */
.o2-hero{
  position:relative;
  height:100vh;min-height:600px;
  display:flex;align-items:flex-end;
  padding:0 clamp(20px,6vw,80px) clamp(56px,8vh,96px);
  overflow:hidden;
}

/* outer div: JS moves this for scroll parallax */
.o2-hero-para{
  position:absolute;inset:0;
  will-change:transform;
}

/* inner div: CSS Ken Burns plays on this */
.o2-hero-bg{
  position:absolute;
  inset:-12%;           /* extra space so zoom never reveals edges */
  background:url('{{ site.heroImage | url }}') center/cover no-repeat;
  animation:kenburns 26s cubic-bezier(0.12,0,0.50,1) forwards;
  will-change:transform;
}

@keyframes kenburns{
  0%  {transform:scale(1.22) translate(2.8%, 1.4%)}
  100%{transform:scale(1.02) translate(0%,   0%)  }
}

/* dark gradient overlay — slightly brightens at center to reveal subject */
.o2-hero-overlay{
  position:absolute;inset:0;z-index:1;
  background:
    linear-gradient(108deg,
      rgba(6,12,8,0.92) 0%,
      rgba(6,12,8,0.68) 42%,
      rgba(6,12,8,0.30) 100%),
    linear-gradient(180deg,
      rgba(6,12,8,0.10) 0%,
      rgba(6,12,8,0.90) 100%);
}

.o2-hero-content{
  position:relative;z-index:2;
  max-width:900px;
}

.o2-tag{
  display:inline-block;
  font-size:11px;font-weight:900;letter-spacing:.20em;text-transform:uppercase;
  color:var(--lime);margin-bottom:14px;
}

.o2 h1{
  font-size:clamp(60px,10vw,150px);
  line-height:.82;letter-spacing:-0.08em;font-weight:900;
}
.o2 h2{
  font-size:clamp(38px,5.5vw,84px);
  line-height:.88;letter-spacing:-0.065em;font-weight:900;
  margin-bottom:16px;
}
.o2 h3{
  font-size:clamp(16px,1.4vw,20px);
  font-weight:800;letter-spacing:-0.02em;line-height:1.3;
  margin-bottom:8px;
}
.o2 p{
  color:var(--muted);line-height:1.72;
  font-size:clamp(14px,1.05vw,16px);
}

/* staggered hero text reveal */
.hero-line{
  opacity:0;transform:translateY(22px);
  animation:heroIn .72s cubic-bezier(0.22,1,0.36,1) forwards;
}
.hero-line:nth-child(1){animation-delay:.22s}
.hero-line:nth-child(2){animation-delay:.42s}
.hero-line:nth-child(3){animation-delay:.60s}
.hero-line:nth-child(4){animation-delay:.78s}
@keyframes heroIn{to{opacity:1;transform:none}}

/* ─────────────────────────────────────────
   STAT STRIP
───────────────────────────────────────── */
.o2-strip{
  display:grid;grid-template-columns:repeat(4,1fr);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}
.o2-strip-cell{
  padding:clamp(22px,3vh,36px) clamp(20px,3vw,44px);
  border-right:1px solid var(--border);
  text-align:center;
}
.o2-strip-cell:last-child{border-right:none}
.o2-strip-cell strong{
  display:block;
  font-size:clamp(30px,3.5vw,52px);
  font-weight:900;letter-spacing:-0.04em;
  color:var(--lime);line-height:1;margin-bottom:4px;
}
.o2-strip-cell span{
  font-size:12px;color:var(--muted);font-weight:500;
}

/* ─────────────────────────────────────────
   SECTION BASE
───────────────────────────────────────── */
.o2-sec{
  padding:clamp(72px,11vh,128px) clamp(20px,6vw,80px);
  position:relative;overflow:hidden;
}
.o2-inner{width:min(1200px,100%);margin:0 auto}

.o2-split{
  display:grid;
  grid-template-columns:minmax(280px,1fr) minmax(280px,1fr);
  gap:clamp(32px,5vw,80px);
  align-items:center;
}
.o2-split.rev>:first-child{order:2}
.o2-split.rev>:last-child {order:1}

/* ─────────────────────────────────────────
   CARD
───────────────────────────────────────── */
.o2-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:20px;
  padding:28px 30px;
  transition:border-color .26s,transform .26s,box-shadow .26s;
}
.o2-card:hover{
  border-color:rgba(255,255,255,0.22);
  transform:translateY(-5px);
  box-shadow:0 22px 64px rgba(0,0,0,0.30);
}

/* ─────────────────────────────────────────
   GYM OBJECTS  (free-floating, no frames)
───────────────────────────────────────── */
.o2-obj-zone{
  position:relative;
  display:flex;align-items:center;justify-content:center;
  min-height:440px;
}
/* ambient glow */
.o2-obj-zone::before{
  content:"";
  position:absolute;
  width:360px;height:360px;border-radius:50%;
  background:radial-gradient(circle,
    var(--glow,rgba(168,255,120,0.20)) 0%,transparent 68%);
  filter:blur(12px);
  animation:glowpulse 5s ease-in-out infinite;
  pointer-events:none;
}
@keyframes glowpulse{
  0%,100%{transform:scale(1);   opacity:.60}
  50%    {transform:scale(1.22);opacity:1  }
}

.o2-obj{
  position:relative;z-index:2;
  filter:drop-shadow(0 30px 32px rgba(0,0,0,.52));
  animation:objfloat var(--dur,6s) ease-in-out infinite;
}
@keyframes objfloat{
  0%,100%{transform:rotate(var(--r,0deg)) translateY(0)   scale(1)   }
  38%    {transform:rotate(calc(var(--r,0deg)+4deg)) translateY(-26px) scale(1.03)}
  72%    {transform:rotate(calc(var(--r,0deg)-2deg)) translateY(-10px) scale(1.01)}
}

/* DUMBBELL */
.o2-dumbbell{
  width:334px;height:100px;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;--r:12deg;--dur:5.8s;
}
.o2-db-p{
  width:80px;height:138px;flex-shrink:0;border-radius:22px;
  background:linear-gradient(175deg,#eaffd8,#66c756 55%,#1a6430);
  box-shadow:inset 0 0 13px rgba(255,255,255,.28),
             inset 0 -5px 16px rgba(0,0,0,.22);
}
.o2-db-b{
  position:absolute;left:72px;right:72px;top:37px;height:24px;
  border-radius:999px;
  background:linear-gradient(90deg,#12201a,#dcffc6 46%,#142e1e);
}

/* KETTLEBELL */
.o2-kettle{
  width:208px;height:208px;border-radius:50% 50% 42% 42%;
  background:linear-gradient(135deg,#ddffc6,#6ace5a 44%,#186e2e);
  box-shadow:inset -8px -8px 24px rgba(0,0,0,.30),
             inset  8px  8px 16px rgba(255,255,255,.20);
  position:relative;--r:-10deg;--dur:7s;
}
.o2-kettle::before{
  content:"";position:absolute;
  left:46px;right:46px;top:-47px;height:78px;
  border:22px solid #181e16;border-bottom:0;
  border-radius:50px 50px 0 0;
}

/* ROPE */
.o2-rope{
  width:256px;height:256px;
  border:13px solid #6ace5a;border-radius:50%;
  box-shadow:0 0 28px rgba(168,255,120,.34),
             inset 0 0 18px rgba(0,0,0,.44);
  position:relative;--r:18deg;--dur:6.3s;
}
.o2-rope::before,.o2-rope::after{
  content:"";position:absolute;
  width:20px;height:78px;border-radius:999px;
  background:#141a16;bottom:-38px;
}
.o2-rope::before{left:36px; transform:rotate(20deg) }
.o2-rope::after {right:36px;transform:rotate(-20deg)}

/* BOTTLE */
.o2-bottle{
  width:98px;height:272px;border-radius:42px 42px 48px 48px;
  background:linear-gradient(90deg,
    #1f5a26,#59bc4c 36%,#c0febe 50%,#4aae3e 62%,#185e26);
  box-shadow:inset 13px 0 22px rgba(255,255,255,.22),
             inset -12px 0 22px rgba(0,0,0,.26);
  position:relative;--r:-8deg;--dur:6.5s;
}
.o2-bottle::before{
  content:"";position:absolute;
  left:22px;right:22px;top:-32px;height:36px;border-radius:11px;
  background:linear-gradient(90deg,#101812,#252c22);
}
.o2-bottle::after{
  content:"";position:absolute;
  left:21px;right:21px;top:-50px;height:48px;
  border:10px solid #111816;border-bottom:0;
  border-radius:32px 32px 0 0;
}

/* ─────────────────────────────────────────
   SERVICE GRID
───────────────────────────────────────── */
.o2-srv{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}

/* ─────────────────────────────────────────
   READOUTS
───────────────────────────────────────── */
.o2-reads{display:grid;gap:10px;margin-top:18px}
.o2-read{
  padding:16px 20px;border-radius:16px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.04);
  transition:background .2s,border-color .2s;
}
.o2-read:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.20)}
.o2-read b{display:block;font-size:14px;font-weight:800;margin-bottom:4px}

/* ─────────────────────────────────────────
   JOURNEY STEPS  — connecting line
───────────────────────────────────────── */
.o2-steps{
  display:grid;grid-template-columns:repeat(4,1fr);gap:12px;
  position:relative;
}
.o2-steps::before{
  content:"";
  position:absolute;top:20px;left:20px;right:20px;height:1px;
  background:linear-gradient(90deg,var(--lime),rgba(168,255,120,.25));
  z-index:0;
}
.o2-step{position:relative;z-index:1}
.o2-step-n{
  width:40px;height:40px;border-radius:50%;
  display:grid;place-items:center;
  background:var(--bg);
  border:1px solid var(--lime);
  color:var(--lime);font-weight:900;font-size:13px;
  margin-bottom:14px;
}

/* ─────────────────────────────────────────
   PLANS
───────────────────────────────────────── */
.o2-plans{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.o2-plan{text-decoration:none;color:inherit;display:block}
.o2-plan.hot{
  background:linear-gradient(148deg,rgba(168,255,120,.15),rgba(255,255,255,.04));
  border-color:rgba(168,255,120,.28);
}
.o2-plan.hot:hover{border-color:rgba(168,255,120,.52)}
.o2-prow{
  display:flex;justify-content:space-between;align-items:center;
  padding:8px 12px;border-radius:10px;
  background:rgba(255,255,255,.07);margin:6px 0;
}
.o2-prow b{color:var(--lime);font-size:14px;font-weight:800}
.o2-prow span{font-size:12px;color:var(--muted)}
.o2-feats{list-style:none;margin-top:10px}
.o2-feats li{
  padding-left:14px;position:relative;
  margin:5px 0;font-size:13px;color:var(--muted);line-height:1.5;
}
.o2-feats li::before{
  content:"";position:absolute;left:0;top:.70em;
  width:4px;height:4px;border-radius:50%;background:var(--lime);
}

/* ─────────────────────────────────────────
   PROOF SIGNALS
───────────────────────────────────────── */
.o2-proof{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.o2-sig{
  aspect-ratio:1;border-radius:50%;
  display:grid;place-items:center;text-align:center;padding:20px;
}
.o2-sig strong{
  display:block;
  font-size:clamp(44px,6vw,82px);
  color:var(--lime);line-height:.84;
  letter-spacing:-0.06em;font-weight:900;
}

/* ─────────────────────────────────────────
   FAQ
───────────────────────────────────────── */
.o2-faqs{display:grid;gap:10px}
.o2-faqs b{display:block;font-size:14px;font-weight:800;margin-bottom:6px}

/* ─────────────────────────────────────────
   SCROLL REVEAL
───────────────────────────────────────── */
.r{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.r.on{opacity:1;transform:none}
.r[d="1"]{transition-delay:.08s}
.r[d="2"]{transition-delay:.16s}
.r[d="3"]{transition-delay:.24s}
.r[d="4"]{transition-delay:.32s}

/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media(max-width:1050px){
  .o2-split,.o2-split.rev{grid-template-columns:1fr}
  .o2-split.rev>:first-child,.o2-split.rev>:last-child{order:initial}
  .o2-strip{grid-template-columns:1fr 1fr}
  .o2-steps{grid-template-columns:1fr 1fr}
  .o2-steps::before{display:none}
  .o2-plans{grid-template-columns:1fr}
  .o2-proof{grid-template-columns:1fr 1fr}
  .o2-srv{grid-template-columns:1fr}
}
@media(max-width:720px){
  .o2-links a:not(:last-child){display:none}
  .o2 h1{font-size:clamp(48px,15vw,82px)}
  .o2-strip{grid-template-columns:1fr 1fr}
  .o2-steps{grid-template-columns:1fr}
  .o2-proof{grid-template-columns:1fr}
  .o2-obj{transform:scale(.78)}
}
</style>

<div class="o2" id="o2">

<!-- ══ NAV ════════════════════════════════ -->
<header class="o2-nav">
  <a href="{{ '/en/' | url }}" class="o2-brand">
    <img src="{{ site.logoUrl | url }}" alt="{{ site.name }}">
    <span>{{ site.name }}</span>
  </a>
  <nav class="o2-links">
    <a href="#services">Services</a>
    <a href="#plans">Plans</a>
    <a href="#contact">Contact</a>
    <a href="{{ site.googleForm }}" class="o2-pill">Start Now</a>
  </nav>
</header>

<!-- ══ HERO  (real photo + Ken Burns + parallax) ══ -->
<section class="o2-hero">
  <div class="o2-hero-para" id="heroPara">
    <div class="o2-hero-bg"></div>
  </div>
  <div class="o2-hero-overlay"></div>
  <div class="o2-hero-content">
    <span class="o2-tag hero-line">{{ pages.home.en.hero.badge }}</span>
    <h1 class="hero-line">
      {{ pages.home.en.hero.title_line1 }}<br>
      {{ pages.home.en.hero.title_line2_gradient }}
    </h1>
    <p class="hero-line" style="max-width:640px;margin-top:18px;font-size:clamp(16px,1.3vw,19px);">
      {{ pages.home.en.hero.description }}
    </p>
    <a class="o2-pill big hero-line" href="{{ site.googleForm }}">
      {{ pages.home.en.hero.cta_primary }}
    </a>
  </div>
</section>

<!-- ══ STAT STRIP ══════════════════════════ -->
<div class="o2-strip">
  <div class="o2-strip-cell r"><strong>{{ site.stats.years }}</strong><span>Years experience</span></div>
  <div class="o2-strip-cell r" d="1"><strong>{{ site.stats.clients }}</strong><span>Clients transformed</span></div>
  <div class="o2-strip-cell r" d="2"><strong>{{ site.stats.custom }}</strong><span>Custom plans</span></div>
  <div class="o2-strip-cell r" d="3"><strong>{{ site.stats.support }}</strong><span>Support availability</span></div>
</div>

<!-- ══ SERVICES ════════════════════════════ -->
<section class="o2-sec" id="services">
  <div class="o2-inner">
    <div class="o2-split rev" style="margin-bottom:40px;">

      <div>
        <span class="o2-tag r">{{ pages.services.en.hero.kicker }}</span>
        <h2 class="r" d="1">{{ pages.services.en.hero.description }}</h2>
        <p class="r" d="2">{{ pages.services.en.seo.description }}</p>
      </div>

      <div class="o2-obj-zone r" d="1">
        <div class="o2-obj o2-dumbbell">
          <div class="o2-db-p"></div>
          <div class="o2-db-b"></div>
          <div class="o2-db-p"></div>
        </div>
      </div>

    </div>

    <div class="o2-srv">
      {% for service in pages.services.en.services %}
      <article class="o2-card r" d="{{ loop.index }}">
        <span class="o2-tag">{{ service.id }}</span>
        <h3 style="margin-top:10px;">{{ service.title }}</h3>
        <p style="margin-top:8px;">{{ service.description }}</p>
        {% if service.items %}
        <ul style="list-style:none;margin-top:10px;">
          {% for item in service.items %}{% if loop.index <= 3 %}
          <li style="padding-left:14px;position:relative;margin:5px 0;color:var(--muted);font-size:13px;">
            <span style="position:absolute;left:0;top:.70em;width:4px;height:4px;border-radius:50%;background:var(--lime);display:block;"></span>
            {{ item }}
          </li>
          {% endif %}{% endfor %}
        </ul>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ══ PILLARS ══════════════════════════════ -->
<section class="o2-sec" style="background:rgba(0,8,20,0.60);">
  <div class="o2-inner">
    <div class="o2-split">

      <div>
        <span class="o2-tag r">{{ pages.home.en.pillars.kicker }}</span>
        <h2 class="r" d="1">{{ pages.home.en.pillars.title }}</h2>
        <div class="o2-reads">
          {% for item in pages.home.en.pillars.items %}
          <div class="o2-read r" d="{{ loop.index }}">
            <b>{{ item.title }}</b>
            <p>{{ item.text }}</p>
          </div>
          {% endfor %}
        </div>
      </div>

      <div class="o2-obj-zone r" d="1" style="--glow:rgba(0,160,220,0.22);">
        <div class="o2-obj o2-kettle"></div>
      </div>

    </div>
  </div>
</section>

<!-- ══ JOURNEY ══════════════════════════════ -->
<section class="o2-sec">
  <div class="o2-inner">
    <div style="text-align:center;margin-bottom:44px;">
      <span class="o2-tag r">Your journey</span>
      <h2 class="r" d="1">How it works</h2>
    </div>
    <div class="o2-steps">
      <article class="o2-step o2-card r" d="1">
        <div class="o2-step-n">01</div>
        <h3>Assess</h3>
        <p>Current level, case, food preferences and lifestyle are mapped in full.</p>
      </article>
      <article class="o2-step o2-card r" d="2">
        <div class="o2-step-n">02</div>
        <h3>Build</h3>
        <p>Training, nutrition and guidance combined into one clear plan.</p>
      </article>
      <article class="o2-step o2-card r" d="3">
        <div class="o2-step-n">03</div>
        <h3>Follow</h3>
        <p>Weekly check-ins keep everything adjustable as your body responds.</p>
      </article>
      <article class="o2-step o2-card r" d="4">
        <div class="o2-step-n">04</div>
        <h3>Upgrade</h3>
        <p>The system evolves with you — goals shift, the plan shifts with them.</p>
      </article>
    </div>
  </div>
</section>

<!-- ══ WHAT YOU GET ══════════════════════════ -->
<section class="o2-sec" style="padding-top:48px;">
  <div class="o2-inner">
    <div style="text-align:center;margin-bottom:36px;">
      <span class="o2-tag r">What you receive</span>
      <h2 class="r" d="1">Every output, delivered</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;">
      {% for item in pages.home.en.what_you_get.items %}
      <article class="o2-card r" d="{{ loop.index }}">
        <span class="o2-tag">Output 0{{ loop.index }}</span>
        <h3 style="margin-top:10px;">{{ item.title }}</h3>
        <p style="margin-top:8px;">{{ item.text }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ══ PLANS ════════════════════════════════ -->
<section class="o2-sec" style="background:rgba(0,8,20,0.60);" id="plans">
  <div class="o2-inner">
    <div class="o2-split" style="margin-bottom:40px;">

      <div class="o2-obj-zone r" style="--glow:rgba(168,255,120,0.22);">
        <div class="o2-obj o2-bottle"></div>
      </div>

      <div>
        <span class="o2-tag r">{{ pages.home.en.plans_section.kicker }}</span>
        <h2 class="r" d="1">{{ pages.home.en.plans_section.title }}</h2>
        <p class="r" d="2">
          Clear access levels built around real goals — pick what fits your pace.
        </p>
      </div>

    </div>

    <div class="o2-plans">
      {% for key in ["basic","standard","advanced"] %}
      {% set p = plans[key] %}
      <a class="o2-plan o2-card r{% if p.highlight %} hot{% endif %}" d="{{ loop.index }}"
         href="{{ ('/en/plans/' + p.slug + '/') | url }}">
        <span class="o2-tag">{{ "Most popular" if p.highlight else "Access level" }}</span>
        <h3 style="margin-top:10px;margin-bottom:10px;">{{ p.en.name }}</h3>
        <p>{{ p.en.blurb }}</p>
        <div style="margin-top:12px;">
          <div class="o2-prow"><span>1 month</span><b>{{ p.pricing.egypt.m1.amount }} {{ p.pricing.egypt.m1.currency }}</b></div>
          <div class="o2-prow"><span>3 months</span><b>{{ p.pricing.egypt.m3.amount }} {{ p.pricing.egypt.m3.currency }}/mo</b></div>
          <div class="o2-prow"><span>6 months</span><b>{{ p.pricing.egypt.m6.amount }} {{ p.pricing.egypt.m6.currency }}/mo</b></div>
        </div>
        <ul class="o2-feats">
          {% for feature in p.en.features %}{% if loop.index <= 5 %}
          <li>{{ feature }}</li>
          {% endif %}{% endfor %}
        </ul>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ══ PROOF / RESULTS ═══════════════════════ -->
<section class="o2-sec">
  <div class="o2-inner">
    <div style="text-align:center;margin-bottom:40px;">
      <span class="o2-tag r">Real results</span>
      <h2 class="r" d="1">Numbers that speak</h2>
    </div>
    <div class="o2-proof">
      {% for item in pages.home.en.results.items %}
      <div class="o2-sig o2-card r" d="{{ loop.index }}">
        <div>
          <span class="o2-tag">Signal</span>
          <strong>{{ item.value }}{{ item.unit }}</strong>
          <p style="margin-top:8px;">{{ item.text }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ══ CONTACT / CTA ═════════════════════════ -->
<section class="o2-sec" style="background:rgba(0,8,20,0.60);" id="contact">
  <div class="o2-inner">
    <div class="o2-split">

      <article class="o2-card r" style="padding:36px 38px;">
        <span class="o2-tag">{{ pages.home.en.cta.badge }}</span>
        <h2 style="margin-top:14px;">{{ pages.home.en.cta.title }}</h2>
        <p style="margin-top:14px;">{{ pages.home.en.cta.description }}</p>
        <a class="o2-pill big" href="{{ site.googleForm }}">{{ pages.home.en.cta.button }}</a>
      </article>

      <div class="o2-faqs r" d="1">
        <article class="o2-card">
          <b>Is this only training?</b>
          <p>No — training, nutrition and ongoing follow-up are all included.</p>
        </article>
        <article class="o2-card">
          <b>Not sure where to start?</b>
          <p>{{ pages.services.en.cta.description }}</p>
        </article>
        <article class="o2-card">
          <b>What makes it different?</b>
          <p>Built entirely around your goals, schedule, lifestyle and health status.</p>
        </article>
      </div>

    </div>
  </div>
</section>

</div><!-- /.o2 -->

<script>
(function(){
  /* ── Ken Burns + scroll parallax on hero ── */
  var para = document.getElementById('heroPara');
  if(para && window.matchMedia('(prefers-reduced-motion:no-preference)').matches){
    window.addEventListener('scroll',function(){
      var y = window.scrollY;
      /* slow the image relative to scroll — cinematic depth */
      para.style.transform = 'translateY('+( y * 0.38 )+'px)';
    },{passive:true});
  }

  /* ── Scroll reveal ── */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('on'); io.unobserve(e.target); }
    });
  },{threshold:0.10,rootMargin:'0px 0px -36px 0px'});

  document.querySelectorAll('.r').forEach(function(el){ io.observe(el); });
})();
</script>
