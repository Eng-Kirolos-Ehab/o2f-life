<style>
.o2f-cinema{--green:#72d36b;--mint:#00d9a3;--deep:#06110d;--ink:#18201c;--muted:#6d776f;min-height:100vh;background:#f6f6f4;color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow:hidden}.o2f-cinema *{box-sizing:border-box}.cinema-shell{position:sticky;top:72px;z-index:5;min-height:82vh;display:grid;place-items:center;padding:clamp(1rem,3vw,2rem)}.cinema-stage{position:relative;width:min(1180px,88vw);height:min(620px,58vw);min-height:420px;border-radius:46px;overflow:hidden;background:#101815;box-shadow:0 34px 70px rgba(0,0,0,.22),0 8px 22px rgba(0,0,0,.12);isolation:isolate;transform:translateZ(0)}.cinema-stage:before{content:"";position:absolute;inset:0;border-radius:inherit;border:16px solid rgba(2,6,5,.95);z-index:10;pointer-events:none}.cinema-bg{position:absolute;inset:-12%;background-image:var(--scene,url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2200&q=85'));background-size:cover;background-position:center;filter:saturate(.92) contrast(1.05);transform:translate3d(var(--px,0),var(--py,0),0) scale(1.08);transition:background-image .55s ease,transform .18s linear}.cinema-stage:after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 38%,rgba(255,255,255,.2),transparent 25%),linear-gradient(90deg,rgba(0,0,0,.58),rgba(0,0,0,.18) 45%,rgba(0,0,0,.48)),linear-gradient(180deg,rgba(255,255,255,.12),rgba(1,10,7,.34));z-index:1}.cinema-nav{position:absolute;left:56px;top:52px;z-index:12;width:22px;height:16px;display:grid;gap:5px}.cinema-nav i{height:2px;border-radius:99px;background:#fff;display:block}.cinema-pill{position:absolute;right:56px;top:46px;z-index:12;border:1px solid rgba(255,255,255,.72);border-radius:999px;padding:.52rem 1rem;color:#fff;text-decoration:none;font-size:.8rem;font-weight:800;background:rgba(255,255,255,.08);backdrop-filter:blur(10px)}.cinema-copy{position:absolute;inset:0;z-index:11;display:grid;place-items:center;text-align:center;padding:4rem;color:#fff;transition:opacity .35s ease,transform .35s ease}.cinema-copy.is-product{opacity:.08;transform:translateY(-22px) scale(.94)}.cinema-copy small{display:inline-block;margin-bottom:.9rem;font-size:.78rem;font-weight:900;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.82)}.cinema-title{font-size:clamp(2.6rem,6vw,5.4rem);line-height:.95;letter-spacing:-.065em;max-width:900px;margin:0;text-wrap:balance;text-shadow:0 18px 50px rgba(0,0,0,.4)}.cinema-desc{max-width:560px;margin:1.15rem auto 1.6rem;color:rgba(255,255,255,.84);line-height:1.65;font-size:1rem}.cinema-cta{display:inline-flex;align-items:center;justify-content:center;min-width:138px;border:1px solid rgba(255,255,255,.78);border-radius:999px;padding:.72rem 1.2rem;color:#fff;text-decoration:none;font-size:.82rem;font-weight:900;background:rgba(0,0,0,.06);backdrop-filter:blur(10px)}.product-layer{position:absolute;inset:0;z-index:12;display:grid;place-items:center;pointer-events:none;perspective:1000px}.fitness-object{position:relative;opacity:0;transform:translate3d(0,60px,0) rotate(-10deg) scale(.65);transition:opacity .45s ease,transform .7s cubic-bezier(.2,.9,.2,1);filter:drop-shadow(0 28px 28px rgba(0,0,0,.32))}.fitness-object.show{opacity:1;transform:translate3d(0,0,0) rotate(var(--r,-8deg)) scale(var(--s,1))}.obj-bottle{width:95px;height:270px;border-radius:42px 42px 48px 48px;background:linear-gradient(90deg,#276d33,#75d35e 36%,#d9ffd0 48%,#5bbb4c 58%,#1d6a34);box-shadow:inset 16px 0 28px rgba(255,255,255,.18),inset -18px 0 30px rgba(0,0,0,.2)}.obj-bottle:before{content:"";position:absolute;left:26px;right:26px;top:-35px;height:42px;border-radius:16px 16px 9px 9px;background:linear-gradient(90deg,#101816,#2f3530,#111);box-shadow:0 6px 0 rgba(255,255,255,.08) inset}.obj-bottle:after{content:"";position:absolute;left:24px;right:24px;top:-52px;height:52px;border:11px solid #111816;border-bottom:0;border-radius:38px 38px 0 0}.obj-dumbbell{width:300px;height:98px;display:flex;align-items:center;justify-content:space-between;--r:12deg;--s:1}.obj-dumbbell span{width:76px;height:132px;border-radius:24px;background:linear-gradient(180deg,#f2fff0,#74d46b 55%,#1d6d34);box-shadow:inset 0 0 20px rgba(255,255,255,.44),inset 0 -18px 22px rgba(0,0,0,.18)}.obj-dumbbell i{position:absolute;left:70px;right:70px;height:24px;border-radius:999px;background:linear-gradient(90deg,#14221a,#eaffdf 46%,#15351e)}.obj-kettle{width:190px;height:190px;border-radius:50% 50% 44% 44%;background:linear-gradient(135deg,#eaffdf,#78d86c 40%,#1b7337 78%);--r:-9deg;box-shadow:inset -18px -28px 35px rgba(0,0,0,.18),inset 20px 15px 30px rgba(255,255,255,.22)}.obj-kettle:before{content:"";position:absolute;left:45px;right:45px;top:-48px;height:78px;border:22px solid #1b211d;border-bottom:0;border-radius:58px 58px 0 0}.obj-rope{width:250px;height:250px;border:14px solid #78d86c;border-radius:50%;--r:22deg;background:radial-gradient(circle,transparent 55%,rgba(255,255,255,.16) 56%,transparent 62%)}.obj-rope:before,.obj-rope:after{content:"";position:absolute;width:24px;height:90px;border-radius:999px;background:#161d19;bottom:-45px}.obj-rope:before{left:40px;transform:rotate(20deg)}.obj-rope:after{right:40px;transform:rotate(-20deg)}.story-track{position:relative;z-index:3;margin-top:-78vh;padding-bottom:18vh}.story-panel{min-height:88vh;display:grid;align-items:end;padding:0 clamp(1rem,6vw,5rem) 7vh}.story-card{width:min(430px,92vw);border:1px solid rgba(8,20,14,.08);border-radius:28px;background:rgba(255,255,255,.72);backdrop-filter:blur(20px);box-shadow:0 24px 80px rgba(0,0,0,.08);padding:1.35rem}.story-panel:nth-child(even) .story-card{margin-left:auto}.story-card b{display:block;color:#2c8d4c;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;margin-bottom:.7rem}.story-card h2{font-size:clamp(1.65rem,3vw,2.65rem);line-height:1;letter-spacing:-.05em;margin:0 0 .8rem}.story-card p{margin:0;color:var(--muted);line-height:1.75}.mini-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin-top:1rem}.mini-grid span{border-radius:18px;background:#eef4ef;padding:.72rem;text-align:center;font-weight:900;color:#233027}.module-list{display:grid;gap:.65rem;margin-top:1rem}.module-list span{display:flex;justify-content:space-between;gap:1rem;border-radius:16px;background:#eef4ef;padding:.72rem .85rem;color:#27352b}.plan-links{display:grid;gap:.65rem;margin-top:1rem}.plan-links a{display:flex;justify-content:space-between;gap:1rem;border-radius:999px;background:#152018;color:#fff;text-decoration:none;padding:.82rem 1rem;font-weight:900}.final-space{min-height:35vh;display:grid;place-items:center;text-align:center;padding:3rem 1rem}.final-space h2{font-size:clamp(2.4rem,6vw,5rem);letter-spacing:-.07em;margin:0}.final-space p{max-width:620px;color:var(--muted);line-height:1.8}.final-space a{display:inline-flex;margin-top:1rem;border-radius:999px;background:#132018;color:#fff;text-decoration:none;padding:1rem 1.35rem;font-weight:900}@media(max-width:900px){.cinema-shell{top:58px;min-height:72vh}.cinema-stage{width:92vw;height:58vh;min-height:360px;border-radius:34px}.cinema-stage:before{border-width:10px}.cinema-nav{left:32px;top:34px}.cinema-pill{right:32px;top:28px}.cinema-title{font-size:clamp(2.4rem,11vw,4rem)}.cinema-desc{font-size:.92rem}.obj-bottle{transform:scale(.74)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.72)}.story-track{margin-top:-66vh}.story-panel{min-height:82vh;padding-bottom:4vh}.story-card,.story-panel:nth-child(even) .story-card{margin-left:auto;margin-right:auto}.mini-grid{grid-template-columns:1fr}}@media(max-width:620px){.cinema-stage{height:62vh;border-radius:28px}.cinema-copy{padding:2rem}.cinema-pill{display:none}.story-track{margin-top:-60vh}.story-card{padding:1.05rem}.obj-bottle{transform:scale(.6)}.obj-dumbbell,.obj-kettle,.obj-rope{transform:scale(.58)}}@media(prefers-reduced-motion:reduce){.fitness-object,.cinema-bg,.cinema-copy{transition:none!important}}
</style>

<div class="o2f-cinema" id="o2fCinema">
  <div class="cinema-shell" aria-hidden="false">
    <div class="cinema-stage" id="cinemaStage">
      <div class="cinema-bg" id="cinemaBg"></div>
      <div class="cinema-nav"><i></i><i></i><i></i></div>
      <a href="{{ '/en/contact/' | url }}" class="cinema-pill">Start Now</a>
      <div class="cinema-copy" id="cinemaCopy">
        <div>
          <small id="stageEyebrow">O2F / Nature Performance</small>
          <h1 class="cinema-title" id="stageTitle">Hydration, Strength, Recovery</h1>
          <p class="cinema-desc" id="stageDesc">A calm cinematic system for training, nutrition, follow-up and natural health direction.</p>
          <a href="{{ '/en/plans/' | url }}" class="cinema-cta">Launch protocol</a>
        </div>
      </div>
      <div class="product-layer"><div class="fitness-object obj-bottle" id="fitnessObject"></div></div>
    </div>
  </div>

  <div class="story-track">
    <section class="story-panel" data-object="none" data-scene="forest" data-eyebrow="O2F / Nature Performance" data-title="Hydration, Strength, Recovery" data-desc="{{ pages.home.en.hero.description | escape }}">
      <div class="story-card"><b>Intro Scene</b><h2>Same clean product-animation feeling.</h2><p>The page opens like the reference: white canvas, rounded cinematic viewport, forest depth, centered headline and calm premium spacing.</p><div class="mini-grid"><span>{{ site.stats.years }}</span><span>{{ site.stats.clients }}</span><span>{{ site.stats.support }}</span></div></div>
    </section>

    <section class="story-panel" data-object="bottle" data-scene="waterfall" data-eyebrow="Hydration Layer" data-title="A green bottle floats into the scene" data-desc="Hydration becomes the first visual product moment, with the object floating in front of a moving waterfall background.">
      <div class="story-card"><b>Object 01</b><h2>Green bottle moment.</h2><p>دي أقرب للّقطة اللي في الفيديو: الزجاجة تظهر في منتصف الكارت فوق خلفية طبيعة متحركة بهدوء.</p></div>
    </section>

    <section class="story-panel" data-object="dumbbell" data-scene="forest" data-eyebrow="Strength Layer" data-title="Training appears as a premium object" data-desc="The dumbbell replaces the bottle as the user scrolls, so every section has its own gym signal without breaking the same visual world.">
      <div class="story-card"><b>Core Modules</b><h2>Training, nutrition and follow-up.</h2><div class="module-list">{% for item in pages.home.en.pillars.items %}<span>{{ item.title }} <small>0{{ loop.index }}</small></span>{% endfor %}</div></div>
    </section>

    <section class="story-panel" data-object="kettle" data-scene="valley" data-eyebrow="Power Layer" data-title="The system reads the body before it pushes" data-desc="Assessment, lifestyle load, recovery signal and adherence risk are presented with a calmer premium mood instead of a hard tech dashboard.">
      <div class="story-card"><b>Diagnostics</b><h2>Before the plan starts, the system reads the problem.</h2><p>O2F studies patterns, builds rules, and tracks the response so the plan stays practical and personal.</p></div>
    </section>

    <section class="story-panel" data-object="rope" data-scene="mist" data-eyebrow="Flow Layer" data-title="A mission sequence, not a static page" data-desc="Diagnose, encode, execute and evolve. The background keeps moving subtly while the object changes with the section.">
      <div class="story-card"><b>Protocol Flow</b><h2>Diagnose → Encode → Execute → Evolve</h2><p>The user understands what happens after joining before they click.</p></div>
    </section>

    <section class="story-panel" data-object="bottle" data-scene="waterfall" data-eyebrow="Outputs" data-title="Practical tools, not vague motivation" data-desc="Plans, weekly calibration, nutrition structure and follow-up are presented as clean product outputs.">
      <div class="story-card"><b>What you get</b><h2>Clear deliverables.</h2><div class="module-list">{% for item in pages.home.en.what_you_get.items %}<span>{{ item.title }} <small>0{{ loop.index }}</small></span>{% endfor %}</div></div>
    </section>

    <section class="story-panel" data-object="dumbbell" data-scene="forest" data-eyebrow="Access Levels" data-title="Choose your operating mode" data-desc="Each plan becomes an access level inside the same transformation journey.">
      <div class="story-card"><b>Plans</b><h2>Choose your mode.</h2><div class="plan-links">{% for key in ["basic","standard","advanced"] %}{% set p = plans[key] %}<a href="{{ ('/en/plans/' + p.slug + '/') | url }}"><span>{{ p.en.name }}</span><span>→</span></a>{% endfor %}</div></div>
    </section>
  </div>

  <div class="final-space">
    <div><h2>Your next version needs a calm system.</h2><p>{{ pages.home.en.cta.description }}</p><a href="{{ '/en/contact/' | url }}">Activate transformation</a></div>
  </div>
</div>

<script>
(function(){
  const root=document.getElementById('o2fCinema');
  const stage=document.getElementById('cinemaStage');
  const bg=document.getElementById('cinemaBg');
  const obj=document.getElementById('fitnessObject');
  const copy=document.getElementById('cinemaCopy');
  const title=document.getElementById('stageTitle');
  const desc=document.getElementById('stageDesc');
  const eyebrow=document.getElementById('stageEyebrow');
  const panels=[...document.querySelectorAll('.story-panel')];
  if(!root||!stage||!bg||!obj||!copy||!panels.length)return;
  const scenes={
    forest:"url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2200&q=85')",
    waterfall:"url('https://images.unsplash.com/photo-1432405972618-c60b0225b8f9?auto=format&fit=crop&w=2200&q=85')",
    valley:"url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2200&q=85')",
    mist:"url('https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=2200&q=85')"
  };
  const objectClasses={none:'',bottle:'obj-bottle',dumbbell:'obj-dumbbell',kettle:'obj-kettle',rope:'obj-rope'};
  const objectHTML={none:'',bottle:'',dumbbell:'<span></span><i></i><span></span>',kettle:'',rope:''};
  let current='';
  function activePanel(){
    let active=panels[0];
    panels.forEach(panel=>{const r=panel.getBoundingClientRect();if(r.top<innerHeight*.55&&r.bottom>innerHeight*.25)active=panel;});
    return active;
  }
  function render(panel){
    const object=panel.dataset.object||'none';
    if(current!==object){
      obj.className='fitness-object '+(objectClasses[object]||'');
      obj.innerHTML=objectHTML[object]||'';
      obj.classList.remove('show');
      copy.classList.toggle('is-product',object!=='none');
      requestAnimationFrame(()=>obj.classList.toggle('show',object!=='none'));
      current=object;
    }
    bg.style.setProperty('--scene',scenes[panel.dataset.scene]||scenes.forest);
    title.textContent=panel.dataset.title||title.textContent;
    desc.textContent=panel.dataset.desc||desc.textContent;
    eyebrow.textContent=panel.dataset.eyebrow||eyebrow.textContent;
  }
  function update(){
    const rootRect=root.getBoundingClientRect();
    const progress=Math.max(0,Math.min(1,(-rootRect.top)/(rootRect.height-innerHeight||1)));
    bg.style.setProperty('--px',`${Math.sin(progress*5.2)*18}px`);
    bg.style.setProperty('--py',`${-progress*90}px`);
    const s=1+progress*.05;
    stage.style.transform=`scale(${s})`;
    render(activePanel());
  }
  let ticking=false;
  function request(){if(!ticking){requestAnimationFrame(()=>{update();ticking=false});ticking=true}}
  update();addEventListener('scroll',request,{passive:true});addEventListener('resize',request);
})();
</script>
