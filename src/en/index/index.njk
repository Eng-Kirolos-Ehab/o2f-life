---
title: "O2F English"
description: "Official English homepage for O2F Life."
permalink: /en/index.html
---

<style>
  .en-home{min-height:100vh;background:#06110d;color:#fff;font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;overflow:hidden;position:relative}.en-home *{box-sizing:border-box}.en-home:before{content:"";position:absolute;inset:-20%;background:radial-gradient(circle at 20% 20%,rgba(168,255,120,.25),transparent 28%),radial-gradient(circle at 80% 70%,rgba(0,217,163,.18),transparent 32%),linear-gradient(135deg,#06110d,#0b2016 60%,#020705);z-index:0}.en-wrap{position:relative;z-index:1;width:min(1120px,100%);margin:0 auto;padding:clamp(80px,12vh,140px) clamp(18px,5vw,72px)}.en-nav{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:clamp(70px,12vh,120px)}.en-brand{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-weight:950}.en-brand img{width:44px;height:44px;border-radius:50%;object-fit:cover}.en-links{display:flex;gap:14px;flex-wrap:wrap}.en-links a,.en-btn{color:#fff;text-decoration:none;border:1px solid rgba(255,255,255,.26);background:rgba(255,255,255,.1);border-radius:999px;padding:11px 15px;font-size:13px;font-weight:850;backdrop-filter:blur(14px)}.en-grid{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);gap:clamp(24px,5vw,70px);align-items:center}.en-kicker{display:inline-block;color:#a8ff78;font-size:12px;font-weight:950;letter-spacing:.18em;text-transform:uppercase;margin-bottom:16px}.en-home h1{font-size:clamp(46px,7vw,92px);line-height:.9;letter-spacing:-.07em;margin:0 0 18px}.en-home p{color:rgba(247,255,247,.78);line-height:1.75;font-size:clamp(16px,1.3vw,19px)}.en-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:26px}.en-btn.primary{background:linear-gradient(135deg,rgba(168,255,120,.28),rgba(0,217,163,.16));border-color:rgba(168,255,120,.45)}.en-card{border:1px solid rgba(255,255,255,.22);background:linear-gradient(145deg,rgba(255,255,255,.18),rgba(255,255,255,.07));backdrop-filter:blur(22px);border-radius:34px;padding:26px;box-shadow:0 26px 90px rgba(0,0,0,.26)}.en-card h2{margin:0 0 12px;font-size:30px}.en-list{display:grid;gap:12px;margin-top:18px}.en-list div{padding:14px;border-radius:18px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12)}.en-list b{display:block;margin-bottom:4px}@media(max-width:850px){.en-grid{grid-template-columns:1fr}.en-nav{align-items:flex-start;flex-direction:column}.en-links a{font-size:12px;padding:10px 12px}.en-home h1{font-size:clamp(42px,13vw,68px)}}
</style>

<div class="en-home">
  <div class="en-wrap">
    <header class="en-nav">
      <a class="en-brand" href="{{ '/en/' | url }}">
        <img src="{{ site.logoUrl | url }}" alt="{{ site.name }}">
        <span>{{ site.name }}</span>
      </a>
      <nav class="en-links">
        <a href="{{ '/en/services/' | url }}">Services</a>
        <a href="{{ '/en/plans/' | url }}">Plans</a>
        <a href="{{ '/en/contact/' | url }}">Contact</a>
        <a href="{{ '/en/home-v2/' | url }}">Home V2</a>
      </nav>
    </header>

    <main class="en-grid">
      <section>
        <span class="en-kicker">{{ pages.home.en.hero.badge }}</span>
        <h1>{{ pages.home.en.hero.title_line1 }} {{ pages.home.en.hero.title_line2_gradient }}</h1>
        <p>{{ pages.home.en.hero.description }}</p>
        <div class="en-actions">
          <a class="en-btn primary" href="{{ site.googleForm }}">{{ pages.home.en.hero.cta_primary }}</a>
          <a class="en-btn" href="{{ '/en/home-v2/' | url }}">Open experimental Home V2</a>
        </div>
      </section>

      <aside class="en-card">
        <span class="en-kicker">O2F Life</span>
        <h2>{{ pages.home.en.pillars.title }}</h2>
        <p>{{ pages.home.en.seo.description }}</p>
        <div class="en-list">
          {% for item in pages.home.en.pillars.items %}
          <div>
            <b>{{ item.title }}</b>
            <span>{{ item.text }}</span>
          </div>
          {% endfor %}
        </div>
      </aside>
    </main>
  </div>
</div>
